{"ast":null,"code":"import { ref, onMounted, watch } from 'vue';\nimport { useRoute } from 'vue-router';\nimport { KeywordCloud, PlotTrendChart, StructureAnalysisChart } from '@/components/visualization';\nimport visualizationService from '@/api/visualization';\nimport novelService from '@/services/novel';\nexport default {\n  name: 'NovelVisualizationView',\n  components: {\n    KeywordCloud,\n    PlotTrendChart,\n    StructureAnalysisChart\n  },\n  setup() {\n    const route = useRoute();\n\n    // 小说信息\n    const novel = ref(null);\n    const loading = ref(false);\n    const errorMessage = ref('');\n\n    // 可视化数据\n    const keywordData = ref([]);\n    const emotionalData = ref([]);\n    const structureData = ref({});\n\n    // 单项加载状态\n    const loadingKeywords = ref(false);\n    const loadingEmotional = ref(false);\n    const loadingStructure = ref(false);\n\n    // 获取小说信息\n    const fetchNovelInfo = async novelId => {\n      try {\n        const response = await novelService.getNovelById(novelId);\n        novel.value = response.data;\n      } catch (error) {\n        console.error('获取小说信息失败:', error);\n        errorMessage.value = '获取小说信息失败: ' + (error.response?.data?.error || error.message);\n      }\n    };\n\n    // 获取关键词云数据\n    const fetchKeywordData = async novelId => {\n      loadingKeywords.value = true;\n      try {\n        const response = await visualizationService.getKeywordCloudData(novelId);\n        keywordData.value = response.data || [];\n      } catch (error) {\n        console.error('获取关键词云数据失败:', error);\n        errorMessage.value = '获取关键词云数据失败: ' + (error.response?.data?.error || error.message);\n      } finally {\n        loadingKeywords.value = false;\n      }\n    };\n\n    // 获取情节波动图数据\n    const fetchEmotionalData = async novelId => {\n      loadingEmotional.value = true;\n      try {\n        const response = await visualizationService.getEmotionalFluctuationData(novelId);\n        // 如果数据格式正确，解析emotional字段\n        emotionalData.value = response.data && response.data.emotional ? response.data.emotional : response.data || [];\n      } catch (error) {\n        console.error('获取情节波动图数据失败:', error);\n        errorMessage.value = '获取情节波动图数据失败: ' + (error.response?.data?.error || error.message);\n      } finally {\n        loadingEmotional.value = false;\n      }\n    };\n\n    // 获取结构分析数据\n    const fetchStructureData = async novelId => {\n      loadingStructure.value = true;\n      try {\n        const response = await visualizationService.getStructureAnalysisData(novelId);\n        structureData.value = response.data || {};\n      } catch (error) {\n        console.error('获取结构分析数据失败:', error);\n        errorMessage.value = '获取结构分析数据失败: ' + (error.response?.data?.error || error.message);\n      } finally {\n        loadingStructure.value = false;\n      }\n    };\n\n    // 一次性获取所有可视化数据\n    const fetchAllVisualizationData = async novelId => {\n      loading.value = true;\n      errorMessage.value = '';\n      loadingKeywords.value = true;\n      loadingEmotional.value = true;\n      loadingStructure.value = true;\n      try {\n        const response = await visualizationService.getAllVisualizationData(novelId);\n        const data = response.data;\n\n        // 解析各项数据\n        if (data.keywords) {\n          keywordData.value = data.keywords;\n        }\n        if (data.emotional) {\n          emotionalData.value = data.emotional;\n        }\n        if (data.structure) {\n          structureData.value = data.structure;\n        }\n      } catch (error) {\n        console.error('获取可视化数据失败:', error);\n        errorMessage.value = '获取可视化数据失败: ' + (error.response?.data?.error || error.message);\n      } finally {\n        loading.value = false;\n        loadingKeywords.value = false;\n        loadingEmotional.value = false;\n        loadingStructure.value = false;\n      }\n    };\n\n    // 当路由参数变化时重新加载数据\n    watch(() => route.params.id, newId => {\n      if (newId) {\n        const novelId = parseInt(newId);\n        fetchNovelInfo(novelId);\n        fetchAllVisualizationData(novelId);\n      }\n    });\n\n    // 组件挂载时加载数据\n    onMounted(() => {\n      const novelId = route.params.id ? parseInt(route.params.id) : null;\n      if (novelId) {\n        fetchNovelInfo(novelId);\n        fetchAllVisualizationData(novelId);\n      }\n    });\n    return {\n      novel,\n      loading,\n      errorMessage,\n      keywordData,\n      emotionalData,\n      structureData,\n      loadingKeywords,\n      loadingEmotional,\n      loadingStructure\n    };\n  }\n};","map":{"version":3,"names":["ref","onMounted","watch","useRoute","KeywordCloud","PlotTrendChart","StructureAnalysisChart","visualizationService","novelService","name","components","setup","route","novel","loading","errorMessage","keywordData","emotionalData","structureData","loadingKeywords","loadingEmotional","loadingStructure","fetchNovelInfo","novelId","response","getNovelById","value","data","error","console","message","fetchKeywordData","getKeywordCloudData","fetchEmotionalData","getEmotionalFluctuationData","emotional","fetchStructureData","getStructureAnalysisData","fetchAllVisualizationData","getAllVisualizationData","keywords","structure","params","id","newId","parseInt"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\NovelVisualizationView.vue"],"sourcesContent":["<template>\r\n  <div class=\"novel-visualization-container\">\r\n    <div class=\"header\">\r\n      <h2>{{ novel ? novel.title : '小说' }}可视化分析</h2>\r\n      <p v-if=\"novel\">作者: {{ novel.author }}</p>\r\n    </div>\r\n    \r\n    <el-tabs type=\"border-card\" class=\"visualization-tabs\">\r\n      <el-tab-pane label=\"关键词云\">\r\n        <keyword-cloud \r\n          :keywords=\"keywordData\" \r\n          :loading=\"loadingKeywords\"\r\n          title=\"小说关键词分布\"\r\n          height=\"400px\"\r\n        />\r\n      </el-tab-pane>\r\n      \r\n      <el-tab-pane label=\"情节波动图\">\r\n        <plot-trend-chart \r\n          :plot-data=\"emotionalData\" \r\n          :loading=\"loadingEmotional\"\r\n          title=\"情节波动趋势\"\r\n          height=\"400px\"\r\n        />\r\n      </el-tab-pane>\r\n      \r\n      <el-tab-pane label=\"结构分析\">\r\n        <structure-analysis-chart \r\n          :structure-data=\"structureData\" \r\n          :loading=\"loadingStructure\"\r\n          height=\"500px\"\r\n        />\r\n      </el-tab-pane>\r\n    </el-tabs>\r\n    \r\n    <!-- 加载中提示 -->\r\n    <div v-if=\"loading\" class=\"global-loading\">\r\n      <el-spinner size=\"large\" />\r\n      <p>正在加载可视化数据...</p>\r\n    </div>\r\n    \r\n    <!-- 错误提示 -->\r\n    <el-alert\r\n      v-if=\"errorMessage\"\r\n      :title=\"errorMessage\"\r\n      type=\"error\"\r\n      show-icon\r\n      @close=\"errorMessage = ''\"\r\n    />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted, watch } from 'vue'\r\nimport { useRoute } from 'vue-router'\r\nimport { KeywordCloud, PlotTrendChart, StructureAnalysisChart } from '@/components/visualization'\r\nimport visualizationService from '@/api/visualization'\r\nimport novelService from '@/services/novel'\r\n\r\nexport default {\r\n  name: 'NovelVisualizationView',\r\n  components: {\r\n    KeywordCloud,\r\n    PlotTrendChart,\r\n    StructureAnalysisChart\r\n  },\r\n  setup() {\r\n    const route = useRoute();\r\n    \r\n    // 小说信息\r\n    const novel = ref(null);\r\n    const loading = ref(false);\r\n    const errorMessage = ref('');\r\n    \r\n    // 可视化数据\r\n    const keywordData = ref([]);\r\n    const emotionalData = ref([]);\r\n    const structureData = ref({});\r\n    \r\n    // 单项加载状态\r\n    const loadingKeywords = ref(false);\r\n    const loadingEmotional = ref(false);\r\n    const loadingStructure = ref(false);\r\n    \r\n    // 获取小说信息\r\n    const fetchNovelInfo = async (novelId) => {\r\n      try {\r\n        const response = await novelService.getNovelById(novelId);\r\n        novel.value = response.data;\r\n      } catch (error) {\r\n        console.error('获取小说信息失败:', error);\r\n        errorMessage.value = '获取小说信息失败: ' + (error.response?.data?.error || error.message);\r\n      }\r\n    };\r\n    \r\n    // 获取关键词云数据\r\n    const fetchKeywordData = async (novelId) => {\r\n      loadingKeywords.value = true;\r\n      try {\r\n        const response = await visualizationService.getKeywordCloudData(novelId);\r\n        keywordData.value = response.data || [];\r\n      } catch (error) {\r\n        console.error('获取关键词云数据失败:', error);\r\n        errorMessage.value = '获取关键词云数据失败: ' + (error.response?.data?.error || error.message);\r\n      } finally {\r\n        loadingKeywords.value = false;\r\n      }\r\n    };\r\n    \r\n    // 获取情节波动图数据\r\n    const fetchEmotionalData = async (novelId) => {\r\n      loadingEmotional.value = true;\r\n      try {\r\n        const response = await visualizationService.getEmotionalFluctuationData(novelId);\r\n        // 如果数据格式正确，解析emotional字段\r\n        emotionalData.value = response.data && response.data.emotional ? \r\n                             response.data.emotional : \r\n                             response.data || [];\r\n      } catch (error) {\r\n        console.error('获取情节波动图数据失败:', error);\r\n        errorMessage.value = '获取情节波动图数据失败: ' + (error.response?.data?.error || error.message);\r\n      } finally {\r\n        loadingEmotional.value = false;\r\n      }\r\n    };\r\n    \r\n    // 获取结构分析数据\r\n    const fetchStructureData = async (novelId) => {\r\n      loadingStructure.value = true;\r\n      try {\r\n        const response = await visualizationService.getStructureAnalysisData(novelId);\r\n        structureData.value = response.data || {};\r\n      } catch (error) {\r\n        console.error('获取结构分析数据失败:', error);\r\n        errorMessage.value = '获取结构分析数据失败: ' + (error.response?.data?.error || error.message);\r\n      } finally {\r\n        loadingStructure.value = false;\r\n      }\r\n    };\r\n    \r\n    // 一次性获取所有可视化数据\r\n    const fetchAllVisualizationData = async (novelId) => {\r\n      loading.value = true;\r\n      errorMessage.value = '';\r\n      loadingKeywords.value = true;\r\n      loadingEmotional.value = true;\r\n      loadingStructure.value = true;\r\n      \r\n      try {\r\n        const response = await visualizationService.getAllVisualizationData(novelId);\r\n        const data = response.data;\r\n        \r\n        // 解析各项数据\r\n        if (data.keywords) {\r\n          keywordData.value = data.keywords;\r\n        }\r\n        \r\n        if (data.emotional) {\r\n          emotionalData.value = data.emotional;\r\n        }\r\n        \r\n        if (data.structure) {\r\n          structureData.value = data.structure;\r\n        }\r\n      } catch (error) {\r\n        console.error('获取可视化数据失败:', error);\r\n        errorMessage.value = '获取可视化数据失败: ' + (error.response?.data?.error || error.message);\r\n      } finally {\r\n        loading.value = false;\r\n        loadingKeywords.value = false;\r\n        loadingEmotional.value = false;\r\n        loadingStructure.value = false;\r\n      }\r\n    };\r\n    \r\n    // 当路由参数变化时重新加载数据\r\n    watch(() => route.params.id, (newId) => {\r\n      if (newId) {\r\n        const novelId = parseInt(newId);\r\n        fetchNovelInfo(novelId);\r\n        fetchAllVisualizationData(novelId);\r\n      }\r\n    });\r\n    \r\n    // 组件挂载时加载数据\r\n    onMounted(() => {\r\n      const novelId = route.params.id ? parseInt(route.params.id) : null;\r\n      if (novelId) {\r\n        fetchNovelInfo(novelId);\r\n        fetchAllVisualizationData(novelId);\r\n      }\r\n    });\r\n    \r\n    return {\r\n      novel,\r\n      loading,\r\n      errorMessage,\r\n      keywordData,\r\n      emotionalData,\r\n      structureData,\r\n      loadingKeywords,\r\n      loadingEmotional,\r\n      loadingStructure\r\n    };\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.novel-visualization-container {\r\n  padding: 20px;\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.header {\r\n  margin-bottom: 20px;\r\n  text-align: center;\r\n}\r\n\r\n.header h2 {\r\n  margin-bottom: 5px;\r\n}\r\n\r\n.visualization-tabs {\r\n  margin-top: 20px;\r\n}\r\n\r\n.visualization-tabs ::v-deep .el-tabs__content {\r\n  padding: 20px;\r\n}\r\n\r\n.global-loading {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  background-color: rgba(255, 255, 255, 0.8);\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n  align-items: center;\r\n  z-index: 1000;\r\n}\r\n\r\n.global-loading p {\r\n  margin-top: 10px;\r\n  color: #606266;\r\n}\r\n</style> "],"mappings":"AAqDA,SAASA,GAAG,EAAEC,SAAS,EAAEC,KAAI,QAAS,KAAI;AAC1C,SAASC,QAAO,QAAS,YAAW;AACpC,SAASC,YAAY,EAAEC,cAAc,EAAEC,sBAAqB,QAAS,4BAA2B;AAChG,OAAOC,oBAAmB,MAAO,qBAAoB;AACrD,OAAOC,YAAW,MAAO,kBAAiB;AAE1C,eAAe;EACbC,IAAI,EAAE,wBAAwB;EAC9BC,UAAU,EAAE;IACVN,YAAY;IACZC,cAAc;IACdC;EACF,CAAC;EACDK,KAAKA,CAAA,EAAG;IACN,MAAMC,KAAI,GAAIT,QAAQ,CAAC,CAAC;;IAExB;IACA,MAAMU,KAAI,GAAIb,GAAG,CAAC,IAAI,CAAC;IACvB,MAAMc,OAAM,GAAId,GAAG,CAAC,KAAK,CAAC;IAC1B,MAAMe,YAAW,GAAIf,GAAG,CAAC,EAAE,CAAC;;IAE5B;IACA,MAAMgB,WAAU,GAAIhB,GAAG,CAAC,EAAE,CAAC;IAC3B,MAAMiB,aAAY,GAAIjB,GAAG,CAAC,EAAE,CAAC;IAC7B,MAAMkB,aAAY,GAAIlB,GAAG,CAAC,CAAC,CAAC,CAAC;;IAE7B;IACA,MAAMmB,eAAc,GAAInB,GAAG,CAAC,KAAK,CAAC;IAClC,MAAMoB,gBAAe,GAAIpB,GAAG,CAAC,KAAK,CAAC;IACnC,MAAMqB,gBAAe,GAAIrB,GAAG,CAAC,KAAK,CAAC;;IAEnC;IACA,MAAMsB,cAAa,GAAI,MAAOC,OAAO,IAAK;MACxC,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMhB,YAAY,CAACiB,YAAY,CAACF,OAAO,CAAC;QACzDV,KAAK,CAACa,KAAI,GAAIF,QAAQ,CAACG,IAAI;MAC7B,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK,CAAC;QACjCb,YAAY,CAACW,KAAI,GAAI,YAAW,IAAKE,KAAK,CAACJ,QAAQ,EAAEG,IAAI,EAAEC,KAAI,IAAKA,KAAK,CAACE,OAAO,CAAC;MACpF;IACF,CAAC;;IAED;IACA,MAAMC,gBAAe,GAAI,MAAOR,OAAO,IAAK;MAC1CJ,eAAe,CAACO,KAAI,GAAI,IAAI;MAC5B,IAAI;QACF,MAAMF,QAAO,GAAI,MAAMjB,oBAAoB,CAACyB,mBAAmB,CAACT,OAAO,CAAC;QACxEP,WAAW,CAACU,KAAI,GAAIF,QAAQ,CAACG,IAAG,IAAK,EAAE;MACzC,EAA