",\n      onClick: $setup.viewResults\n    }, {\n      default: _withCtx(() => _cache[5] || (_cache[5] = [_createTextVNode(\"查看分析结果\")])),\n      _: 1 /* STABLE */\n    }, 8 /* PROPS */, [\"onClick\"]), _createVNode(_component_el_button, {\n      onClick: $setup.backToHome\n    }, {\n      default: _withCtx(() => _cache[6] || (_cache[6] = [_createTextVNode(\"返回首页\")])),\n      _: 1 /* STABLE */\n    }, 8 /* PROPS */, [\"onClick\"])])) : _createCommentVNode(\"v-if\", true)]),\n    _: 1 /* STABLE */\n  })]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","_createVNode","_component_el_card","header","_withCtx","_createElementVNode","_hoisted_2","$setup","isDemo","_createBlock","_component_el_tag","type","default","_cache","_createTextVNode","_","_createCommentVNode","_hoisted_3","_component_el_progress","percentage","status","progressStatus","_hoisted_4","_toDisplayString","statusText","_hoisted_5","_component_el_alert","title","description","closable","processingStatus","_hoisted_6","_hoisted_7","currentChapter","totalChapters","_hoisted_8","estimatedTime","_hoisted_9","_component_el_button","onClick","retry","_hoisted_10","viewResults","backToHome"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\AnalyzeView.vue"],"sourcesContent":["<template>\r\n  <div class=\"analyze-container\">\r\n    <el-card class=\"analyze-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <h2>小说处理中</h2>\r\n          <el-tag type=\"warning\" v-if=\"isDemo\">演示模式</el-tag>\r\n        </div>\r\n      </template>\r\n      \r\n      <div class=\"progress-info\">\r\n        <el-progress :percentage=\"percentage\" :status=\"progressStatus\"></el-progress>\r\n        <p class=\"status-text\">{{ statusText }}</p>\r\n        \r\n        <div v-if=\"isDemo\" class=\"demo-notice\">\r\n          <el-alert\r\n            title=\"演示模式提示\"\r\n            type=\"warning\"\r\n            description=\"当前处于演示模式，使用的是预设数据。在实际项目中，这里会展示真实的处理进度。\"\r\n            show-icon\r\n            :closable=\"false\"\r\n          >\r\n          </el-alert>\r\n        </div>\r\n        \r\n        <div class=\"details-container\" v-if=\"processingStatus !== 'FAILED'\">\r\n          <div class=\"detail-item\">\r\n            <h4>处理章节</h4>\r\n            <p>{{ currentChapter }} / {{ totalChapters }}</p>\r\n          </div>\r\n          <div class=\"detail-item\">\r\n            <h4>预计完成时间</h4>\r\n            <p>{{ estimatedTime }}</p>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"error-container\" v-if=\"processingStatus === 'FAILED'\">\r\n          <el-alert\r\n            title=\"处理失败\"\r\n            type=\"error\"\r\n            description=\"小说处理过程中出现错误，请重试或联系客服。\"\r\n            show-icon\r\n          >\r\n          </el-alert>\r\n          <el-button type=\"primary\" @click=\"retry\" class=\"retry-btn\">重新尝试</el-button>\r\n        </div>\r\n      </div>\r\n      \r\n      <div class=\"action-buttons\" v-if=\"processingStatus === 'COMPLETED'\">\r\n        <el-button type=\"primary\" @click=\"viewResults\">查看分析结果</el-button>\r\n        <el-button @click=\"backToHome\">返回首页</el-button>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, computed, onMounted, onBeforeUnmount } from 'vue'\r\nimport { useStore } from 'vuex'\r\nimport { useRouter } from 'vue-router'\r\nimport { novelApi } from '../services/novelApi'\r\n\r\nexport default {\r\n  name: 'AnalyzeView',\r\n  setup() {\r\n    const store = useStore()\r\n    const router = useRouter()\r\n    \r\n    // 演示模式标志\r\n    const isDemo = computed(() => !store.state.isApiAvailable)\r\n    \r\n    // 模拟处理状态相关变量\r\n    const processingStatus = computed(() => store.state.processingStatus || 'PROCESSING')\r\n    const percentage = computed(() => store.getters.processingPercentage)\r\n    const currentChapter = ref(0)\r\n    const totalChapters = ref(10)\r\n    const estimatedTime = ref('约30秒')\r\n    \r\n    // 根据处理状态显示不同的状态文本\r\n    const statusText = computed(() => {\r\n      switch (processingStatus.value) {\r\n        case 'UPLOADING': return '正在上传小说文件...'\r\n        case 'PROCESSING': return isDemo.value ? '正在分析小说内容（演示模式）...' : '正在分析小说内容...'\r\n        case 'COMPLETED': return '分析完成！'\r\n        case 'FAILED': return '处理失败'\r\n        default: return '准备中...'\r\n      }\r\n    })\r\n    \r\n    // 进度条状态\r\n    const progressStatus = computed(() => {\r\n      if (processingStatus.value === 'COMPLETED') return 'success'\r\n      if (processingStatus.value === 'FAILED') return 'exception'\r\n      return ''\r\n    })\r\n    \r\n    // 模拟进度更新\r\n    let interval = null\r\n    \r\n    onMounted(() => {\r\n      if (processingStatus.value === 'PROCESSING') {\r\n        // 模拟章节处理进度\r\n        currentChapter.value = 0\r\n        interval = setInterval(() => {\r\n          if (currentChapter.value < totalChapters.value) {\r\n            currentChapter.value += 1\r\n            \r\n            // 模拟完成\r\n            if (currentChapter.value >= totalChapters.value) {\r\n              store.commit('SET_PROCESSING_STATUS', 'COMPLETED')\r\n              clearInterval(interval)\r\n            }\r\n          }\r\n        }, 300) // 稍微放慢进度，使演示更真实\r\n      }\r\n    })\r\n    \r\n    onBeforeUnmount(() => {\r\n      if (interval) {\r\n        clearInterval(interval)\r\n      }\r\n    })\r\n    \r\n    // 查看结果\r\n    const viewResults = () => {\r\n      router.push({ name: 'novel-detail', params: { id: 3 } })\r\n    }\r\n    \r\n    // 返回首页\r\n    const backToHome = () => {\r\n      router.push({ name: 'home' })\r\n    }\r\n    \r\n    // 重试\r\n    const retry = () => {\r\n      store.commit('SET_PROCESSING_STATUS', 'PROCESSING')\r\n      currentChapter.value = 0\r\n      \r\n      // 重启模拟进度\r\n      interval = setInterval(() => {\r\n        if (currentChapter.value < totalChapters.value) {\r\n          currentChapter.value += 1\r\n          \r\n          if (currentChapter.value >= totalChapters.value) {\r\n            store.commit('SET_PROCESSING_STATUS', 'COMPLETED')\r\n            clearInterval(interval)\r\n          }\r\n        }\r\n      }, 300)\r\n    }\r\n    \r\n    // 轮询获取处理状态（如果API可用）\r\n    const setupStatusPolling = () => {\r\n      // 如果API不可用，使用本地模拟\r\n      if (!store.state.isApiAvailable) {\r\n        return;\r\n      }\r\n      \r\n      // 获取URL中的novelId参数\r\n      const urlParams = new URLSearchParams(window.location.search);\r\n      const novelId = urlParams.get('id') || 3; // 默认演示ID\r\n      \r\n      // 设置定时器轮询状态\r\n      interval = setInterval(async () => {\r\n        try {\r\n          const response = await novelApi.getNovelStatus(novelId);\r\n          store.commit('SET_PROCESSING_STATUS', response.status.toUpperCase());\r\n          \r\n          if (response.status === 'COMPLETED' || response.status === 'FAILED') {\r\n            clearInterval(interval);\r\n          }\r\n        } catch (error) {\r\n          console.error('获取处理状态失败', error);\r\n        }\r\n      }, 2000);\r\n    }\r\n    \r\n    return {\r\n      processingStatus,\r\n      percentage,\r\n      currentChapter,\r\n      totalChapters,\r\n      estimatedTime,\r\n      statusText,\r\n      progressStatus,\r\n      viewResults,\r\n      backToHome,\r\n      retry,\r\n      isDemo\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.analyze-container {\r\n  max-width: 800px;\r\n  margin: 40px auto;\r\n}\r\n\r\n.analyze-card {\r\n  border-radius: 8px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.progress-info {\r\n  padding: 20px;\r\n}\r\n\r\n.status-text {\r\n  text-align: center;\r\n  font-size: 16px;\r\n  margin: 20px 0;\r\n  color: #606266;\r\n}\r\n\r\n.demo-notice {\r\n  margin: 20px 0;\r\n}\r\n\r\n.details-container {\r\n  display: flex;\r\n  justify-content: space-around;\r\n  margin: 30px 0;\r\n}\r\n\r\n.detail-item {\r\n  text-align: center;\r\n}\r\n\r\n.detail-item h4 {\r\n  margin-bottom: 8px;\r\n  color: #909399;\r\n}\r\n\r\n.error-container {\r\n  margin: 20px 0;\r\n}\r\n\r\n.retry-btn {\r\n  margin-top: 20px;\r\n  width: 100%;\r\n}\r\n\r\n.action-buttons {\r\n  display: flex;\r\n  justify-content: center;\r\n  gap: 20px;\r\n  margin-top: 20px;\r\n}\r\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAmB;;EAGnBA,KAAK,EAAC;AAAa;;EAMrBA,KAAK,EAAC;AAAe;;EAErBA,KAAK,EAAC;AAAa;;EAZ9BC,GAAA;EAc2BD,KAAK,EAAC;;;EAdjCC,GAAA;EAyBaD,KAAK,EAAC;;;EACJA,KAAK,EAAC;AAAa;;EAInBA,KAAK,EAAC;AAAa;;EA9BlCC,GAAA;EAoCaD,KAAK,EAAC;;;EApCnBC,GAAA;EAgDWD,KAAK,EAAC;;;;;;;;uBA/CfE,mBAAA,CAoDM,OApDNC,UAoDM,GAnDJC,YAAA,CAkDUC,kBAAA;IAlDDL,KAAK,EAAC;EAAc;IAChBM,MAAM,EAAAC,QAAA,CACf,MAGM,CAHNC,mBAAA,CAGM,OAHNC,UAGM,G,0BAFJD,mBAAA,CAAc,YAAV,OAAK,sBACoBE,MAAA,CAAAC,MAAM,I,cAAnCC,YAAA,CAAkDC,iBAAA;MAN5DZ,GAAA;MAMkBa,IAAI,EAAC;;MANvBC,OAAA,EAAAR,QAAA,CAM+C,MAAIS,MAAA,QAAAA,MAAA,OANnDC,gBAAA,CAM+C,MAAI,E;MANnDC,CAAA;UAAAC,mBAAA,e;IAAAJ,OAAA,EAAAR,QAAA,CAUM,MAoCM,CApCNC,mBAAA,CAoCM,OApCNY,UAoCM,GAnCJhB,YAAA,CAA6EiB,sBAAA;MAA/DC,UAAU,EAAEZ,MAAA,CAAAY,UAAU;MAAGC,MAAM,EAAEb,MAAA,CAAAc;uDAC/ChB,mBAAA,CAA2C,KAA3CiB,UAA2C,EAAAC,gBAAA,CAAjBhB,MAAA,CAAAiB,UAAU,kBAEzBjB,MAAA,CAAAC,MAAM,I,cAAjBT,mBAAA,CASM,OATN0B,UASM,GARJxB,YAAA,CAOWyB,mBAAA;MANTC,KAAK,EAAC,QAAQ;MACdhB,IAAI,EAAC,SAAS;MACdiB,WAAW,EAAC,wCAAwC;MACpD,WAAS,EAAT,EAAS;MACRC,QAAQ,EAAE;YApBvBb,mBAAA,gBAyB6CT,MAAA,CAAAuB,gBAAgB,iB,cAArD/B,mBAAA,CASM,OATNgC,UASM,GARJ1B,mBAAA,CAGM,OAHN2B,UAGM,G,0BAFJ3B,mBAAA,CAAa,YAAT,MAAI,sBACRA,mBAAA,CAAiD,WAAAkB,gBAAA,CAA3ChB,MAAA,CAAA0B,cAAc,IAAG,KAAG,GAAAV,gBAAA,CAAGhB,MAAA,CAAA2B,aAAa,iB,GAE5C7B,mBAAA,CAGM,OAHN8B,UAGM,G,0BAFJ9B,mBAAA,CAAe,YAAX,QAAM,sBACVA,mBAAA,CAA0B,WAAAkB,gBAAA,CAApBhB,MAAA,CAAA6B,aAAa,iB,OAhC/BpB,mBAAA,gBAoC2CT,MAAA,CAAAuB,gBAAgB,iB,cAAnD/B,mBAAA,CASM,OATNsC,UASM,GARJpC,YAAA,CAMWyB,mBAAA;MALTC,KAAK,EAAC,MAAM;MACZhB,IAAI,EAAC,OAAO;MACZiB,WAAW,EAAC,uBAAuB;MACnC,WAAS,EAAT;QAGF3B,YAAA,CAA2EqC,oB