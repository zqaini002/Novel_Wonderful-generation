{"ast":null,"code":"import { createElementVNode as _createElementVNode, openBlock as _openBlock, createElementBlock as _createElementBlock, createCommentVNode as _createCommentVNode, normalizeStyle as _normalizeStyle } from \"vue\";\nconst _hoisted_1 = {\n  class: \"chart-container\"\n};\nconst _hoisted_2 = {\n  key: 0,\n  class: \"loading-overlay\"\n};\nconst _hoisted_3 = {\n  key: 1,\n  class: \"no-data-message\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [$props.loading ? (_openBlock(), _createElementBlock(\"div\", _hoisted_2, _cache[0] || (_cache[0] = [_createElementVNode(\"div\", {\n    class: \"loading-spinner\"\n  }, null, -1 /* HOISTED */), _createElementVNode(\"div\", {\n    class: \"loading-text\"\n  }, \"加载中...\", -1 /* HOISTED */)]))) : !$setup.hasData ? (_openBlock(), _createElementBlock(\"div\", _hoisted_3, _cache[1] || (_cache[1] = [_createElementVNode(\"i\", {\n    class: \"el-icon-warning-outline\"\n  }, null, -1 /* HOISTED */), _createElementVNode(\"p\", null, \"暂无关键词数据\", -1 /* HOISTED */)]))) : _createCommentVNode(\"v-if\", true), _createElementVNode(\"div\", {\n    ref: \"chartRef\",\n    class: \"keyword-cloud-chart\",\n    style: _normalizeStyle({\n      opacity: $setup.hasData ? 1 : 0\n    })\n  }, null, 4 /* STYLE */)]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","$props","loading","_hoisted_2","_cache","_createElementVNode","$setup","hasData","_hoisted_3","_createCommentVNode","ref","style","_normalizeStyle","opacity"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\components\\visualization\\KeywordCloud.vue"],"sourcesContent":["<template>\n  <div class=\"chart-container\">\n    <div v-if=\"loading\" class=\"loading-overlay\">\n      <div class=\"loading-spinner\"></div>\n      <div class=\"loading-text\">加载中...</div>\n    </div>\n    <div v-else-if=\"!hasData\" class=\"no-data-message\">\n      <i class=\"el-icon-warning-outline\"></i>\n      <p>暂无关键词数据</p>\n    </div>\n    <div ref=\"chartRef\" class=\"keyword-cloud-chart\" :style=\"{ opacity: hasData ? 1 : 0 }\"></div>\n  </div>\n</template>\n\n<script>\nimport { ref, onMounted, onBeforeUnmount, watch, computed, nextTick } from 'vue'\nimport * as echarts from 'echarts'\n// 显式导入并确保注册wordcloud组件\nimport 'echarts-wordcloud'\n\n// 如果插件未正常注册，尝试手动注册 wordCloud 系列\nif (!echarts.getMap('series').wordCloud) {\n  try {\n    // 从 window 对象中获取已加载的 echarts\n    const ecInstance = window.echarts || echarts;\n    \n    // 检查是否已加载词云图类型\n    if (ecInstance.SeriesModel && !ecInstance.SeriesModel.extend) {\n      console.warn('无法注册 wordCloud 系列，缺少 SeriesModel.extend 方法');\n    } else if (window.echarts && window.echarts.registerMap) {\n      console.log('尝试手动注册 wordCloud 系列类型');\n      \n      // 如果有第三方注册的 echarts-wordcloud\n      if (typeof window.echarts.graphic.registerShape === 'function') {\n        console.log('使用全局 echarts 注册 wordCloud');\n      }\n    }\n  } catch (e) {\n    console.error('手动注册 wordCloud 系列失败:', e);\n  }\n}\n\n// 确认wordCloud系列类型已注册的调试日志\nconsole.log('echarts registered series types:', echarts.getMap('series'));\n\nexport default {\n  name: 'KeywordCloud',\n  props: {\n    keywords: {\n      type: Array,\n      required: true,\n      default: () => []\n    },\n    title: {\n      type: String,\n      default: '关键词云'\n    },\n    height: {\n      type: String,\n      default: '400px'\n    },\n    width: {\n      type: String,\n      default: '100%'\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  setup(props) {\n    const chartRef = ref(null)\n    let chart = null\n    \n    // 计算是否有数据\n    const hasData = computed(() => {\n      return props.keywords && props.keywords.length > 0;\n    });\n\n    // 初始化图表\n    const initChart = () => {\n      // 确保DOM已挂载\n      if (!chartRef.value) return\n\n      // 销毁旧图表\n      if (chart) {\n        chart.dispose()\n      }\n\n      // 使用 nextTick 确保DOM已完全渲染并且有正确的尺寸\n      nextTick(() => {\n        // 检查DOM是否可见且有尺寸\n        if (chartRef.value.clientWidth === 0 || chartRef.value.clientHeight === 0) {\n          // 如果DOM尺寸为0，延迟初始化\n          setTimeout(() => {\n            initChart();\n          }, 300);\n          return;\n        }\n\n        try {\n          // 先检查是否有 wordCloud 系列\n          if (!echarts.getMap('series').wordCloud) {\n            console.error('wordCloud 系列未注册，无法渲染关键词云图');\n            // 使用饼图来展示关键词，作为后备\n            renderPieChart();\n            return;\n          }\n\n          // 初始化图表实例\n          chart = echarts.init(chartRef.value)\n          \n          // 如果没有数据，渲染空图表\n          if (!hasData.value) {\n            chart.setOption({\n              title: {\n                text: props.title || '关键词云',\n                left: 'center'\n              },\n              graphic: {\n                type: 'text',\n                left: 'center',\n                top: 'middle',\n                style: {\n                  text: '暂无数据',\n                  font: '14px sans-serif',\n                  fill: '#999'\n                }\n              }\n            })\n            return\n          }\n          \n          // 设置图表选项\n          const option = {\n            title: {\n              text: props.title,\n              left: 'center',\n              textStyle: {\n                fontWeight: 'normal',\n                fontSize: 16\n              }\n            },\n            tooltip: {\n              show: true,\n              formatter: function(params) {\n                return params.data.name + ': ' + params.data.value\n              },\n              backgroundColor: 'rgba(50,50,50,0.7)',\n              borderColor: '#ccc',\n              borderWidth: 0,\n              padding: [5, 10],\n              textStyle: {\n                color: '#fff'\n              }\n            },\n            series: [{\n              name: '关键词云',\n              type: 'wordCloud',\n              shape: 'circle',\n              left: 'center',\n              top: 'center',\n              width: '90%',\n              height: '90%',\n              right: null,\n              bottom: null,\n              sizeRange: [12, 60],\n              rotationRange: [-60, 60],\n              rotationStep: 15,\n              gridSize: 8,\n              drawOutOfBound: false,\n              layoutAnimation: true,\n              textStyle: {\n                fontFamily: 'sans-serif',\n                fontWeight: 'bold',\n                color: function() {\n                  // 更多柔和的调色板\n                  return 'rgb(' + \n                    [\n                      Math.round(Math.random() * 100 + 80),\n                      Math.round(Math.random() * 140 + 60),\n                      Math.round(Math.random() * 180 + 40)\n                    ].join(',') + ')'\n                }\n              },\n              emphasis: {\n                focus: 'self',\n                textStyle: {\n                  shadowBlur: 10,\n                  shadowColor: '#333'\n                }\n              },\n              data: formatKeywords(props.keywords)\n            }]\n          }\n\n          // 在渲染前检查数据\n          console.log('关键词云数据:', formatKeywords(props.keywords));\n          console.log('ECharts图表选项配置:', option);\n\n          // 渲染图表\n          try {\n            chart.setOption(option);\n            console.log('关键词云图表渲染成功');\n          } catch (error) {\n            console.error('关键词云图表渲染失败:', error);\n            // 如果词云渲染失败，尝试使用饼图作为备选\n            renderPieChart();\n          }\n        } catch (error) {\n          console.error('初始化图表失败:', error);\n          renderPieChart();\n        }\n      });\n    }\n\n    // 如果词云不可用，渲染饼图作为备选\n    const renderPieChart = () => {\n      if (!chartRef.value) return;\n      \n      const keywords = formatKeywords(props.keywords);\n      if (!keywords.length) return;\n      \n      // 限制显示前10个关键词\n      const topKeywords = keywords.slice(0, 10);\n      \n      chart = echarts.init(chartRef.value);\n      chart.setOption({\n        title: {\n          text: props.title,\n          left: 'center',\n          textStyle: {\n            fontWeight: 'normal',\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'item',\n          formatter: '{a} <br/>{b}: {c} ({d}%)'\n        },\n        legend: {\n          orient: 'vertical',\n          left: 10,\n          top: 'center',\n          data: topKeywords.map(item => item.name)\n        },\n        series: [\n          {\n            name: '关键词分布',\n            type: 'pie',\n            radius: ['30%', '70%'],\n            avoidLabelOverlap: true,\n            itemStyle: {\n              borderRadius: 10,\n              borderColor: '#fff',\n              borderWidth: 2\n            },\n            label: {\n              show: true,\n              formatter: '{b}: {c}'\n            },\n            emphasis: {\n              label: {\n                show: true,\n                fontSize: '14',\n                fontWeight: 'bold'\n              }\n            },\n            data: topKeywords\n          }\n        ]\n      });\n      console.log('已渲染饼图作为关键词云的替代');\n    };\n\n    // 格式化关键词数据\n    const formatKeywords = (keywords) => {\n      if (!keywords || !keywords.length) return []\n      \n      console.log('原始关键词数据:', keywords);\n      \n      // 确保keywords是一个数组\n      if (!Array.isArray(keywords)) {\n        console.warn('关键词数据不是数组格式:', keywords);\n        // 尝试从对象中提取关键词数据\n        if (typeof keywords === 'object' && keywords !== null) {\n          // 查找可能的数组属性\n          for (const key in keywords) {\n            if (Array.isArray(keywords[key])) {\n              console.log('从对象中找到关键词数组:', key);\n              keywords = keywords[key];\n              break;\n            }\n          }\n        }\n        \n        // 如果仍然不是数组，返回空数组\n        if (!Array.isArray(keywords)) {\n          console.error('无法处理的关键词数据格式，返回空数组');\n          return [];\n        }\n      }\n      \n      const result = keywords.map(item => {\n        if (typeof item === 'string') {\n          return {\n            name: item,\n            value: Math.floor(Math.random() * 90) + 10 // 如果只有词，随机生成权重\n          }\n        } else if (typeof item === 'object' && item !== null) {\n          return {\n            name: item.word || item.name || item.keyword || '',\n            value: item.weight || item.value || item.count || Math.floor(Math.random() * 90) + 10\n          }\n        }\n        return { name: '', value: 0 }\n      }).filter(item => item.name);\n      \n      console.log('格式化后的关键词数据:', result);\n      return result;\n    }\n\n    // 处理窗口大小改变\n    const handleResize = () => {\n      chart && chart.resize()\n    }\n\n    // 监听关键词变化\n    watch(() => props.keywords, (newVal) => {\n      if (chart) {\n        try {\n          // 如果是词云图表\n          if (chart.getOption().series[0] && chart.getOption().series[0].type === 'wordCloud') {\n            chart.setOption({\n              series: [{\n                data: formatKeywords(newVal)\n              }]\n            });\n          } else {\n            // 如果是饼图\n            const topKeywords = formatKeywords(newVal).slice(0, 10);\n            chart.setOption({\n              legend: {\n                data: topKeywords.map(item => item.name)\n              },\n              series: [{\n                data: topKeywords\n              }]\n            });\n          }\n        } catch (e) {\n          console.error('更新图表数据失败:', e);\n          initChart(); // 重新初始化图表\n        }\n      } else {\n        // 如果图表还未初始化，则初始化\n        initChart()\n      }\n    }, { deep: true })\n    \n    // 监听加载状态\n    watch(() => props.loading, (newVal) => {\n      if (!newVal && !chart && chartRef.value) {\n        // 加载完成且图表未初始化\n        initChart()\n      }\n    })\n\n    // 组件挂载时初始化图表\n    onMounted(() => {\n      // 如果窗口已经加载完成\n      if (document.readyState === 'complete') {\n        nextTick().then(() => initChart())\n      } else {\n        // 否则等待窗口完全加载\n        window.addEventListener('load', () => {\n          nextTick().then(() => initChart())\n        })\n      }\n      \n      // 确保在组件销毁时移除事件监听\n      window.addEventListener('resize', handleResize)\n    })\n\n    // 组件卸载前销毁图表\n    onBeforeUnmount(() => {\n      if (chart) {\n        chart.dispose()\n        chart = null\n      }\n      window.removeEventListener('resize', handleResize)\n    })\n\n    return {\n      chartRef,\n      hasData,\n      chart\n    }\n  }\n}\n</script>\n\n<style scoped>\n.chart-container {\n  width: v-bind(width);\n  height: v-bind(height);\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.keyword-cloud-chart {\n  width: 100%;\n  height: 100%;\n  transition: opacity 0.3s ease;\n}\n\n.loading-overlay {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  background-color: rgba(255, 255, 255, 0.8);\n  z-index: 10;\n}\n\n.loading-spinner {\n  width: 40px;\n  height: 40px;\n  border: 3px solid #f3f3f3;\n  border-top: 3px solid #3498db;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n.loading-text {\n  margin-top: 10px;\n  color: #666;\n}\n\n.no-data-message {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  color: #909399;\n  font-size: 14px;\n}\n\n.no-data-message i {\n  font-size: 32px;\n  margin-bottom: 10px;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAiB;;EAD9BC,GAAA;EAEwBD,KAAK,EAAC;;;EAF9BC,GAAA;EAM8BD,KAAK,EAAC;;;uBALlCE,mBAAA,CAUM,OAVNC,UAUM,GATOC,MAAA,CAAAC,OAAO,I,cAAlBH,mBAAA,CAGM,OAHNI,UAGM,EAAAC,MAAA,QAAAA,MAAA,OAFJC,mBAAA,CAAmC;IAA9BR,KAAK,EAAC;EAAiB,4BAC5BQ,mBAAA,CAAsC;IAAjCR,KAAK,EAAC;EAAc,GAAC,QAAM,oB,OAEjBS,MAAA,CAAAC,OAAO,I,cAAxBR,mBAAA,CAGM,OAHNS,UAGM,EAAAJ,MAAA,QAAAA,MAAA,OAFJC,mBAAA,CAAuC;IAApCR,KAAK,EAAC;EAAyB,4BAClCQ,mBAAA,CAAc,WAAX,SAAO,oB,MARhBI,mBAAA,gBAUIJ,mBAAA,CAA4F;IAAvFK,GAAG,EAAC,UAAU;IAACb,KAAK,EAAC,qBAAqB;IAAEc,KAAK,EAV1DC,eAAA;MAAAC,OAAA,EAUuEP,MAAA,CAAAC,OAAO;IAAA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}