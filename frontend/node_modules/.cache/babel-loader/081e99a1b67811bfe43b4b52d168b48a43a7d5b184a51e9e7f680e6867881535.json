{"ast":null,"code":"import { defineComponent, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRoute } from 'vue-router';\nimport { HomeFilled, Upload, InfoFilled, User, ArrowDown, Collection, SwitchButton, Reading } from '@element-plus/icons-vue';\nexport default defineComponent({\n  name: 'HeaderComponent',\n  components: {\n    HomeFilled,\n    Upload,\n    InfoFilled,\n    User,\n    ArrowDown,\n    Collection,\n    SwitchButton,\n    Reading\n  },\n  setup() {\n    const store = useStore();\n    const route = useRoute();\n\n    // 计算当前激活的菜单项\n    const activeIndex = computed(() => route.path);\n\n    // 从store获取登录状态\n    const isLoggedIn = computed(() => store.getters.isLoggedIn || false);\n\n    // 从store获取用户名\n    const username = computed(() => store.state.user ? store.state.user.name : '');\n\n    // 登录功能（示例）\n    const login = () => {\n      console.log('登录功能待实现');\n    };\n\n    // 注册功能（示例）\n    const register = () => {\n      console.log('注册功能待实现');\n    };\n\n    // 登出功能（示例）\n    const logout = () => {\n      store.commit('SET_USER', null);\n    };\n    return {\n      activeIndex,\n      isLoggedIn,\n      username,\n      login,\n      register,\n      logout\n    };\n  }\n});","map":{"version":3,"names":["defineComponent","computed","useStore","useRoute","HomeFilled","Upload","InfoFilled","User","ArrowDown","Collection","SwitchButton","Reading","name","components","setup","store","route","activeIndex","path","isLoggedIn","getters","username","state","user","login","console","log","register","logout","commit"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\components\\layout\\HeaderComponent.vue"],"sourcesContent":["<template>\r\n  <div class=\"header-container\">\r\n    <el-menu\r\n      :default-active=\"activeIndex\"\r\n      class=\"menu\"\r\n      mode=\"horizontal\"\r\n      router\r\n      :ellipsis=\"false\">\r\n      <div class=\"logo\">\r\n        <router-link to=\"/\">\r\n          <div class=\"logo-content\">\r\n            <el-icon class=\"logo-icon\"><Reading /></el-icon>\r\n            <h1>小说精读助手</h1>\r\n          </div>\r\n        </router-link>\r\n      </div>\r\n      <div class=\"menu-items\">\r\n        <el-menu-item index=\"/\">\r\n          <el-icon><HomeFilled /></el-icon>\r\n          <span>首页</span>\r\n        </el-menu-item>\r\n        <el-menu-item index=\"/upload\">\r\n          <el-icon><Upload /></el-icon>\r\n          <span>上传小说</span>\r\n        </el-menu-item>\r\n        <el-menu-item index=\"/about\">\r\n          <el-icon><InfoFilled /></el-icon>\r\n          <span>关于</span>\r\n        </el-menu-item>\r\n      </div>\r\n      <div class=\"user-area\">\r\n        <el-dropdown v-if=\"isLoggedIn\" trigger=\"click\">\r\n          <div class=\"avatar-wrapper\">\r\n            <el-avatar :size=\"32\" src=\"https://cube.elemecdn.com/0/88/03b0d39583f48206768a7534e55bcpng.png\"></el-avatar>\r\n            <span class=\"username\">{{ username }}</span>\r\n            <el-icon><ArrowDown /></el-icon>\r\n          </div>\r\n          <template #dropdown>\r\n            <el-dropdown-menu>\r\n              <el-dropdown-item>\r\n                <el-icon><User /></el-icon>\r\n                <span>个人中心</span>\r\n              </el-dropdown-item>\r\n              <el-dropdown-item>\r\n                <el-icon><Collection /></el-icon>\r\n                <span>我的小说</span>\r\n              </el-dropdown-item>\r\n              <el-dropdown-item divided @click=\"logout\">\r\n                <el-icon><SwitchButton /></el-icon>\r\n                <span>退出登录</span>\r\n              </el-dropdown-item>\r\n            </el-dropdown-menu>\r\n          </template>\r\n        </el-dropdown>\r\n        <div v-else class=\"auth-buttons\">\r\n          <el-button type=\"primary\" size=\"small\" @click=\"login\">登录</el-button>\r\n          <el-button size=\"small\" @click=\"register\">注册</el-button>\r\n        </div>\r\n      </div>\r\n    </el-menu>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { defineComponent, computed } from 'vue'\r\nimport { useStore } from 'vuex'\r\nimport { useRoute } from 'vue-router'\r\nimport { \r\n  HomeFilled, \r\n  Upload, \r\n  InfoFilled, \r\n  User, \r\n  ArrowDown, \r\n  Collection, \r\n  SwitchButton,\r\n  Reading\r\n} from '@element-plus/icons-vue'\r\n\r\nexport default defineComponent({\r\n  name: 'HeaderComponent',\r\n  components: {\r\n    HomeFilled, \r\n    Upload, \r\n    InfoFilled, \r\n    User, \r\n    ArrowDown, \r\n    Collection, \r\n    SwitchButton,\r\n    Reading\r\n  },\r\n  setup() {\r\n    const store = useStore()\r\n    const route = useRoute()\r\n    \r\n    // 计算当前激活的菜单项\r\n    const activeIndex = computed(() => route.path)\r\n    \r\n    // 从store获取登录状态\r\n    const isLoggedIn = computed(() => store.getters.isLoggedIn || false)\r\n    \r\n    // 从store获取用户名\r\n    const username = computed(() => store.state.user ? store.state.user.name : '')\r\n    \r\n    // 登录功能（示例）\r\n    const login = () => {\r\n      console.log('登录功能待实现')\r\n    }\r\n    \r\n    // 注册功能（示例）\r\n    const register = () => {\r\n      console.log('注册功能待实现')\r\n    }\r\n    \r\n    // 登出功能（示例）\r\n    const logout = () => {\r\n      store.commit('SET_USER', null)\r\n    }\r\n    \r\n    return {\r\n      activeIndex,\r\n      isLoggedIn,\r\n      username,\r\n      login,\r\n      register,\r\n      logout\r\n    }\r\n  }\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.header-container {\r\n  width: 100%;\r\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);\r\n  position: relative;\r\n  z-index: 10;\r\n}\r\n\r\n.menu {\r\n  display: flex;\r\n  height: 64px;\r\n  padding: 0 20px;\r\n  background: linear-gradient(135deg, #4d7bef 0%, #5e60ce 100%);\r\n  border: none;\r\n}\r\n\r\n:deep(.el-menu--horizontal .el-menu-item) {\r\n  height: 64px;\r\n  line-height: 64px;\r\n  border: none !important;\r\n  margin: 0 5px;\r\n  font-weight: 500;\r\n  color: rgba(255, 255, 255, 0.9) !important;\r\n  padding: 0 20px;\r\n  position: relative;\r\n  transition: all 0.3s;\r\n}\r\n\r\n:deep(.el-menu--horizontal .el-menu-item:hover),\r\n:deep(.el-menu--horizontal .el-menu-item.is-active) {\r\n  background-color: rgba(255, 255, 255, 0.15) !important;\r\n  border-radius: 4px;\r\n  color: #ffffff !important;\r\n}\r\n\r\n:deep(.el-menu--horizontal .el-menu-item.is-active::after) {\r\n  content: '';\r\n  position: absolute;\r\n  bottom: 10px;\r\n  left: 20px;\r\n  right: 20px;\r\n  height: 3px;\r\n  background-color: #fff;\r\n  border-radius: 1.5px;\r\n}\r\n\r\n.logo {\r\n  margin-right: 20px;\r\n  display: flex;\r\n  align-items: center;\r\n  padding-right: 20px;\r\n}\r\n\r\n.logo a {\r\n  text-decoration: none;\r\n}\r\n\r\n.logo-content {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.logo-icon {\r\n  font-size: 28px;\r\n  color: #fff;\r\n  margin-right: 10px;\r\n}\r\n\r\n.logo h1 {\r\n  color: #fff;\r\n  margin: 0;\r\n  font-size: 22px;\r\n  font-weight: 600;\r\n  letter-spacing: 0.5px;\r\n  text-shadow: 1px 1px 2px rgba(0,0,0,0.1);\r\n}\r\n\r\n.menu-items {\r\n  flex: 1;\r\n  display: flex;\r\n}\r\n\r\n.menu-items .el-icon {\r\n  margin-right: 4px;\r\n  font-size: 18px;\r\n}\r\n\r\n.user-area {\r\n  display: flex;\r\n  align-items: center;\r\n  color: #fff;\r\n}\r\n\r\n.avatar-wrapper {\r\n  display: flex;\r\n  align-items: center;\r\n  cursor: pointer;\r\n  padding: 2px 10px;\r\n  border-radius: 20px;\r\n  transition: background-color 0.3s;\r\n}\r\n\r\n.avatar-wrapper:hover {\r\n  background-color: rgba(255, 255, 255, 0.15);\r\n}\r\n\r\n.username {\r\n  margin: 0 8px;\r\n  font-weight: 500;\r\n  color: #fff;\r\n}\r\n\r\n.auth-buttons {\r\n  display: flex;\r\n  gap: 10px;\r\n}\r\n\r\n:deep(.auth-buttons .el-button--primary) {\r\n  background-color: rgba(255, 255, 255, 0.2);\r\n  border-color: rgba(255, 255, 255, 0.3);\r\n}\r\n\r\n:deep(.auth-buttons .el-button--primary:hover) {\r\n  background-color: rgba(255, 255, 255, 0.3);\r\n  border-color: rgba(255, 255, 255, 0.4);\r\n}\r\n\r\n:deep(.auth-buttons .el-button--default) {\r\n  border-color: rgba(255, 255, 255, 0.6);\r\n  color: #fff;\r\n}\r\n\r\n:deep(.auth-buttons .el-button--default:hover) {\r\n  background-color: rgba(255, 255, 255, 0.15);\r\n  border-color: rgba(255, 255, 255, 0.8);\r\n}\r\n\r\n:deep(.el-dropdown-menu__item) {\r\n  display: flex;\r\n  align-items: center;\r\n  line-height: 1.5;\r\n}\r\n\r\n:deep(.el-dropdown-menu__item .el-icon) {\r\n  margin-right: 8px;\r\n  font-size: 16px;\r\n}\r\n</style> "],"mappings":"AAgEA,SAASA,eAAe,EAAEC,QAAO,QAAS,KAAI;AAC9C,SAASC,QAAO,QAAS,MAAK;AAC9B,SAASC,QAAO,QAAS,YAAW;AACpC,SACEC,UAAU,EACVC,MAAM,EACNC,UAAU,EACVC,IAAI,EACJC,SAAS,EACTC,UAAU,EACVC,YAAY,EACZC,OAAM,QACD,yBAAwB;AAE/B,eAAeX,eAAe,CAAC;EAC7BY,IAAI,EAAE,iBAAiB;EACvBC,UAAU,EAAE;IACVT,UAAU;IACVC,MAAM;IACNC,UAAU;IACVC,IAAI;IACJC,SAAS;IACTC,UAAU;IACVC,YAAY;IACZC;EACF,CAAC;EACDG,KAAKA,CAAA,EAAG;IACN,MAAMC,KAAI,GAAIb,QAAQ,CAAC;IACvB,MAAMc,KAAI,GAAIb,QAAQ,CAAC;;IAEvB;IACA,MAAMc,WAAU,GAAIhB,QAAQ,CAAC,MAAMe,KAAK,CAACE,IAAI;;IAE7C;IACA,MAAMC,UAAS,GAAIlB,QAAQ,CAAC,MAAMc,KAAK,CAACK,OAAO,CAACD,UAAS,IAAK,KAAK;;IAEnE;IACA,MAAME,QAAO,GAAIpB,QAAQ,CAAC,MAAMc,KAAK,CAACO,KAAK,CAACC,IAAG,GAAIR,KAAK,CAACO,KAAK,CAACC,IAAI,CAACX,IAAG,GAAI,EAAE;;IAE7E;IACA,MAAMY,KAAI,GAAIA,CAAA,KAAM;MAClBC,OAAO,CAACC,GAAG,CAAC,SAAS;IACvB;;IAEA;IACA,MAAMC,QAAO,GAAIA,CAAA,KAAM;MACrBF,OAAO,CAACC,GAAG,CAAC,SAAS;IACvB;;IAEA;IACA,MAAME,MAAK,GAAIA,CAAA,KAAM;MACnBb,KAAK,CAACc,MAAM,CAAC,UAAU,EAAE,IAAI;IAC/B;IAEA,OAAO;MACLZ,WAAW;MACXE,UAAU;MACVE,QAAQ;MACRG,KAAK;MACLG,QAAQ;MACRC;IACF;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}