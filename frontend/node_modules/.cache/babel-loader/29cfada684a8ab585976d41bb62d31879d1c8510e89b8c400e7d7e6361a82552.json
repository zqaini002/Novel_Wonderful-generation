{"ast":null,"code":"import { createElementVNode as _createElementVNode, openBlock as _openBlock, createElementBlock as _createElementBlock, createCommentVNode as _createCommentVNode, normalizeStyle as _normalizeStyle } from \"vue\";\nconst _hoisted_1 = {\n  class: \"chart-container\"\n};\nconst _hoisted_2 = {\n  key: 0,\n  class: \"loading-overlay\"\n};\nconst _hoisted_3 = {\n  key: 1,\n  class: \"no-data-message\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [$props.loading ? (_openBlock(), _createElementBlock(\"div\", _hoisted_2, _cache[0] || (_cache[0] = [_createElementVNode(\"div\", {\n    class: \"loading-spinner\"\n  }, null, -1 /* HOISTED */), _createElementVNode(\"div\", {\n    class: \"loading-text\"\n  }, \"加载中...\", -1 /* HOISTED */)]))) : !$setup.hasData ? (_openBlock(), _createElementBlock(\"div\", _hoisted_3, _cache[1] || (_cache[1] = [_createElementVNode(\"i\", {\n    class: \"el-icon-warning-outline\"\n  }, null, -1 /* HOISTED */), _createElementVNode(\"p\", null, \"暂无关键词数据\", -1 /* HOISTED */)]))) : _createCommentVNode(\"v-if\", true), _createElementVNode(\"div\", {\n    ref: \"chartRef\",\n    class: \"keyword-cloud-chart\",\n    style: _normalizeStyle({\n      opacity: $setup.hasData ? 1 : 0\n    })\n  }, null, 4 /* STYLE */)]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","$props","loading","_hoisted_2","_cache","_createElementVNode","$setup","hasData","_hoisted_3","_createCommentVNode","ref","style","_normalizeStyle","opacity"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\components\\visualization\\KeywordCloud.vue"],"sourcesContent":["<template>\n  <div class=\"chart-container\">\n    <div v-if=\"loading\" class=\"loading-overlay\">\n      <div class=\"loading-spinner\"></div>\n      <div class=\"loading-text\">加载中...</div>\n    </div>\n    <div v-else-if=\"!hasData\" class=\"no-data-message\">\n      <i class=\"el-icon-warning-outline\"></i>\n      <p>暂无关键词数据</p>\n    </div>\n    <div ref=\"chartRef\" class=\"keyword-cloud-chart\" :style=\"{ opacity: hasData ? 1 : 0 }\"></div>\n  </div>\n</template>\n\n<script>\nimport { ref, onMounted, onBeforeUnmount, watch, computed, nextTick } from 'vue'\nimport * as echarts from 'echarts'\n// 显式导入并确保注册wordcloud组件\nimport 'echarts-wordcloud'\n\n// 手动检查和输出注册状态\nconsole.log('KeywordCloud组件 - 可用的ECharts系列类型:', Object.keys(echarts.getMap('series') || {}));\n\n// 确保wordCloud系列类型已注册，否则手动注册\nif (!echarts.getMap('series').wordCloud) {\n  console.warn('WordCloud系列未注册，尝试手动注册');\n  \n  // 加载echarts-wordcloud模块并确保注册\n  try {\n    require('echarts-wordcloud');\n    console.log('手动加载echarts-wordcloud成功');\n  } catch (error) {\n    console.error('手动加载echarts-wordcloud失败:', error);\n  }\n  \n  // 再次检查是否注册成功\n  console.log('注册后的ECharts系列类型:', Object.keys(echarts.getMap('series') || {}));\n}\n\nexport default {\n  name: 'KeywordCloud',\n  props: {\n    keywords: {\n      type: Array,\n      required: true,\n      default: () => []\n    },\n    title: {\n      type: String,\n      default: '关键词云'\n    },\n    height: {\n      type: String,\n      default: '400px'\n    },\n    width: {\n      type: String,\n      default: '100%'\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  setup(props) {\n    const chartRef = ref(null)\n    let chart = null\n    \n    // 计算是否有数据\n    const hasData = computed(() => {\n      return props.keywords && props.keywords.length > 0;\n    });\n\n    // 初始化图表\n    const initChart = () => {\n      // 确保DOM已挂载\n      if (!chartRef.value) {\n        console.warn('chartRef未挂载，无法初始化图表');\n        return;\n      }\n\n      // 销毁旧图表\n      if (chart) {\n        chart.dispose();\n        chart = null;\n      }\n\n      console.log('开始初始化关键词云图表');\n\n      // 使用 nextTick 确保DOM已完全渲染并且有正确的尺寸\n      nextTick(() => {\n        // 检查DOM是否可见且有尺寸\n        if (chartRef.value.clientWidth === 0 || chartRef.value.clientHeight === 0) {\n          console.warn('图表容器尺寸为0，延迟初始化');\n          // 如果DOM尺寸为0，延迟初始化\n          setTimeout(() => {\n            initChart();\n          }, 500); // 增加延迟时间\n          return;\n        }\n\n        console.log('图表容器尺寸:', {\n          width: chartRef.value.clientWidth,\n          height: chartRef.value.clientHeight\n        });\n\n        try {\n          // 初始化图表实例\n          chart = echarts.init(chartRef.value);\n          console.log('ECharts实例创建成功');\n        } catch (error) {\n          console.error('ECharts实例创建失败:', error);\n          return;\n        }\n        \n        // 检查是否有数据\n        const formattedData = formatKeywords(props.keywords);\n        console.log(`格式化后的数据长度: ${formattedData.length}`);\n        \n        // 如果没有数据，渲染空图表\n        if (!hasData.value || formattedData.length === 0) {\n          console.warn('无关键词数据，显示空图表');\n          chart.setOption({\n            title: {\n              text: props.title || '关键词云',\n              left: 'center'\n            },\n            graphic: {\n              type: 'text',\n              left: 'center',\n              top: 'middle',\n              style: {\n                text: '暂无数据',\n                font: '14px sans-serif',\n                fill: '#999'\n              }\n            }\n          });\n          return;\n        }\n        \n        // 设置图表选项\n        const option = {\n          title: {\n            text: props.title,\n            left: 'center',\n            textStyle: {\n              fontWeight: 'normal',\n              fontSize: 16\n            }\n          },\n          tooltip: {\n            show: true,\n            formatter: function(params) {\n              return params.data.name + ': ' + params.data.value;\n            },\n            backgroundColor: 'rgba(50,50,50,0.7)',\n            borderColor: '#ccc',\n            borderWidth: 0,\n            padding: [5, 10],\n            textStyle: {\n              color: '#fff'\n            }\n          },\n          series: [{\n            name: '关键词云',\n            type: 'wordCloud',\n            shape: 'circle',\n            left: 'center',\n            top: 'center',\n            width: '90%',\n            height: '90%',\n            right: null,\n            bottom: null,\n            sizeRange: [12, 60],\n            rotationRange: [-60, 60],\n            rotationStep: 15,\n            gridSize: 8,\n            drawOutOfBound: false,\n            layoutAnimation: true,\n            textStyle: {\n              fontFamily: 'sans-serif',\n              fontWeight: 'bold',\n              color: function() {\n                // 更多柔和的调色板\n                return 'rgb(' + \n                  [\n                    Math.round(Math.random() * 100 + 80),\n                    Math.round(Math.random() * 140 + 60),\n                    Math.round(Math.random() * 180 + 40)\n                  ].join(',') + ')';\n              }\n            },\n            emphasis: {\n              focus: 'self',\n              textStyle: {\n                shadowBlur: 10,\n                shadowColor: '#333'\n              }\n            },\n            data: formattedData\n          }]\n        };\n\n        // 在渲染前检查数据\n        console.log('关键词云数据:', formattedData);\n        \n        // 检查series类型是否支持\n        if (!echarts.getMap('series').wordCloud) {\n          console.error('wordCloud系列类型未注册，图表将无法正常显示');\n          chart.setOption({\n            title: {\n              text: '图表加载失败',\n              left: 'center'\n            },\n            graphic: {\n              type: 'text',\n              left: 'center',\n              top: 'middle',\n              style: {\n                text: 'wordCloud组件未正确加载',\n                font: '14px sans-serif',\n                fill: '#f00'\n              }\n            }\n          });\n          return;\n        }\n\n        // 渲染图表\n        try {\n          chart.setOption(option);\n          console.log('关键词云图表渲染成功');\n        } catch (error) {\n          console.error('关键词云图表渲染失败:', error);\n          // 尝试使用简单柱状图作为后备显示方案\n          try {\n            const backupOption = {\n              title: {\n                text: props.title,\n                left: 'center'\n              },\n              tooltip: {\n                trigger: 'axis'\n              },\n              xAxis: {\n                type: 'category',\n                data: formattedData.slice(0, 10).map(item => item.name),\n                axisLabel: {\n                  rotate: 45,\n                  interval: 0\n                }\n              },\n              yAxis: {\n                type: 'value'\n              },\n              series: [{\n                name: '权重',\n                type: 'bar',\n                data: formattedData.slice(0, 10).map(item => item.value)\n              }]\n            };\n            chart.setOption(backupOption);\n            console.log('使用备用图表方案渲染成功');\n          } catch (backupError) {\n            console.error('备用图表方案也失败:', backupError);\n          }\n        }\n      });\n    }\n\n    // 格式化关键词数据\n    const formatKeywords = (keywords) => {\n      if (!keywords || !keywords.length) return []\n      \n      console.log('原始关键词数据:', keywords);\n      \n      // 确保keywords是一个数组\n      if (!Array.isArray(keywords)) {\n        console.warn('关键词数据不是数组格式:', keywords);\n        // 尝试从对象中提取关键词数据\n        if (typeof keywords === 'object' && keywords !== null) {\n          // 查找可能的数组属性\n          for (const key in keywords) {\n            if (Array.isArray(keywords[key])) {\n              console.log('从对象中找到关键词数组:', key);\n              keywords = keywords[key];\n              break;\n            }\n          }\n        }\n        \n        // 如果仍然不是数组，返回空数组\n        if (!Array.isArray(keywords)) {\n          console.error('无法处理的关键词数据格式，返回空数组');\n          return [];\n        }\n      }\n      \n      const result = keywords.map(item => {\n        if (typeof item === 'string') {\n          return {\n            name: item,\n            value: Math.floor(Math.random() * 90) + 10 // 如果只有词，随机生成权重\n          }\n        } else if (typeof item === 'object' && item !== null) {\n          return {\n            name: item.word || item.name || item.keyword || '',\n            value: item.weight || item.value || item.count || Math.floor(Math.random() * 90) + 10\n          }\n        }\n        return { name: '', value: 0 }\n      }).filter(item => item.name);\n      \n      console.log('格式化后的关键词数据:', result);\n      return result;\n    }\n\n    // 处理窗口大小改变\n    const handleResize = () => {\n      chart && chart.resize()\n    }\n\n    // 监听关键词变化\n    watch(() => props.keywords, (newVal) => {\n      if (chart) {\n        chart.setOption({\n          series: [{\n            data: formatKeywords(newVal)\n          }]\n        })\n      } else {\n        // 如果图表还未初始化，则初始化\n        initChart()\n      }\n    }, { deep: true })\n    \n    // 监听加载状态\n    watch(() => props.loading, (newVal) => {\n      if (!newVal && !chart && chartRef.value) {\n        // 加载完成且图表未初始化\n        initChart()\n      }\n    })\n\n    // 组件挂载时初始化图表\n    onMounted(() => {\n      console.log('KeywordCloud组件已挂载');\n      \n      // 确保echarts-wordcloud已加载\n      if (!echarts.getMap('series').wordCloud) {\n        console.warn('WordCloud系列未在组件挂载时注册，尝试重新加载');\n        try {\n          // 尝试重新导入\n          import('echarts-wordcloud').then(() => {\n            console.log('重新导入echarts-wordcloud成功');\n            // 延迟初始化图表，确保注册完成\n            setTimeout(() => initChart(), 300);\n          }).catch(error => {\n            console.error('重新导入echarts-wordcloud失败:', error);\n          });\n        } catch (error) {\n          console.error('导入echarts-wordcloud失败:', error);\n        }\n      } else {\n        // 如果窗口已经加载完成\n        if (document.readyState === 'complete') {\n          console.log('文档已完全加载，立即初始化图表');\n          nextTick().then(() => initChart());\n        } else {\n          // 否则等待窗口完全加载\n          console.log('文档未完全加载，等待load事件');\n          window.addEventListener('load', () => {\n            console.log('文档加载完成，开始初始化图表');\n            nextTick().then(() => initChart());\n          });\n        }\n      }\n      \n      // 确保在组件销毁时移除事件监听\n      window.addEventListener('resize', handleResize);\n    })\n\n    // 组件卸载前销毁图表\n    onBeforeUnmount(() => {\n      if (chart) {\n        chart.dispose()\n        chart = null\n      }\n      window.removeEventListener('resize', handleResize)\n    })\n\n    return {\n      chartRef,\n      hasData,\n      chart\n    }\n  }\n}\n</script>\n\n<style scoped>\n.chart-container {\n  width: v-bind(width);\n  height: v-bind(height);\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.keyword-cloud-chart {\n  width: 100%;\n  height: 100%;\n  transition: opacity 0.3s ease;\n}\n\n.loading-overlay {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  background-color: rgba(255, 255, 255, 0.8);\n  z-index: 10;\n}\n\n.loading-spinner {\n  width: 40px;\n  height: 40px;\n  border: 3px solid #f3f3f3;\n  border-top: 3px solid #3498db;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n.loading-text {\n  margin-top: 10px;\n  color: #666;\n}\n\n.no-data-message {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  color: #909399;\n  font-size: 14px;\n}\n\n.no-data-message i {\n  font-size: 32px;\n  margin-bottom: 10px;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAiB;;EAD9BC,GAAA;EAEwBD,KAAK,EAAC;;;EAF9BC,GAAA;EAM8BD,KAAK,EAAC;;;uBALlCE,mBAAA,CAUM,OAVNC,UAUM,GATOC,MAAA,CAAAC,OAAO,I,cAAlBH,mBAAA,CAGM,OAHNI,UAGM,EAAAC,MAAA,QAAAA,MAAA,OAFJC,mBAAA,CAAmC;IAA9BR,KAAK,EAAC;EAAiB,4BAC5BQ,mBAAA,CAAsC;IAAjCR,KAAK,EAAC;EAAc,GAAC,QAAM,oB,OAEjBS,MAAA,CAAAC,OAAO,I,cAAxBR,mBAAA,CAGM,OAHNS,UAGM,EAAAJ,MAAA,QAAAA,MAAA,OAFJC,mBAAA,CAAuC;IAApCR,KAAK,EAAC;EAAyB,4BAClCQ,mBAAA,CAAc,WAAX,SAAO,oB,MARhBI,mBAAA,gBAUIJ,mBAAA,CAA4F;IAAvFK,GAAG,EAAC,UAAU;IAACb,KAAK,EAAC,qBAAqB;IAAEc,KAAK,EAV1DC,eAAA;MAAAC,OAAA,EAUuEP,MAAA,CAAAC,OAAO;IAAA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}