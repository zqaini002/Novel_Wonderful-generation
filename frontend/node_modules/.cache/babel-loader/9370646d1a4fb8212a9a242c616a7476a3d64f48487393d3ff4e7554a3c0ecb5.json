\", {\n      key: novel.id\n    }, [_createElementVNode(\"td\", null, _toDisplayString(novel.id), 1 /* TEXT */), _createElementVNode(\"td\", null, _toDisplayString(novel.title), 1 /* TEXT */), _createElementVNode(\"td\", null, _toDisplayString(novel.author), 1 /* TEXT */), _createElementVNode(\"td\", null, [_createElementVNode(\"span\", {\n      class: _normalizeClass(['status-badge', novel.analysisStatus === 'COMPLETED' ? 'status-success' : novel.analysisStatus === 'PROCESSING' ? 'status-warning' : 'status-danger'])\n    }, _toDisplayString($setup.getStatusText(novel.analysisStatus)), 3 /* TEXT, CLASS */)]), _createElementVNode(\"td\", null, _toDisplayString($setup.formatDate(novel.analysisTime)), 1 /* TEXT */), _createElementVNode(\"td\", null, [_createElementVNode(\"button\", {\n      class: \"btn btn-primary btn-sm\",\n      onClick: $event => $setup.viewVisualization(novel.id)\n    }, \" 查看可视化 \", 8 /* PROPS */, _hoisted_17)])]);\n  }), 128 /* KEYED_FRAGMENT */))])])])])]), _createElementVNode(\"div\", _hoisted_18, [_createElementVNode(\"div\", _hoisted_19, [_cache[7] || (_cache[7] = _createElementVNode(\"h3\", null, \"小说类型分布\", -1 /* HOISTED */)), _createElementVNode(\"div\", _hoisted_20, null, 512 /* NEED_PATCH */)]), _createElementVNode(\"div\", _hoisted_21, [_cache[8] || (_cache[8] = _createElementVNode(\"h3\", null, \"每月分析数量\", -1 /* HOISTED */)), _createElementVNode(\"div\", _hoisted_22, null, 512 /* NEED_PATCH */)])])]);\n}","map":{"version":3,"names":["class","ref","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_hoisted_3","_hoisted_4","_hoisted_5","_hoisted_6","_toDisplayString","$setup","stats","totalNovels","_hoisted_7","_hoisted_8","analyzedNovels","_hoisted_9","_hoisted_10","totalUsers","_hoisted_11","_hoisted_12","totalAnalysis","_hoisted_13","_hoisted_14","_hoisted_15","_hoisted_16","_Fragment","_renderList","recentNovels","novel","key","id","title","author","_normalizeClass","analysisStatus","getStatusText","formatDate","analysisTime","onClick","$event","viewVisualization","_hoisted_17","_hoisted_18","_hoisted_19","_hoisted_20","_hoisted_21","_hoisted_22"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\admin\\VisualizationView.vue"],"sourcesContent":["<template>\r\n  <div class=\"visualization-container\">\r\n    <h1 class=\"page-title\">小说可视化总览</h1>\r\n    \r\n    <div class=\"card stats-card\">\r\n      <div class=\"card-header\">\r\n        <h2>平台数据总览</h2>\r\n      </div>\r\n      <div class=\"card-body\">\r\n        <div class=\"stats-grid\">\r\n          <div class=\"stat-item\">\r\n            <div class=\"stat-value\">{{ stats.totalNovels }}</div>\r\n            <div class=\"stat-label\">小说总数</div>\r\n          </div>\r\n          <div class=\"stat-item\">\r\n            <div class=\"stat-value\">{{ stats.analyzedNovels }}</div>\r\n            <div class=\"stat-label\">已分析小说</div>\r\n          </div>\r\n          <div class=\"stat-item\">\r\n            <div class=\"stat-value\">{{ stats.totalUsers }}</div>\r\n            <div class=\"stat-label\">用户总数</div>\r\n          </div>\r\n          <div class=\"stat-item\">\r\n            <div class=\"stat-value\">{{ stats.totalAnalysis }}</div>\r\n            <div class=\"stat-label\">分析总次数</div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"card\">\r\n      <div class=\"card-header\">\r\n        <h2>最近分析的小说</h2>\r\n      </div>\r\n      <div class=\"card-body\">\r\n        <div class=\"table-responsive\">\r\n          <table class=\"data-table\">\r\n            <thead>\r\n              <tr>\r\n                <th>ID</th>\r\n                <th>书名</th>\r\n                <th>作者</th>\r\n                <th>分析状态</th>\r\n                <th>分析时间</th>\r\n                <th>操作</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"novel in recentNovels\" :key=\"novel.id\">\r\n                <td>{{ novel.id }}</td>\r\n                <td>{{ novel.title }}</td>\r\n                <td>{{ novel.author }}</td>\r\n                <td>\r\n                  <span :class=\"['status-badge', novel.analysisStatus === 'COMPLETED' ? 'status-success' : \r\n                    novel.analysisStatus === 'PROCESSING' ? 'status-warning' : 'status-danger']\">\r\n                    {{ getStatusText(novel.analysisStatus) }}\r\n                  </span>\r\n                </td>\r\n                <td>{{ formatDate(novel.analysisTime) }}</td>\r\n                <td>\r\n                  <button class=\"btn btn-primary btn-sm\" @click=\"viewVisualization(novel.id)\">\r\n                    查看可视化\r\n                  </button>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"visualization-grid\">\r\n      <div class=\"chart-container\">\r\n        <h3>小说类型分布</h3>\r\n        <div ref=\"genreChartRef\" class=\"chart\"></div>\r\n      </div>\r\n      <div class=\"chart-container\">\r\n        <h3>每月分析数量</h3>\r\n        <div ref=\"monthlyAnalysisRef\" class=\"chart\"></div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted, reactive } from 'vue';\r\nimport { useRouter } from 'vue-router';\r\nimport * as echarts from 'echarts';\r\nimport adminService from '@/api/admin';\r\n\r\nconst router = useRouter();\r\nconst genreChartRef = ref(null);\r\nconst monthlyAnalysisRef = ref(null);\r\nconst recentNovels = ref([]);\r\n\r\nconst stats = reactive({\r\n  totalNovels: 0,\r\n  analyzedNovels: 0,\r\n  totalUsers: 0,\r\n  totalAnalysis: 0\r\n});\r\n\r\nonMounted(async () => {\r\n  try {\r\n    // 获取仪表盘数据\r\n    const dashboardData = await adminService.getDashboardStats();\r\n    stats.totalNovels = dashboardData.totalNovels || 0;\r\n    stats.analyzedNovels = dashboardData.analyzedNovels || 0;\r\n    stats.totalUsers = dashboardData.totalUsers || 0;\r\n    stats.totalAnalysis = dashboardData.totalAnalysis || 0;\r\n    \r\n    // 获取最近分析的小说\r\n    const novelsResponse = await adminService.getRecentAnalyzedNovels();\r\n    recentNovels.value = novelsResponse.data || [];\r\n    \r\n    // 获取图表数据\r\n    const chartData = await adminService.getVisualizationData();\r\n    \r\n    // 初始化图表\r\n    initGenreChart(chartData.genreDistribution || []);\r\n    initMonthlyAnalysisChart(chartData.monthlyAnalysis || []);\r\n  } catch (error) {\r\n    console.error('获取可视化数据失败:', error);\r\n  }\r\n});\r\n\r\n// 初始化小说类型分布图表\r\nfunction initGenreChart(data) {\r\n  if (!genreChartRef.value) return;\r\n  \r\n  const chart = echarts.init(genreChartRef.value);\r\n  const option = {\r\n    tooltip: {\r\n      trigger: 'item',\r\n      formatter: '{a} <br/>{b}: {c} ({d}%)'\r\n    },\r\n    legend: {\r\n      orient: 'vertical',\r\n      right: 10,\r\n      top: 'center',\r\n      data: data.map(item => item.name)\r\n    },\r\n    series: [\r\n      {\r\n        name: '小说类型',\r\n        type: 'pie',\r\n        radius: ['50%', '70%'],\r\n        avoidLabelOverlap: false,\r\n        itemStyle: {\r\n          borderRadius: 10,\r\n          borderColor: '#fff',\r\n          borderWidth: 2\r\n        },\r\n        label: {\r\n          show: false,\r\n          position: 'center'\r\n        },\r\n        emphasis: {\r\n          label: {\r\n            show: true,\r\n            fontSize: '18',\r\n            fontWeight: 'bold'\r\n          }\r\n        },\r\n        labelLine: {\r\n          show: false\r\n        },\r\n        data: data\r\n      }\r\n    ]\r\n  };\r\n  \r\n  chart.setOption(option);\r\n  window.addEventListener('resize', () => {\r\n    chart.resize();\r\n  });\r\n}\r\n\r\n// 初始化每月分析数量图表\r\nfunction initMonthlyAnalysisChart(data) {\r\n  if (!monthlyAnalysisRef.value) return;\r\n  \r\n  const chart = echarts.init(monthlyAnalysisRef.value);\r\n  const months = data.map(item => item.month);\r\n  const counts = data.map(item => item.count);\r\n  \r\n  const option = {\r\n    tooltip: {\r\n      trigger: 'axis',\r\n      axisPointer: {\r\n        type: 'shadow'\r\n      }\r\n    },\r\n    grid: {\r\n      left: '3%',\r\n      right: '4%',\r\n      bottom: '3%',\r\n      containLabel: true\r\n    },\r\n    xAxis: [\r\n      {\r\n        type: 'category',\r\n        data: months,\r\n        axisTick: {\r\n          alignWithLabel: true\r\n        }\r\n      }\r\n    ],\r\n    yAxis: [\r\n      {\r\n        type: 'value'\r\n      }\r\n    ],\r\n    series: [\r\n      {\r\n        name: '分析数量',\r\n        type: 'bar',\r\n        barWidth: '60%',\r\n        data: counts\r\n      }\r\n    ]\r\n  };\r\n  \r\n  chart.setOption(option);\r\n  window.addEventListener('resize', () => {\r\n    chart.resize();\r\n  });\r\n}\r\n\r\n// 格式化日期\r\nfunction formatDate(dateString) {\r\n  if (!dateString) return '未知';\r\n  const date = new Date(dateString);\r\n  return date.toLocaleString('zh-CN', {\r\n    year: 'numeric',\r\n    month: '2-digit',\r\n    day: '2-digit',\r\n    hour: '2-digit',\r\n    minute: '2-digit'\r\n  });\r\n}\r\n\r\n// 获取状态文本\r\nfunction getStatusText(status) {\r\n  const statusMap = {\r\n    'COMPLETED': '已完成',\r\n    'PROCESSING': '处理中',\r\n    'FAILED': '失败',\r\n    'PENDING': '等待中'\r\n  };\r\n  return statusMap[status] || status;\r\n}\r\n\r\n// 查看小说可视化\r\nfunction viewVisualization(novelId) {\r\n  router.push(`/admin/novel/${novelId}/visualization`);\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.visualization-container {\r\n  padding: 20px;\r\n}\r\n\r\n.page-title {\r\n  font-size: 24px;\r\n  margin-bottom: 20px;\r\n  color: var(--primary-color);\r\n}\r\n\r\n.card {\r\n  background: #fff;\r\n  border-radius: 8px;\r\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);\r\n  margin-bottom: 24px;\r\n  overflow: hidden;\r\n}\r\n\r\n.card-header {\r\n  padding: 15px 20px;\r\n  background: rgba(0, 0, 0, 0.03);\r\n  border-bottom: 1px solid rgba(0, 0, 0, 0.125);\r\n}\r\n\r\n.card-header h2 {\r\n  margin: 0;\r\n  font-size: 18px;\r\n  font-weight: 600;\r\n}\r\n\r\n.card-body {\r\n  padding: 20px;\r\n}\r\n\r\n.stats-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(4, 1fr);\r\n  gap: 20px;\r\n}\r\n\r\n.stat-item {\r\n  text-align: center;\r\n  padding: 15px;\r\n  background: var(--secondary-bg);\r\n  border-radius: 8px;\r\n}\r\n\r\n.stat-value {\r\n  font-size: 28px;\r\n  font-weight: 700;\r\n  color: var(--primary-color);\r\n  margin-bottom: 5px;\r\n}\r\n\r\n.stat-label {\r\n  font-size: 14px;\r\n  color: #666;\r\n}\r\n\r\n.data-table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n}\r\n\r\n.data-table th,\r\n.data-table td {\r\n  padding: 12px 15px;\r\n  text-align: left;\r\n  border-bottom: 1px solid #eee;\r\n}\r\n\r\n.data-table th {\r\n  background-color: var(--secondary-bg);\r\n  font-weight: 600;\r\n}\r\n\r\n.status-badge {\r\n  padding: 4px 8px;\r\n  border-radius: 4px;\r\n  font-size: 12px;\r\n  font-weight: 500;\r\n}\r\n\r\n.status-success {\r\n  background-color: #e6f7e6;\r\n  color: #28a745;\r\n}\r\n\r\n.status-warning {\r\n  background-color: #fff8e1;\r\n  color: #ffc107;\r\n}\r\n\r\n.status-danger {\r\n  background-color: #ffebee;\r\n  color: #dc3545;\r\n}\r\n\r\n.btn {\r\n  padding: 5px 12px;\r\n  border: none;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n  font-weight: 500;\r\n  transition: background-color 0.2s;\r\n}\r\n\r\n.btn-primary {\r\n  background-color: var(--primary-color);\r\n  color: white;\r\n}\r\n\r\n.btn-sm {\r\n  font-size: 12px;\r\n  padding: 4px 8px;\r\n}\r\n\r\n.visualization-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(2, 1fr);\r\n  gap: 24px;\r\n  margin-top: 24px;\r\n}\r\n\r\n.chart-container {\r\n  background: #fff;\r\n  border-radius: 8px;\r\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);\r\n  padding: 20px;\r\n}\r\n\r\n.chart-container h3 {\r\n  margin-top: 0;\r\n  margin-bottom: 15px;\r\n  font-size: 16px;\r\n  color: #333;\r\n}\r\n\r\n.chart {\r\n  height: 300px;\r\n  width: 100%;\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .stats-grid {\r\n    grid-template-columns: repeat(2, 1fr);\r\n  }\r\n  \r\n  .visualization-grid {\r\n    grid-template-columns: 1fr;\r\n  }\r\n  \r\n  .table-responsive {\r\n    overflow-x: auto;\r\n  }\r\n}\r\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAyB;;EAG7BA,KAAK,EAAC;AAAiB;;EAIrBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAChBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAGpBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAGpBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAGpBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAO1BA,KAAK,EAAC;AAAM;;EAIVA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAkB;;EACpBA,KAAK,EAAC;AAAY;oBApCnC;;EAuESA,KAAK,EAAC;AAAoB;;EACxBA,KAAK,EAAC;AAAiB;;EAErBC,GAAG,EAAC,eAAe;EAACD,KAAK,EAAC;;;EAE5BA,KAAK,EAAC;AAAiB;;EAErBC,GAAG,EAAC,oBAAoB;EAACD,KAAK,EAAC;;;uBA7E1CE,mBAAA,CAgFM,OAhFNC,UAgFM,G,0BA/EJC,mBAAA,CAAmC;IAA/BJ,KAAK,EAAC;EAAY,GAAC,SAAO,sBAE9BI,mBAAA,CAwBM,OAxBNC,UAwBM,G,0BAvBJD,mBAAA,CAEM;IAFDJ,KAAK,EAAC;EAAa,IACtBI,mBAAA,CAAe,YAAX,QAAM,E,sBAEZA,mBAAA,CAmBM,OAnBNE,UAmBM,GAlBJF,mBAAA,CAiBM,OAjBNG,UAiBM,GAhBJH,mBAAA,CAGM,OAHNI,UAGM,GAFJJ,mBAAA,CAAqD,OAArDK,UAAqD,EAAAC,gBAAA,CAA1BC,MAAA,CAAAC,KAAK,CAACC,WAAW,kB,0BAC5CT,mBAAA,CAAkC;IAA7BJ,KAAK,EAAC;EAAY,GAAC,MAAI,qB,GAE9BI,mBAAA,CAGM,OAHNU,UAGM,GAFJV,mBAAA,CAAwD,OAAxDW,UAAwD,EAAAL,gBAAA,CAA7BC,MAAA,CAAAC,KAAK,CAACI,cAAc,kB,0BAC/CZ,mBAAA,CAAmC;IAA9BJ,KAAK,EAAC;EAAY,GAAC,OAAK,qB,GAE/BI,mBAAA,CAGM,OAHNa,UAGM,GAFJb,mBAAA,CAAoD,OAApDc,WAAoD,EAAAR,gBAAA,CAAzBC,MAAA,CAAAC,KAAK,CAACO,UAAU,kB,0BAC3Cf,mBAAA,CAAkC;IAA7BJ,KAAK,EAAC;EAAY,GAAC,MAAI,qB,GAE9BI,mBAAA,CAGM,OAHNgB,WAGM,GAFJhB,mBAAA,CAAuD,OAAvDiB,WAAuD,EAAAX,gBAAA,CAA5BC,MAAA,CAAAC,KAAK,CAACU,aAAa,kB,0BAC9ClB,mBAAA,CAAmC;IAA9BJ,KAAK,EAAC;EAAY,GAAC,OAAK,qB,SAMrCI,mBAAA,CAuCM,OAvCNmB,WAuCM,G,0BAtCJnB,mBAAA,CAEM;IAFDJ,KAAK,EAAC;EAAa,IACtBI,mBAAA,CAAgB,YAAZ,SAAO,E,sBAEbA,mBAAA,CAkCM,OAlCNoB,WAkCM,GAjCJpB,mBAAA,CAgCM,OAhCNqB,WAgCM,GA/BJrB,mBAAA,CA8BQ,SA9BRsB,WA8BQ,G,0BA7BNtB,mBAAA,CASQ,gBARNA,mBAAA,CAOK,aANHA,mBAAA,CAAW,Y