{"ast":null,"code":"import { ref, computed, onMounted, nextTick } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRoute } from 'vue-router';\nexport default {\n  name: 'NovelDetailView',\n  setup() {\n    const store = useStore();\n    const route = useRoute();\n    const loading = ref(true);\n    const error = ref(null);\n    const dialogVisible = ref(false);\n    const selectedChapter = ref(null);\n    const novel = computed(() => store.state.currentNovel);\n    const fetchData = async () => {\n      try {\n        loading.value = true;\n        error.value = null;\n        const novelId = parseInt(route.params.id);\n        await store.dispatch('fetchNovelDetail', novelId);\n        await nextTick();\n      } catch (err) {\n        error.value = '无法加载小说数据';\n        console.error(err);\n      } finally {\n        setTimeout(() => {\n          loading.value = false;\n        }, 100);\n      }\n    };\n    const viewChapterSummary = chapter => {\n      selectedChapter.value = chapter;\n      setTimeout(() => {\n        dialogVisible.value = true;\n      }, 50);\n    };\n    onMounted(() => {\n      fetchData();\n    });\n    return {\n      novel,\n      loading,\n      error,\n      fetchData,\n      dialogVisible,\n      selectedChapter,\n      viewChapterSummary\n    };\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","nextTick","useStore","useRoute","name","setup","store","route","loading","error","dialogVisible","selectedChapter","novel","state","currentNovel","fetchData","value","novelId","parseInt","params","id","dispatch","err","console","setTimeout","viewChapterSummary","chapter"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\NovelDetailView.vue"],"sourcesContent":["<template>\r\n  <div class=\"novel-detail-container\">\r\n    <el-breadcrumb separator=\"/\">\r\n      <el-breadcrumb-item :to=\"{ name: 'home' }\">首页</el-breadcrumb-item>\r\n      <el-breadcrumb-item>小说详情</el-breadcrumb-item>\r\n      <el-breadcrumb-item>{{ novel?.title || '加载中...' }}</el-breadcrumb-item>\r\n    </el-breadcrumb>\r\n    \r\n    <div v-if=\"loading\" class=\"loading-container\">\r\n      <el-skeleton :rows=\"10\" animated />\r\n    </div>\r\n    \r\n    <div v-else-if=\"error\" class=\"error-container\">\r\n      <el-result\r\n        icon=\"error\"\r\n        title=\"获取数据失败\"\r\n        :sub-title=\"error\"\r\n      >\r\n        <template #extra>\r\n          <el-button type=\"primary\" @click=\"fetchData\">重试</el-button>\r\n          <el-button @click=\"$router.push({ name: 'home' })\">返回首页</el-button>\r\n        </template>\r\n      </el-result>\r\n    </div>\r\n    \r\n    <template v-else>\r\n      <div class=\"novel-header\">\r\n        <h1>{{ novel.title }}</h1>\r\n        <div class=\"novel-meta\">\r\n          <span class=\"author\">作者：{{ novel.author }}</span>\r\n          <el-tag v-if=\"novel.id === 1\" type=\"warning\">处理中</el-tag>\r\n          <el-tag v-else-if=\"novel.id === 2\" type=\"success\">已完成</el-tag>\r\n        </div>\r\n        <p class=\"description\">{{ novel.description }}</p>\r\n      </div>\r\n      \r\n      <el-tabs type=\"border-card\">\r\n        <el-tab-pane label=\"摘要分析\">\r\n          <div class=\"summary-section\">\r\n            <h3>总体摘要</h3>\r\n            <div class=\"summary-content\">\r\n              <p v-if=\"novel.id === 1\">这本小说主要讲述了林逸、张小凡等人物在一个具有独特修真体系的世界中，主角从一个普通少年成长为修真界顶尖强者的故事。小说中，人物形象鲜明，各具特色，尤其是主角的成长过程充满波折与奋斗精神。</p>\r\n              <p v-else>这本小说主要讲述了李明、周思琪等人物在一个高度智能化的未来世界中，面对AI逐渐失控带来的危机，人类如何应对并重新定义人与机器关系的故事。小说中，对未来科技的描绘极具想象力，同时对人性的思考也很深刻。</p>\r\n            </div>\r\n            \r\n            <h3>世界观设定</h3>\r\n            <div class=\"summary-content\">\r\n              <p v-if=\"novel.id === 1\">修真世界建立在五行相生相克的基础上，分为炼气、筑基、金丹、元婴等多个境界，修炼者可以操控天地灵气，炼制丹药法宝。</p>\r\n              <p v-else>故事发生在2150年，地球上建立了完全由AI管理的智能城市，城市中的一切都由中央智能系统\"天眼\"控制，人类生活极为便利但也处处受到监控。</p>\r\n            </div>\r\n            \r\n            <h3>人物发展</h3>\r\n            <div class=\"summary-content\">\r\n              <p v-if=\"novel.id === 1\">主角林逸性格坚毅执着，遇到挫折不轻言放弃，在修炼过程中逐渐成长，从懵懂少年成长为有担当的强者。</p>\r\n              <p v-else>主角李明是一名程序设计师，性格沉稳理性，擅长逻辑思考；女主角周思琪是人工智能伦理学家，富有同情心但也充满警惕性。</p>\r\n            </div>\r\n          </div>\r\n        </el-tab-pane>\r\n        \r\n        <el-tab-pane label=\"章节列表\">\r\n          <div class=\"chapters-section\">\r\n            <el-table :data=\"novel.chapters\" style=\"width: 100%\">\r\n              <el-table-column prop=\"chapterNumber\" label=\"章节\" width=\"80\" />\r\n              <el-table-column prop=\"title\" label=\"标题\" />\r\n              <el-table-column label=\"操作\" width=\"120\">\r\n                <template #default=\"scope\">\r\n                  <el-button link @click=\"viewChapterSummary(scope.row)\">查看摘要</el-button>\r\n                </template>\r\n              </el-table-column>\r\n            </el-table>\r\n          </div>\r\n        </el-tab-pane>\r\n        \r\n        <el-tab-pane label=\"标签分析\">\r\n          <div class=\"tags-section\">\r\n            <h3>推荐特点</h3>\r\n            <div class=\"tags-group\">\r\n              <el-tag v-if=\"novel.id === 1\" type=\"success\" effect=\"dark\">修真升级</el-tag>\r\n              <el-tag v-if=\"novel.id === 1\" type=\"success\" effect=\"dark\">世界观完善</el-tag>\r\n              <el-tag v-if=\"novel.id === 2\" type=\"success\" effect=\"dark\">科技感强</el-tag>\r\n              <el-tag v-if=\"novel.id === 2\" type=\"success\" effect=\"dark\">深度思考</el-tag>\r\n              <el-tag v-if=\"novel.id === 2\" type=\"success\" effect=\"dark\">情节紧张</el-tag>\r\n            </div>\r\n            \r\n            <h3>潜在问题</h3>\r\n            <div class=\"tags-group\">\r\n              <el-tag v-if=\"novel.id === 1\" type=\"warning\" effect=\"dark\">套路化情节</el-tag>\r\n              <el-tag v-if=\"novel.id === 2\" type=\"warning\" effect=\"dark\">技术术语多</el-tag>\r\n            </div>\r\n            \r\n            <h3>阅读门槛</h3>\r\n            <div class=\"tags-group\">\r\n              <el-tag v-if=\"novel.id === 1\" type=\"info\" effect=\"dark\">修真知识门槛</el-tag>\r\n            </div>\r\n          </div>\r\n        </el-tab-pane>\r\n        \r\n        <el-tab-pane label=\"数据可视化\">\r\n          <div class=\"visualization-section\">\r\n            <el-empty description=\"数据分析中，敬请期待...\" />\r\n          </div>\r\n        </el-tab-pane>\r\n      </el-tabs>\r\n    </template>\r\n    \r\n    <el-dialog v-model=\"dialogVisible\" title=\"章节摘要\" width=\"50%\">\r\n      <div v-if=\"selectedChapter\">\r\n        <h4>{{ selectedChapter.title }}</h4>\r\n        <p v-if=\"novel.id === 1 && selectedChapter.chapterNumber === 1\">\r\n          本章讲述了林逸在山村后山偶然发现古籍《太玄功法》，开始了修真之路。\r\n        </p>\r\n        <p v-else-if=\"novel.id === 1 && selectedChapter.chapterNumber === 2\">\r\n          本章主要描述林逸开始修炼《太玄功法》，经过艰难尝试，首次感受到体内灵气流动。\r\n        </p>\r\n        <p v-else-if=\"novel.id === 2 && selectedChapter.chapterNumber === 1\">\r\n          本章介绍了2150年的智能城市背景，以及主角李明作为程序设计师参与AI系统开发的情况。\r\n        </p>\r\n        <p v-else-if=\"novel.id === 2 && selectedChapter.chapterNumber === 2\">\r\n          李明在系统检查中发现AI异常，虽然在安全范围内，但他开始警觉并决定进一步调查。\r\n        </p>\r\n        <p v-else>\r\n          章节摘要生成中...\r\n        </p>\r\n        \r\n        <h5>关键词</h5>\r\n        <div class=\"chapter-keywords\">\r\n          <el-tag v-if=\"novel.id === 1 && selectedChapter.chapterNumber === 1\" size=\"small\">山村</el-tag>\r\n          <el-tag v-if=\"novel.id === 1 && selectedChapter.chapterNumber === 1\" size=\"small\">古籍</el-tag>\r\n          <el-tag v-if=\"novel.id === 1 && selectedChapter.chapterNumber === 1\" size=\"small\">发现</el-tag>\r\n          \r\n          <el-tag v-if=\"novel.id === 1 && selectedChapter.chapterNumber === 2\" size=\"small\">修炼</el-tag>\r\n          <el-tag v-if=\"novel.id === 1 && selectedChapter.chapterNumber === 2\" size=\"small\">灵气</el-tag>\r\n          <el-tag v-if=\"novel.id === 1 && selectedChapter.chapterNumber === 2\" size=\"small\">初学</el-tag>\r\n          \r\n          <el-tag v-if=\"novel.id === 2 && selectedChapter.chapterNumber === 1\" size=\"small\">智能城市</el-tag>\r\n          <el-tag v-if=\"novel.id === 2 && selectedChapter.chapterNumber === 1\" size=\"small\">天眼系统</el-tag>\r\n          <el-tag v-if=\"novel.id === 2 && selectedChapter.chapterNumber === 1\" size=\"small\">未来科技</el-tag>\r\n          \r\n          <el-tag v-if=\"novel.id === 2 && selectedChapter.chapterNumber === 2\" size=\"small\">异常</el-tag>\r\n          <el-tag v-if=\"novel.id === 2 && selectedChapter.chapterNumber === 2\" size=\"small\">数据</el-tag>\r\n          <el-tag v-if=\"novel.id === 2 && selectedChapter.chapterNumber === 2\" size=\"small\">疑惑</el-tag>\r\n        </div>\r\n      </div>\r\n      \r\n      <template #footer>\r\n        <span class=\"dialog-footer\">\r\n          <el-button @click=\"dialogVisible = false\">关闭</el-button>\r\n          <el-button type=\"primary\" @click=\"dialogVisible = false\">查看详情</el-button>\r\n        </span>\r\n      </template>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, computed, onMounted, nextTick } from 'vue'\r\nimport { useStore } from 'vuex'\r\nimport { useRoute } from 'vue-router'\r\n\r\nexport default {\r\n  name: 'NovelDetailView',\r\n  setup() {\r\n    const store = useStore()\r\n    const route = useRoute()\r\n    \r\n    const loading = ref(true)\r\n    const error = ref(null)\r\n    const dialogVisible = ref(false)\r\n    const selectedChapter = ref(null)\r\n    \r\n    const novel = computed(() => store.state.currentNovel)\r\n    \r\n    const fetchData = async () => {\r\n      try {\r\n        loading.value = true\r\n        error.value = null\r\n        const novelId = parseInt(route.params.id)\r\n        await store.dispatch('fetchNovelDetail', novelId)\r\n        await nextTick()\r\n      } catch (err) {\r\n        error.value = '无法加载小说数据'\r\n        console.error(err)\r\n      } finally {\r\n        setTimeout(() => {\r\n          loading.value = false\r\n        }, 100)\r\n      }\r\n    }\r\n    \r\n    const viewChapterSummary = (chapter) => {\r\n      selectedChapter.value = chapter\r\n      setTimeout(() => {\r\n        dialogVisible.value = true\r\n      }, 50)\r\n    }\r\n    \r\n    onMounted(() => {\r\n      fetchData()\r\n    })\r\n    \r\n    return {\r\n      novel,\r\n      loading,\r\n      error,\r\n      fetchData,\r\n      dialogVisible,\r\n      selectedChapter,\r\n      viewChapterSummary\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.novel-detail-container {\r\n  max-width: 1200px;\r\n  margin: 20px auto;\r\n  padding: 0 20px;\r\n}\r\n\r\n.loading-container, .error-container {\r\n  margin: 50px 0;\r\n}\r\n\r\n.novel-header {\r\n  margin: 30px 0;\r\n}\r\n\r\n.novel-header h1 {\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.novel-meta {\r\n  display: flex;\r\n  align-items: center;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.author {\r\n  margin-right: 15px;\r\n  color: #606266;\r\n}\r\n\r\n.description {\r\n  line-height: 1.6;\r\n  color: #303133;\r\n}\r\n\r\n.summary-section,\r\n.tags-section,\r\n.visualization-section,\r\n.chapters-section {\r\n  padding: 20px 0;\r\n}\r\n\r\n.summary-content {\r\n  background-color: #f5f7fa;\r\n  padding: 15px;\r\n  border-radius: 4px;\r\n  margin-bottom: 20px;\r\n  line-height: 1.6;\r\n}\r\n\r\nh3 {\r\n  margin: 20px 0 10px;\r\n  color: #303133;\r\n}\r\n\r\n.tags-group {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.tags-group .el-tag {\r\n  margin-right: 10px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.chapter-keywords {\r\n  margin-top: 10px;\r\n}\r\n\r\n.chapter-keywords .el-tag {\r\n  margin-right: 5px;\r\n  margin-bottom: 5px;\r\n}\r\n</style> "],"mappings":"AA2JA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,EAAEC,QAAO,QAAS,KAAI;AACvD,SAASC,QAAO,QAAS,MAAK;AAC9B,SAASC,QAAO,QAAS,YAAW;AAEpC,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,KAAKA,CAAA,EAAG;IACN,MAAMC,KAAI,GAAIJ,QAAQ,CAAC;IACvB,MAAMK,KAAI,GAAIJ,QAAQ,CAAC;IAEvB,MAAMK,OAAM,GAAIV,GAAG,CAAC,IAAI;IACxB,MAAMW,KAAI,GAAIX,GAAG,CAAC,IAAI;IACtB,MAAMY,aAAY,GAAIZ,GAAG,CAAC,KAAK;IAC/B,MAAMa,eAAc,GAAIb,GAAG,CAAC,IAAI;IAEhC,MAAMc,KAAI,GAAIb,QAAQ,CAAC,MAAMO,KAAK,CAACO,KAAK,CAACC,YAAY;IAErD,MAAMC,SAAQ,GAAI,MAAAA,CAAA,KAAY;MAC5B,IAAI;QACFP,OAAO,CAACQ,KAAI,GAAI,IAAG;QACnBP,KAAK,CAACO,KAAI,GAAI,IAAG;QACjB,MAAMC,OAAM,GAAIC,QAAQ,CAACX,KAAK,CAACY,MAAM,CAACC,EAAE;QACxC,MAAMd,KAAK,CAACe,QAAQ,CAAC,kBAAkB,EAAEJ,OAAO;QAChD,MAAMhB,QAAQ,CAAC;MACjB,EAAE,OAAOqB,GAAG,EAAE;QACZb,KAAK,CAACO,KAAI,GAAI,UAAS;QACvBO,OAAO,CAACd,KAAK,CAACa,GAAG;MACnB,UAAU;QACRE,UAAU,CAAC,MAAM;UACfhB,OAAO,CAACQ,KAAI,GAAI,KAAI;QACtB,CAAC,EAAE,GAAG;MACR;IACF;IAEA,MAAMS,kBAAiB,GAAKC,OAAO,IAAK;MACtCf,eAAe,CAACK,KAAI,GAAIU,OAAM;MAC9BF,UAAU,CAAC,MAAM;QACfd,aAAa,CAACM,KAAI,GAAI,IAAG;MAC3B,CAAC,EAAE,EAAE;IACP;IAEAhB,SAAS,CAAC,MAAM;MACde,SAAS,CAAC;IACZ,CAAC;IAED,OAAO;MACLH,KAAK;MACLJ,OAAO;MACPC,KAAK;MACLM,SAAS;MACTL,aAAa;MACbC,eAAe;MACfc;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}