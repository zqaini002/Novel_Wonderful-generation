{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.some.js\";\nimport { defineComponent } from 'vue';\nimport { ElConfigProvider } from 'element-plus';\nimport zhCn from 'element-plus/es/locale/lang/zh-cn';\nimport HeaderComponent from '@/components/layout/HeaderComponent.vue';\nimport FooterComponent from '@/components/layout/FooterComponent.vue';\nexport default defineComponent({\n  name: 'App',\n  components: {\n    HeaderComponent,\n    FooterComponent,\n    ElConfigProvider\n  },\n  setup() {\n    return {\n      zhCn\n    };\n  },\n  created() {\n    // 全局前置守卫\n    this.$router.beforeEach((to, from, next) => {\n      // 设置页面标题\n      document.title = to.meta.title || '小说精读助手';\n\n      // 判断该路由是否需要登录权限\n      if (to.matched.some(record => record.meta.requiresAuth)) {\n        const user = JSON.parse(localStorage.getItem('user'));\n        if (!user) {\n          // 用户未登录，跳转到登录页\n          next({\n            path: '/login',\n            query: {\n              redirect: to.fullPath\n            }\n          });\n        } else if (to.matched.some(record => record.meta.requiresAdmin)) {\n          // 检查是否有管理员权限\n          const isAdmin = user.roles && user.roles.some(role => role.name === 'ROLE_ADMIN');\n          if (!isAdmin) {\n            // 无管理员权限，跳转到首页\n            next({\n              path: '/'\n            });\n          } else {\n            // 有管理员权限，继续访问\n            next();\n          }\n        } else {\n          // 普通登录页面，继续访问\n          next();\n        }\n      } else {\n        // 不需要登录的页面\n        next();\n      }\n    });\n  }\n});","map":{"version":3,"names":["defineComponent","ElConfigProvider","zhCn","HeaderComponent","FooterComponent","name","components","setup","created","$router","beforeEach","to","from","next","document","title","meta","matched","some","record","requiresAuth","user","JSON","parse","localStorage","getItem","path","query","redirect","fullPath","requiresAdmin","isAdmin","roles","role"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\App.vue"],"sourcesContent":["<template>\r\n  <div class=\"app-container\">\r\n    <el-config-provider :locale=\"zhCn\">\r\n      <el-container>\r\n        <el-header>\r\n          <header-component />\r\n        </el-header>\r\n        <el-main>\r\n          <transition name=\"fade\" mode=\"out-in\">\r\n            <router-view />\r\n          </transition>\r\n        </el-main>\r\n        <el-footer>\r\n          <footer-component />\r\n        </el-footer>\r\n      </el-container>\r\n    </el-config-provider>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { defineComponent } from 'vue'\r\nimport { ElConfigProvider } from 'element-plus'\r\nimport zhCn from 'element-plus/es/locale/lang/zh-cn'\r\nimport HeaderComponent from '@/components/layout/HeaderComponent.vue'\r\nimport FooterComponent from '@/components/layout/FooterComponent.vue'\r\n\r\nexport default defineComponent({\r\n  name: 'App',\r\n  components: {\r\n    HeaderComponent,\r\n    FooterComponent,\r\n    ElConfigProvider\r\n  },\r\n  setup() {\r\n    return {\r\n      zhCn\r\n    }\r\n  },\r\n  created() {\r\n    // 全局前置守卫\r\n    this.$router.beforeEach((to, from, next) => {\r\n      // 设置页面标题\r\n      document.title = to.meta.title || '小说精读助手'\r\n      \r\n      // 判断该路由是否需要登录权限\r\n      if (to.matched.some(record => record.meta.requiresAuth)) {\r\n        const user = JSON.parse(localStorage.getItem('user'))\r\n        \r\n        if (!user) {\r\n          // 用户未登录，跳转到登录页\r\n          next({\r\n            path: '/login',\r\n            query: { redirect: to.fullPath }\r\n          })\r\n        } else if (to.matched.some(record => record.meta.requiresAdmin)) {\r\n          // 检查是否有管理员权限\r\n          const isAdmin = user.roles && user.roles.some(role => role.name === 'ROLE_ADMIN')\r\n          \r\n          if (!isAdmin) {\r\n            // 无管理员权限，跳转到首页\r\n            next({ path: '/' })\r\n          } else {\r\n            // 有管理员权限，继续访问\r\n            next()\r\n          }\r\n        } else {\r\n          // 普通登录页面，继续访问\r\n          next()\r\n        }\r\n      } else {\r\n        // 不需要登录的页面\r\n        next()\r\n      }\r\n    })\r\n  }\r\n})\r\n</script>\r\n\r\n<style>\r\n@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap');\r\n\r\n:root {\r\n  --primary-color: #4d7bef;\r\n  --secondary-color: #5e60ce;\r\n  --background-color: #f9fafc;\r\n  --text-color: #333;\r\n  --border-color: #eaedf2;\r\n  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06);\r\n  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);\r\n  --radius: 8px;\r\n}\r\n\r\nhtml, body {\r\n  margin: 0;\r\n  padding: 0;\r\n  height: 100%;\r\n  font-family: 'Noto Sans SC', 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;\r\n  color: var(--text-color);\r\n  background-color: var(--background-color);\r\n  -webkit-font-smoothing: antialiased;\r\n  -moz-osx-font-smoothing: grayscale;\r\n}\r\n\r\n.app-container {\r\n  min-height: 100vh;\r\n  display: flex;\r\n  flex-direction: column;\r\n  background-image: \r\n    radial-gradient(circle at 100% 0%, rgba(77, 123, 239, 0.05) 0%, transparent 25%),\r\n    radial-gradient(circle at 0% 80%, rgba(94, 96, 206, 0.05) 0%, transparent 25%);\r\n  background-attachment: fixed;\r\n  background-size: cover;\r\n}\r\n\r\n.el-header {\r\n  padding: 0;\r\n  z-index: 999;\r\n}\r\n\r\n.el-main {\r\n  flex: 1;\r\n  padding: 24px;\r\n  max-width: 1280px;\r\n  margin: 0 auto;\r\n  width: 100%;\r\n}\r\n\r\n.el-footer {\r\n  padding: 30px 0;\r\n  background-color: #fff;\r\n  border-top: 1px solid var(--border-color);\r\n}\r\n\r\n/* 卡片样式优化 */\r\n.el-card {\r\n  border-radius: var(--radius);\r\n  border: none;\r\n  box-shadow: var(--shadow-sm) !important;\r\n  transition: box-shadow 0.3s;\r\n  overflow: hidden;\r\n}\r\n\r\n.el-card:hover {\r\n  box-shadow: var(--shadow-md) !important;\r\n}\r\n\r\n/* 按钮样式优化 */\r\n.el-button {\r\n  border-radius: 4px;\r\n  font-weight: 500;\r\n}\r\n\r\n.el-button--primary {\r\n  background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);\r\n  border: none;\r\n}\r\n\r\n/* 动画效果 */\r\n.fade-enter-active,\r\n.fade-leave-active {\r\n  transition: opacity 0.3s ease;\r\n}\r\n\r\n.fade-enter-from,\r\n.fade-leave-to {\r\n  opacity: 0;\r\n}\r\n\r\n/* 移动设备适配 */\r\n@media (max-width: 768px) {\r\n  .el-main {\r\n    padding: 16px;\r\n  }\r\n}\r\n</style> "],"mappings":";;AAqBA,SAASA,eAAc,QAAS,KAAI;AACpC,SAASC,gBAAe,QAAS,cAAa;AAC9C,OAAOC,IAAG,MAAO,mCAAkC;AACnD,OAAOC,eAAc,MAAO,yCAAwC;AACpE,OAAOC,eAAc,MAAO,yCAAwC;AAEpE,eAAeJ,eAAe,CAAC;EAC7BK,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IACVH,eAAe;IACfC,eAAe;IACfH;EACF,CAAC;EACDM,KAAKA,CAAA,EAAG;IACN,OAAO;MACLL;IACF;EACF,CAAC;EACDM,OAAOA,CAAA,EAAG;IACR;IACA,IAAI,CAACC,OAAO,CAACC,UAAU,CAAC,CAACC,EAAE,EAAEC,IAAI,EAAEC,IAAI,KAAK;MAC1C;MACAC,QAAQ,CAACC,KAAI,GAAIJ,EAAE,CAACK,IAAI,CAACD,KAAI,IAAK,QAAO;;MAEzC;MACA,IAAIJ,EAAE,CAACM,OAAO,CAACC,IAAI,CAACC,MAAK,IAAKA,MAAM,CAACH,IAAI,CAACI,YAAY,CAAC,EAAE;QACvD,MAAMC,IAAG,GAAIC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,CAAC;QAEpD,IAAI,CAACJ,IAAI,EAAE;UACT;UACAR,IAAI,CAAC;YACHa,IAAI,EAAE,QAAQ;YACdC,KAAK,EAAE;cAAEC,QAAQ,EAAEjB,EAAE,CAACkB;YAAS;UACjC,CAAC;QACH,OAAO,IAAIlB,EAAE,CAACM,OAAO,CAACC,IAAI,CAACC,MAAK,IAAKA,MAAM,CAACH,IAAI,CAACc,aAAa,CAAC,EAAE;UAC/D;UACA,MAAMC,OAAM,GAAIV,IAAI,CAACW,KAAI,IAAKX,IAAI,CAACW,KAAK,CAACd,IAAI,CAACe,IAAG,IAAKA,IAAI,CAAC5B,IAAG,KAAM,YAAY;UAEhF,IAAI,CAAC0B,OAAO,EAAE;YACZ;YACAlB,IAAI,CAAC;cAAEa,IAAI,EAAE;YAAI,CAAC;UACpB,OAAO;YACL;YACAb,IAAI,CAAC;UACP;QACF,OAAO;UACL;UACAA,IAAI,CAAC;QACP;MACF,OAAO;QACL;QACAA,IAAI,CAAC;MACP;IACF,CAAC;EACH;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}