{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, onMounted } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { ElMessage } from 'element-plus';\nimport { DataAnalysis, InfoFilled } from '@element-plus/icons-vue';\nimport adminService from '@/api/admin';\nexport default {\n  __name: 'VisualizationView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const loading = ref(true);\n    const novels = ref([]);\n    const total = ref(0);\n    const currentPage = ref(1);\n    const pageSize = ref(10);\n\n    // 获取小说列表\n    const fetchNovels = async () => {\n      loading.value = true;\n      try {\n        const response = await adminService.getAllNovels();\n        if (response && response.novels) {\n          novels.value = response.novels;\n          total.value = response.total || response.novels.length;\n        } else {\n          novels.value = [];\n          total.value = 0;\n          console.warn('获取小说列表返回格式异常');\n        }\n      } catch (error) {\n        console.error('获取小说列表失败:', error);\n        ElMessage.error('获取小说列表失败: ' + (error.message || '未知错误'));\n        novels.value = [];\n        total.value = 0;\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 刷新数据\n    const refreshData = () => {\n      fetchNovels();\n    };\n\n    // 格式化日期时间\n    const formatDateTime = dateTime => {\n      if (!dateTime) return '未知';\n      const date = new Date(dateTime);\n      return date.toLocaleString();\n    };\n\n    // 获取状态类型\n    const getStatusType = status => {\n      switch (status) {\n        case 'COMPLETED':\n          return 'success';\n        case 'PROCESSING':\n          return 'warning';\n        case 'FAILED':\n          return 'danger';\n        case 'PENDING':\n          return 'info';\n        default:\n          return 'info';\n      }\n    };\n\n    // 获取状态文本\n    const getStatusText = status => {\n      switch (status) {\n        case 'COMPLETED':\n          return '已完成';\n        case 'PROCESSING':\n          return '处理中';\n        case 'FAILED':\n          return '处理失败';\n        case 'PENDING':\n          return '等待处理';\n        default:\n          return '未知状态';\n      }\n    };\n\n    // 检查小说是否已完成分析\n    const isNovelComplete = status => {\n      return status === 'COMPLETED';\n    };\n\n    // 跳转到小说可视化分析页面\n    const showNovelVisualization = novelId => {\n      router.push(`/admin/novel/${novelId}/visualization`);\n    };\n\n    // 处理页码变化\n    const handleCurrentChange = page => {\n      currentPage.value = page;\n      fetchNovels();\n    };\n\n    // 处理每页数量变化\n    const handleSizeChange = size => {\n      pageSize.value = size;\n      fetchNovels();\n    };\n\n    // 组件挂载时获取数据\n    onMounted(() => {\n      fetchNovels();\n    });\n    const __returned__ = {\n      router,\n      loading,\n      novels,\n      total,\n      currentPage,\n      pageSize,\n      fetchNovels,\n      refreshData,\n      formatDateTime,\n      getStatusType,\n      getStatusText,\n      isNovelComplete,\n      showNovelVisualization,\n      handleCurrentChange,\n      handleSizeChange,\n      ref,\n      onMounted,\n      get useRouter() {\n        return useRouter;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get DataAnalysis() {\n        return DataAnalysis;\n      },\n      get InfoFilled() {\n        return InfoFilled;\n      },\n      get adminService() {\n        return adminService;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useRouter","ElMessage","DataAnalysis","InfoFilled","adminService","router","loading","novels","total","currentPage","pageSize","fetchNovels","value","response","getAllNovels","length","console","warn","error","message","refreshData","formatDateTime","dateTime","date","Date","toLocaleString","getStatusType","status","getStatusText","isNovelComplete","showNovelVisualization","novelId","push","handleCurrentChange","page","handleSizeChange","size"],"sources":["E:/Novel_Wonderful generation/novel-assistant/frontend/src/views/admin/VisualizationView.vue"],"sourcesContent":["<template>\r\n  <div class=\"visualization-container\">\r\n    <el-card class=\"visualization-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <h2>小说可视化分析</h2>\r\n          <el-button type=\"primary\" @click=\"refreshData\">刷新数据</el-button>\r\n        </div>\r\n      </template>\r\n      \r\n      <div v-if=\"loading\" class=\"loading-container\">\r\n        <el-skeleton :rows=\"10\" animated />\r\n      </div>\r\n      \r\n      <div v-else>\r\n        <el-alert\r\n          v-if=\"novels.length === 0\"\r\n          title=\"暂无小说数据\"\r\n          type=\"info\"\r\n          show-icon\r\n          :closable=\"false\"\r\n        >\r\n          系统中目前没有可供可视化分析的小说数据\r\n        </el-alert>\r\n        \r\n        <el-table v-else :data=\"novels\" border style=\"width: 100%\">\r\n          <el-table-column prop=\"id\" label=\"ID\" width=\"80\" />\r\n          <el-table-column prop=\"title\" label=\"小说标题\" min-width=\"200\" />\r\n          <el-table-column prop=\"author\" label=\"作者\" width=\"150\" />\r\n          <el-table-column prop=\"totalChapters\" label=\"章节数\" width=\"100\" />\r\n          <el-table-column prop=\"status\" label=\"状态\" width=\"120\">\r\n            <template #default=\"scope\">\r\n              <el-tag :type=\"getStatusType(scope.row.status)\">\r\n                {{ getStatusText(scope.row.status) }}\r\n              </el-tag>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column prop=\"createTime\" label=\"上传时间\" width=\"180\">\r\n            <template #default=\"scope\">\r\n              {{ formatDateTime(scope.row.createTime) }}\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"操作\" width=\"300\">\r\n            <template #default=\"scope\">\r\n              <el-button \r\n                type=\"primary\" \r\n                size=\"small\" \r\n                @click=\"showNovelVisualization(scope.row.id)\"\r\n                :disabled=\"!isNovelComplete(scope.row.status)\"\r\n              >\r\n                <el-icon><DataAnalysis /></el-icon>\r\n                可视化分析\r\n              </el-button>\r\n              <el-popover\r\n                placement=\"top\"\r\n                width=\"200\"\r\n                trigger=\"hover\"\r\n              >\r\n                <template #reference>\r\n                  <el-button\r\n                    size=\"small\"\r\n                    type=\"info\"\r\n                    :disabled=\"!isNovelComplete(scope.row.status)\"\r\n                  >\r\n                    <el-icon><InfoFilled /></el-icon>\r\n                    详情\r\n                  </el-button>\r\n                </template>\r\n                <div class=\"visualization-popover-content\">\r\n                  <p><b>可视化内容包括：</b></p>\r\n                  <ul>\r\n                    <li>关键词云图</li>\r\n                    <li>情节波动图</li>\r\n                    <li>人物关系网络</li>\r\n                    <li>小说结构分析</li>\r\n                    <li>章节情感分析</li>\r\n                  </ul>\r\n                </div>\r\n              </el-popover>\r\n            </template>\r\n          </el-table-column>\r\n        </el-table>\r\n        \r\n        <div class=\"pagination-container\">\r\n          <el-pagination\r\n            background\r\n            layout=\"prev, pager, next, sizes, total\"\r\n            :total=\"total\"\r\n            :page-size=\"pageSize\"\r\n            :page-sizes=\"[10, 20, 50, 100]\"\r\n            @size-change=\"handleSizeChange\"\r\n            @current-change=\"handleCurrentChange\"\r\n          />\r\n        </div>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\nimport { ElMessage } from 'element-plus'\r\nimport { DataAnalysis, InfoFilled } from '@element-plus/icons-vue'\r\nimport adminService from '@/api/admin'\r\n\r\nconst router = useRouter()\r\nconst loading = ref(true)\r\nconst novels = ref([])\r\nconst total = ref(0)\r\nconst currentPage = ref(1)\r\nconst pageSize = ref(10)\r\n\r\n// 获取小说列表\r\nconst fetchNovels = async () => {\r\n  loading.value = true\r\n  try {\r\n    const response = await adminService.getAllNovels()\r\n    if (response && response.novels) {\r\n      novels.value = response.novels\r\n      total.value = response.total || response.novels.length\r\n    } else {\r\n      novels.value = []\r\n      total.value = 0\r\n      console.warn('获取小说列表返回格式异常')\r\n    }\r\n  } catch (error) {\r\n    console.error('获取小说列表失败:', error)\r\n    ElMessage.error('获取小说列表失败: ' + (error.message || '未知错误'))\r\n    novels.value = []\r\n    total.value = 0\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\n// 刷新数据\r\nconst refreshData = () => {\r\n  fetchNovels()\r\n}\r\n\r\n// 格式化日期时间\r\nconst formatDateTime = (dateTime) => {\r\n  if (!dateTime) return '未知'\r\n  const date = new Date(dateTime)\r\n  return date.toLocaleString()\r\n}\r\n\r\n// 获取状态类型\r\nconst getStatusType = (status) => {\r\n  switch (status) {\r\n    case 'COMPLETED':\r\n      return 'success'\r\n    case 'PROCESSING':\r\n      return 'warning'\r\n    case 'FAILED':\r\n      return 'danger'\r\n    case 'PENDING':\r\n      return 'info'\r\n    default:\r\n      return 'info'\r\n  }\r\n}\r\n\r\n// 获取状态文本\r\nconst getStatusText = (status) => {\r\n  switch (status) {\r\n    case 'COMPLETED':\r\n      return '已完成'\r\n    case 'PROCESSING':\r\n      return '处理中'\r\n    case 'FAILED':\r\n      return '处理失败'\r\n    case 'PENDING':\r\n      return '等待处理'\r\n    default:\r\n      return '未知状态'\r\n  }\r\n}\r\n\r\n// 检查小说是否已完成分析\r\nconst isNovelComplete = (status) => {\r\n  return status === 'COMPLETED'\r\n}\r\n\r\n// 跳转到小说可视化分析页面\r\nconst showNovelVisualization = (novelId) => {\r\n  router.push(`/admin/novel/${novelId}/visualization`)\r\n}\r\n\r\n// 处理页码变化\r\nconst handleCurrentChange = (page) => {\r\n  currentPage.value = page\r\n  fetchNovels()\r\n}\r\n\r\n// 处理每页数量变化\r\nconst handleSizeChange = (size) => {\r\n  pageSize.value = size\r\n  fetchNovels()\r\n}\r\n\r\n// 组件挂载时获取数据\r\nonMounted(() => {\r\n  fetchNovels()\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.visualization-container {\r\n  padding: 20px;\r\n}\r\n\r\n.visualization-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.loading-container {\r\n  padding: 20px;\r\n}\r\n\r\n.pagination-container {\r\n  margin-top: 20px;\r\n  display: flex;\r\n  justify-content: center;\r\n}\r\n\r\n.visualization-popover-content ul {\r\n  padding-left: 20px;\r\n  margin-top: 5px;\r\n}\r\n\r\n.visualization-popover-content li {\r\n  margin-bottom: 5px;\r\n}\r\n</style> "],"mappings":";AAoGA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,SAAS,QAAQ,YAAY;AACtC,SAASC,SAAS,QAAQ,cAAc;AACxC,SAASC,YAAY,EAAEC,UAAU,QAAQ,yBAAyB;AAClE,OAAOC,YAAY,MAAM,aAAa;;;;;;;IAEtC,MAAMC,MAAM,GAAGL,SAAS,CAAC,CAAC;IAC1B,MAAMM,OAAO,GAAGR,GAAG,CAAC,IAAI,CAAC;IACzB,MAAMS,MAAM,GAAGT,GAAG,CAAC,EAAE,CAAC;IACtB,MAAMU,KAAK,GAAGV,GAAG,CAAC,CAAC,CAAC;IACpB,MAAMW,WAAW,GAAGX,GAAG,CAAC,CAAC,CAAC;IAC1B,MAAMY,QAAQ,GAAGZ,GAAG,CAAC,EAAE,CAAC;;IAExB;IACA,MAAMa,WAAW,GAAG,MAAAA,CAAA,KAAY;MAC9BL,OAAO,CAACM,KAAK,GAAG,IAAI;MACpB,IAAI;QACF,MAAMC,QAAQ,GAAG,MAAMT,YAAY,CAACU,YAAY,CAAC,CAAC;QAClD,IAAID,QAAQ,IAAIA,QAAQ,CAACN,MAAM,EAAE;UAC/BA,MAAM,CAACK,KAAK,GAAGC,QAAQ,CAACN,MAAM;UAC9BC,KAAK,CAACI,KAAK,GAAGC,QAAQ,CAACL,KAAK,IAAIK,QAAQ,CAACN,MAAM,CAACQ,MAAM;QACxD,CAAC,MAAM;UACLR,MAAM,CAACK,KAAK,GAAG,EAAE;UACjBJ,KAAK,CAACI,KAAK,GAAG,CAAC;UACfI,OAAO,CAACC,IAAI,CAAC,cAAc,CAAC;QAC9B;MACF,CAAC,CAAC,OAAOC,KAAK,EAAE;QACdF,OAA