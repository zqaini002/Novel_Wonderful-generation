{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { defineComponent, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRoute, useRouter } from 'vue-router';\nimport { HomeFilled, Upload, InfoFilled, User, ArrowDown, Collection, SwitchButton, Reading, Key, UserFilled, Monitor } from '@element-plus/icons-vue';\nimport { ElMessage } from 'element-plus';\nimport AuthService from '@/api/auth';\nexport default defineComponent({\n  name: 'HeaderComponent',\n  components: {\n    HomeFilled,\n    Upload,\n    InfoFilled,\n    User,\n    ArrowDown,\n    Collection,\n    SwitchButton,\n    Reading,\n    Key,\n    UserFilled,\n    Monitor\n  },\n  setup() {\n    const store = useStore();\n    const route = useRoute();\n    const router = useRouter();\n\n    // 计算当前激活的菜单项\n    const activeIndex = computed(() => route.path);\n\n    // 从store获取登录状态\n    const isLoggedIn = computed(() => store.getters['auth/isLoggedIn'] || false);\n\n    // 从store获取用户名\n    const username = computed(() => {\n      if (store.state.auth && store.state.auth.user) {\n        return store.state.auth.user.username || store.state.auth.user.name || '用户';\n      }\n      return '用户';\n    });\n\n    // 检查用户是否为管理员\n    const isAdmin = computed(() => {\n      return AuthService.isAdmin();\n    });\n\n    // 登录功能\n    const login = () => {\n      router.push('/login');\n    };\n\n    // 注册功能\n    const register = () => {\n      router.push('/register');\n    };\n\n    // 登出功能\n    const logout = () => {\n      store.dispatch('auth/logout');\n      router.push('/login');\n      ElMessage.success('已退出登录');\n    };\n\n    // 跳转到管理员仪表盘\n    const goToDashboard = () => {\n      router.push('/admin/dashboard');\n    };\n    return {\n      activeIndex,\n      isLoggedIn,\n      username,\n      isAdmin,\n      login,\n      register,\n      logout,\n      goToDashboard\n    };\n  }\n});","map":{"version":3,"names":["defineComponent","computed","useStore","useRoute","useRout