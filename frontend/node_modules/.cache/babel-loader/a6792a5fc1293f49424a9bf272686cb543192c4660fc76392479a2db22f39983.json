{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, onMounted } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { ElMessage } from 'element-plus';\nimport adminService from '@/api/admin';\nexport default {\n  __name: 'VisualizationView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const loading = ref(true);\n    const novels = ref([]);\n\n    // 获取小说列表\n    const fetchNovels = async () => {\n      loading.value = true;\n      try {\n        const response = await adminService.getAllNovels();\n        if (response && response.novels) {\n          novels.value = response.novels;\n          console.log(`加载了 ${novels.value.length} 本小说`);\n        } else {\n          novels.value = [];\n          console.warn('小说列表为空');\n        }\n      } catch (error) {\n        console.error('获取小说列表失败:', error);\n        ElMessage.error('获取小说列表失败: ' + (error.message || '未知错误'));\n        novels.value = [];\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 格式化日期\n    const formatDate = dateString => {\n      if (!dateString) return '未知';\n      const date = new Date(dateString);\n      return date.toLocaleString();\n    };\n\n    // 格式化字数\n    const formatWordCount = count => {\n      if (!count) return '0';\n      return count >= 10000 ? (count / 10000).toFixed(1) + '万' : count;\n    };\n\n    // 获取状态标签类型\n    const getStatusType = status => {\n      switch (status) {\n        case 'COMPLETED':\n          return 'success';\n        case 'PROCESSING':\n          return 'warning';\n        case 'FAILED':\n          return 'danger';\n        case 'PENDING':\n          return 'info';\n        default:\n          return '';\n      }\n    };\n\n    // 获取状态文本\n    const getStatusText = status => {\n      switch (status) {\n        case 'COMPLETED':\n          return '已完成';\n        case 'PROCESSING':\n          return '处理中';\n        case 'FAILED':\n          return '失败';\n        case 'PENDING':\n          return '等待中';\n        default:\n          return '未知';\n      }\n    };\n\n    // 跳转到小说可视化分析页面\n    const goToNovelVisualization = novelId => {\n      router.push(`/admin/novel/${novelId}/visualization`);\n    };\n\n    // 组件挂载时获取数据\n    onMounted(() => {\n      fetchNovels();\n    });\n    const __returned__ = {\n      router,\n      loading,\n      novels,\n      fetchNovels,\n      formatDate,\n      formatWordCount,\n      getStatusType,\n      getStatusText,\n      goToNovelVisualization,\n      ref,\n      onMounted,\n      get useRouter() {\n        return useRouter;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get adminService() {\n        return adminService;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useRouter","ElMessage","adminService","router","loading","novels","fetchNovels","value","response","getAllNovels","console","log","length","warn","error","message","formatDate","dateString","date","Date","toLocaleString","formatWordCount","count","toFixed","getStatusType","status","getStatusText","goToNovelVisualization","novelId","push"],"sources":["E:/Novel_Wonderful generation/novel-assistant/frontend/src/views/admin/VisualizationView.vue"],"sourcesContent":["<template>\r\n  <div class=\"visualization-container\">\r\n    <el-card class=\"visualization-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <h2>小说可视化分析</h2>\r\n          <el-button type=\"primary\" @click=\"fetchNovels\">刷新</el-button>\r\n        </div>\r\n      </template>\r\n      \r\n      <div v-if=\"loading\" class=\"loading-container\">\r\n        <el-skeleton :rows=\"10\" animated />\r\n      </div>\r\n      \r\n      <div v-else>\r\n        <el-table\r\n          :data=\"novels\"\r\n          style=\"width: 100%\"\r\n          border\r\n          stripe\r\n          v-loading=\"loading\"\r\n        >\r\n          <el-table-column label=\"ID\" prop=\"id\" width=\"80\" />\r\n          <el-table-column label=\"封面\" width=\"100\">\r\n            <template #default=\"scope\">\r\n              <el-image \r\n                v-if=\"scope.row.coverUrl\" \r\n                :src=\"scope.row.coverUrl\" \r\n                style=\"width: 60px; height: 80px\"\r\n                fit=\"cover\"\r\n                :preview-src-list=\"[scope.row.coverUrl]\"\r\n              />\r\n              <div v-else class=\"no-cover\">无封面</div>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"标题\" prop=\"title\" min-width=\"180\" show-overflow-tooltip />\r\n          <el-table-column label=\"作者\" prop=\"author\" width=\"120\" show-overflow-tooltip />\r\n          <el-table-column label=\"字数\" width=\"100\">\r\n            <template #default=\"scope\">\r\n              {{ formatWordCount(scope.row.wordCount) }}\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"章节数\" prop=\"chapterCount\" width=\"100\" />\r\n          <el-table-column label=\"上传时间\" width=\"180\">\r\n            <template #default=\"scope\">\r\n              {{ formatDate(scope.row.createdAt) }}\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"处理状态\" width=\"120\">\r\n            <template #default=\"scope\">\r\n              <el-tag :type=\"getStatusType(scope.row.status)\">\r\n                {{ getStatusText(scope.row.status) }}\r\n              </el-tag>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\r\n            <template #default=\"scope\">\r\n              <el-button \r\n                type=\"primary\" \r\n                size=\"small\" \r\n                @click=\"goToNovelVisualization(scope.row.id)\"\r\n                :disabled=\"scope.row.status !== 'COMPLETED'\"\r\n              >\r\n                可视化分析\r\n              </el-button>\r\n            </template>\r\n          </el-table-column>\r\n        </el-table>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\nimport { ElMessage } from 'element-plus'\r\nimport adminService from '@/api/admin'\r\n\r\nconst router = useRouter()\r\nconst loading = ref(true)\r\nconst novels = ref([])\r\n\r\n// 获取小说列表\r\nconst fetchNovels = async () => {\r\n  loading.value = true\r\n  try {\r\n    const response = await adminService.getAllNovels()\r\n    \r\n    if (response && response.novels) {\r\n      novels.value = response.novels\r\n      console.log(`加载了 ${novels.value.length} 本小说`)\r\n    } else {\r\n      novels.value = []\r\n      console.warn('小说列表为空')\r\n    }\r\n  } catch (error) {\r\n    console.error('获取小说列表失败:', error)\r\n    ElMessage.error('获取小说列表失败: ' + (error.message || '未知错误'))\r\n    novels.value = []\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\n// 格式化日期\r\nconst formatDate = (dateString) => {\r\n  if (!dateString) return '未知'\r\n  const date = new Date(dateString)\r\n  return date.toLocaleString()\r\n}\r\n\r\n// 格式化字数\r\nconst formatWordCount = (count) => {\r\n  if (!count) return '0'\r\n  return count >= 10000 ? (count / 10000).toFixed(1) + '万' : count\r\n}\r\n\r\n// 获取状态标签类型\r\nconst getStatusType = (status) => {\r\n  switch (status) {\r\n    case 'COMPLETED':\r\n      return 'success'\r\n    case 'PROCESSING':\r\n      return 'warning'\r\n    case 'FAILED':\r\n      return 'danger'\r\n    case 'PENDING':\r\n      return 'info'\r\n    default:\r\n      return ''\r\n  }\r\n}\r\n\r\n// 获取状态文本\r\nconst getStatusText = (status) => {\r\n  switch (status) {\r\n    case 'COMPLETED':\r\n      return '已完成'\r\n    case 'PROCESSING':\r\n      return '处理中'\r\n    case 'FAILED':\r\n      return '失败'\r\n    case 'PENDING':\r\n      return '等待中'\r\n    default:\r\n      return '未知'\r\n  }\r\n}\r\n\r\n// 跳转到小说可视化分析页面\r\nconst goToNovelVisualization = (novelId) => {\r\n  router.push(`/admin/novel/${novelId}/visualization`)\r\n}\r\n\r\n// 组件挂载时获取数据\r\nonMounted(() => {\r\n  fetchNovels()\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.visualization-container {\r\n  padding: 20px;\r\n}\r\n\r\n.visualization-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.loading-container {\r\n  padding: 20px;\r\n}\r\n\r\n.no-cover {\r\n  width: 60px;\r\n  height: 80px;\r\n  background-color: #f0f0f0;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  color: #999;\r\n  font-size: 12px;\r\n}\r\n</style> "],"mappings":";AA0EA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,SAAS,QAAQ,YAAY;AACtC,SAASC,SAAS,QAAQ,cAAc;AACxC,OAAOC,YAAY,MAAM,aAAa;;;;;;;IAEtC,MAAMC,MAAM,GAAGH,SAAS,CAAC,CAAC;IAC1B,MAAMI,OAAO,GAAGN,GAAG,CAAC,IAAI,CAAC;IACzB,MAAMO,MAAM,GAAGP,GAAG,CAAC,EAAE,CAAC;;IAEtB;IACA,MAAMQ,WAAW,GAAG,MAAAA,CAAA,KAAY;MAC9BF,OAAO,CAACG,KAAK,GAAG,IAAI;MACpB,IAAI;QACF,MAAMC,QAAQ,GAAG,MAAMN,YAAY,CAACO,YAAY,CAAC,CAAC;QAElD,IAAID,QAAQ,IAAIA,QAAQ,CAACH,MAAM,EAAE;UAC/BA,MAAM,CAACE,KAAK,GAAGC,QAAQ,CAACH,MAAM;UAC9BK,OAAO,CAACC,GAAG,CAAC,OAAON,MAAM,CAACE,KAAK,CAACK,MAAM,MAAM,CAAC;QAC/C,CAAC,MAAM;UACLP,MAAM,CAACE,KAAK,GAAG,EAAE;UACjBG,OAAO,CAACG,IAAI,CAAC,QAAQ,CAAC;QACxB;MACF,CAAC,CAAC,OAAOC,KAAK,EAAE;QACdJ,OAAO,CAACI,KAAK,CAAC,WAAW,EAAEA,KAAK,CAAC;QACjCb,SAAS,CAACa,KAAK,CAAC,YAAY,IAAIA,KAAK,CAACC,OAAO,IAAI,MAAM,CAAC,CAAC;QACzDV,MAAM,CAACE,KAAK,GAAG,EAAE;MACnB,CAAC,SAAS;QACRH,OAAO,CAACG,KAAK,GAAG,KAAK;MACvB;IACF,CAAC;;IAED;IACA,MAAMS,UAAU,GAAIC,UAAU,IAAK;MACjC,IAAI,CAACA,UAAU,EAAE,OAAO,IAAI;MAC5B,MAAMC,IAAI,GAAG,IAAIC,IAAI,CAACF,UAAU,CAAC;MACjC,OAAOC,IAAI,CAACE,cAAc,CAAC,CAAC;IAC9B,CAAC;;IAED;IACA,MAAMC,eAAe,GAAIC,KAAK,IAAK;MACjC,IAAI,CAACA,KAAK,