{"ast":null,"code":"import { ref, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { ElMessage } from 'element-plus';\nimport axios from 'axios';\nexport default {\n  name: 'LoginTestView',\n  setup() {\n    const store = useStore();\n    const publicApiResult = ref(null);\n    const userApiResult = ref(null);\n    const adminApiResult = ref(null);\n\n    // 从Vuex获取认证状态\n    const isLoggedIn = computed(() => store.getters.isLoggedIn);\n    const currentUser = computed(() => store.getters.currentUser);\n\n    // 登录\n    const handleLogin = async () => {\n      try {\n        await store.dispatch('auth/login', {\n          username: 'admin',\n          password: 'admin123'\n        });\n        ElMessage.success('登录成功');\n      } catch (error) {\n        console.error('登录失败', error);\n        ElMessage.error('登录失败: ' + (error.response?.data?.message || error.message));\n      }\n    };\n\n    // 登出\n    const handleLogout = () => {\n      store.dispatch('auth/logout');\n      ElMessage.success('已登出');\n      // 清空API测试结果\n      publicApiResult.value = null;\n      userApiResult.value = null;\n      adminApiResult.value = null;\n    };\n\n    // API测试函数\n    const testPublicApi = async () => {\n      try {\n        const response = await axios.get('/api/test/public');\n        publicApiResult.value = response.data;\n      } catch (error) {\n        publicApiResult.value = {\n          error: true,\n          message: error.response?.data?.message || error.message,\n          status: error.response?.status\n        };\n      }\n    };\n    const testUserApi = async () => {\n      try {\n        const response = await axios.get('/api/test/user');\n        userApiResult.value = response.data;\n      } catch (error) {\n        userApiResult.value = {\n          error: true,\n          message: error.response?.data?.message || error.message,\n          status: error.response?.status\n        };\n      }\n    };\n    const testAdminApi = async () => {\n      try {\n        const response = await axios.get('/api/test/admin');\n        adminApiResult.value = response.data;\n      } catch (error) {\n        adminApiResult.value = {\n          error: true,\n          message: error.response?.data?.message || error.message,\n          status: error.response?.status\n        };\n      }\n    };\n    return {\n      isLoggedIn,\n      currentUser,\n      handleLogin,\n      handleLogout,\n      testPublicApi,\n      testUserApi,\n      testAdminApi,\n      publicApiResult,\n      userApiResult,\n      adminApiResult\n    };\n  }\n};","map":{"version":3,"names":["ref","computed","useStore","ElMessage","axios","name","setup","store","publicApiResult","userApiResult","adminApiResult","isLoggedIn","getters","currentUser","handleLogin","dispatch","username","password","success","error","console","response","data","message","handleLogout","value","testPublicApi","get","status","testUserApi","testAdminApi"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\LoginTestView.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-test-container\">\r\n    <h1>API访问权限测试</h1>\r\n    \r\n    <el-card class=\"auth-status-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <span>认证状态</span>\r\n        </div>\r\n      </template>\r\n      <div class=\"auth-status\">\r\n        <p><strong>登录状态:</strong> {{ isLoggedIn ? '已登录' : '未登录' }}</p>\r\n        <p v-if=\"isLoggedIn\"><strong>用户名:</strong> {{ currentUser?.username }}</p>\r\n        <p v-if=\"isLoggedIn\"><strong>角色:</strong> {{ currentUser?.roles?.join(', ') }}</p>\r\n      </div>\r\n      <div class=\"auth-actions\">\r\n        <el-button type=\"primary\" @click=\"handleLogin\" v-if=\"!isLoggedIn\">登录</el-button>\r\n        <el-button type=\"danger\" @click=\"handleLogout\" v-else>登出</el-button>\r\n      </div>\r\n    </el-card>\r\n\r\n    <el-divider content-position=\"center\">API测试</el-divider>\r\n\r\n    <div class=\"api-test-section\">\r\n      <el-row :gutter=\"20\">\r\n        <el-col :span=\"8\">\r\n          <el-card>\r\n            <template #header>\r\n              <div class=\"card-header\">\r\n                <span>公开API (无需认证)</span>\r\n              </div>\r\n            </template>\r\n            <el-button type=\"success\" @click=\"testPublicApi\">测试公开API</el-button>\r\n            <div class=\"api-result\" v-if=\"publicApiResult\">\r\n              <pre>{{ JSON.stringify(publicApiResult, null, 2) }}</pre>\r\n            </div>\r\n          </el-card>\r\n        </el-col>\r\n        <el-col :span=\"8\">\r\n          <el-card>\r\n            <template #header>\r\n              <div class=\"card-header\">\r\n                <span>用户API (需要USER角色)</span>\r\n              </div>\r\n            </template>\r\n            <el-button type=\"warning\" @click=\"testUserApi\">测试用户API</el-button>\r\n            <div class=\"api-result\" v-if=\"userApiResult\">\r\n              <pre>{{ JSON.stringify(userApiResult, null, 2) }}</pre>\r\n            </div>\r\n          </el-card>\r\n        </el-col>\r\n        <el-col :span=\"8\">\r\n          <el-card>\r\n            <template #header>\r\n              <div class=\"card-header\">\r\n                <span>管理员API (需要ADMIN角色)</span>\r\n              </div>\r\n            </template>\r\n            <el-button type=\"danger\" @click=\"testAdminApi\">测试管理员API</el-button>\r\n            <div class=\"api-result\" v-if=\"adminApiResult\">\r\n              <pre>{{ JSON.stringify(adminApiResult, null, 2) }}</pre>\r\n            </div>\r\n          </el-card>\r\n        </el-col>\r\n      </el-row>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, computed } from 'vue';\r\nimport { useStore } from 'vuex';\r\nimport { ElMessage } from 'element-plus';\r\nimport axios from 'axios';\r\n\r\nexport default {\r\n  name: 'LoginTestView',\r\n  setup() {\r\n    const store = useStore();\r\n    const publicApiResult = ref(null);\r\n    const userApiResult = ref(null);\r\n    const adminApiResult = ref(null);\r\n\r\n    // 从Vuex获取认证状态\r\n    const isLoggedIn = computed(() => store.getters.isLoggedIn);\r\n    const currentUser = computed(() => store.getters.currentUser);\r\n\r\n    // 登录\r\n    const handleLogin = async () => {\r\n      try {\r\n        await store.dispatch('auth/login', { username: 'admin', password: 'admin123' });\r\n        ElMessage.success('登录成功');\r\n      } catch (error) {\r\n        console.error('登录失败', error);\r\n        ElMessage.error('登录失败: ' + (error.response?.data?.message || error.message));\r\n      }\r\n    };\r\n\r\n    // 登出\r\n    const handleLogout = () => {\r\n      store.dispatch('auth/logout');\r\n      ElMessage.success('已登出');\r\n      // 清空API测试结果\r\n      publicApiResult.value = null;\r\n      userApiResult.value = null;\r\n      adminApiResult.value = null;\r\n    };\r\n\r\n    // API测试函数\r\n    const testPublicApi = async () => {\r\n      try {\r\n        const response = await axios.get('/api/test/public');\r\n        publicApiResult.value = response.data;\r\n      } catch (error) {\r\n        publicApiResult.value = { \r\n          error: true, \r\n          message: error.response?.data?.message || error.message,\r\n          status: error.response?.status\r\n        };\r\n      }\r\n    };\r\n\r\n    const testUserApi = async () => {\r\n      try {\r\n        const response = await axios.get('/api/test/user');\r\n        userApiResult.value = response.data;\r\n      } catch (error) {\r\n        userApiResult.value = { \r\n          error: true, \r\n          message: error.response?.data?.message || error.message,\r\n          status: error.response?.status\r\n        };\r\n      }\r\n    };\r\n\r\n    const testAdminApi = async () => {\r\n      try {\r\n        const response = await axios.get('/api/test/admin');\r\n        adminApiResult.value = response.data;\r\n      } catch (error) {\r\n        adminApiResult.value = { \r\n          error: true, \r\n          message: error.response?.data?.message || error.message,\r\n          status: error.response?.status\r\n        };\r\n      }\r\n    };\r\n\r\n    return {\r\n      isLoggedIn,\r\n      currentUser,\r\n      handleLogin,\r\n      handleLogout,\r\n      testPublicApi,\r\n      testUserApi,\r\n      testAdminApi,\r\n      publicApiResult,\r\n      userApiResult,\r\n      adminApiResult\r\n    };\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.login-test-container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n}\r\n\r\n.auth-status-card {\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.auth-status {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.auth-actions {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n}\r\n\r\n.api-test-section {\r\n  margin-top: 20px;\r\n}\r\n\r\n.api-result {\r\n  margin-top: 15px;\r\n  padding: 10px;\r\n  background-color: #f8f8f8;\r\n  border-radius: 4px;\r\n  max-height: 200px;\r\n  overflow-y: auto;\r\n}\r\n\r\npre {\r\n  margin: 0;\r\n  white-space: pre-wrap;\r\n  word-break: break-word;\r\n}\r\n</style> "],"mappings":"AAsEA,SAASA,GAAG,EAAEC,QAAO,QAAS,KAAK;AACnC,SAASC,QAAO,QAAS,MAAM;AAC/B,SAASC,SAAQ,QAAS,cAAc;AACxC,OAAOC,KAAI,MAAO,OAAO;AAEzB,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,KAAKA,CAAA,EAAG;IACN,MAAMC,KAAI,GAAIL,QAAQ,CAAC,CAAC;IACxB,MAAMM,eAAc,GAAIR,GAAG,CAAC,IAAI,CAAC;IACjC,MAAMS,aAAY,GAAIT,GAAG,CAAC,IAAI,CAAC;IAC/B,MAAMU,cAAa,GAAIV,GAAG,CAAC,IAAI,CAAC;;IAEhC;IACA,MAAMW,UAAS,GAAIV,QAAQ,CAAC,MAAMM,KAAK,CAACK,OAAO,CAACD,UAAU,CAAC;IAC3D,MAAME,WAAU,GAAIZ,QAAQ,CAAC,MAAMM,KAAK,CAACK,OAAO,CAACC,WAAW,CAAC;;IAE7D;IACA,MAAMC,WAAU,GAAI,MAAAA,CAAA,KAAY;MAC9B,IAAI;QACF,MAAMP,KAAK,CAACQ,QAAQ,CAAC,YAAY,EAAE;UAAEC,QAAQ,EAAE,OAAO;UAAEC,QAAQ,EAAE;QAAW,CAAC,CAAC;QAC/Ed,SAAS,CAACe,OAAO,CAAC,MAAM,CAAC;MAC3B,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,MAAM,EAAEA,KAAK,CAAC;QAC5BhB,SAAS,CAACgB,KAAK,CAAC,Q