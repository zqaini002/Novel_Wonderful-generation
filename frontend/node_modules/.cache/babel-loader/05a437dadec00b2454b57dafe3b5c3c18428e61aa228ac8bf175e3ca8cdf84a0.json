{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport { ElMessage } from 'element-plus';\nimport authService from '@/api/auth';\nimport apiClient from '@/api/api';\nimport axios from 'axios';\nexport default {\n  name: 'LoginTestView',\n  setup() {\n    const loginForm = ref({\n      username: 'admin',\n      password: 'admin123'\n    });\n    const authStatus = ref(null);\n    const storedUser = ref(null);\n    const loginResponse = ref(null);\n    const error = ref(null);\n    const apiResponse = ref(null);\n    const handleLogin = async () => {\n      try {\n        error.value = null;\n        const response = await axios.post('http://localhost:8080/api/auth/signin', {\n          username: loginForm.value.username,\n          password: loginForm.value.password\n        });\n        loginResponse.value = response.data;\n\n        // 保存令牌到localStorage\n        localStorage.setItem('user', JSON.stringify(response.data));\n        ElMessage.success('登录成功');\n        loadStoredUser();\n\n        // 添加调试信息\n        console.log('登录成功，响应数据：', response.data);\n        console.log('存储的令牌：', response.data.token);\n      } catch (err) {\n        console.error('登录失败:', err);\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message;\n        ElMessage.error('登录失败');\n      }\n    };\n    const handleLogout = () => {\n      localStorage.removeItem('user');\n      ElMessage.success('已退出登录');\n      loadStoredUser();\n      loginResponse.value = null;\n    };\n    const checkAuth = async () => {\n      try {\n        error.value = null;\n        // 直接使用axios，而不是通过authService\n        const response = await axios.get('http://localhost:8080/api/test/public');\n        authStatus.value = {\n          message: '可以访问公开API',\n          response: response.data\n        };\n\n        // 检查本地存储的用户信息\n        const userStr = localStorage.getItem('user');\n        if (userStr) {\n          const user = JSON.parse(userStr);\n          authStatus.value.user = {\n            username: user.username,\n            roles: user.roles || []\n          };\n          authStatus.value.isLoggedIn = true;\n        } else {\n          authStatus.value.isLoggedIn = false;\n        }\n      } catch (err) {\n        console.error('检查API可用性失败:', err);\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message;\n        ElMessage.error('后端服务可能未启动');\n      }\n    };\n    const loadStoredUser = () => {\n      const user = localStorage.getItem('user');\n      if (user) {\n        try {\n          storedUser.value = JSON.parse(user);\n        } catch (err) {\n          console.error('解析存储的用户信息失败:', err);\n        }\n      } else {\n        storedUser.value = null;\n      }\n    };\n\n    // 测试公开API\n    const testPublicApi = async () => {\n      try {\n        error.value = null;\n        const response = await axios.get('http://localhost:8080/api/test/public');\n        apiResponse.value = response.data;\n        ElMessage.success('测试公开API成功');\n      } catch (err) {\n        console.error('测试公开API失败:', err);\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message;\n        ElMessage.error('测试公开API失败');\n      }\n    };\n\n    // 测试用户API\n    const testUserApi = async () => {\n      try {\n        error.value = null;\n        const userStr = localStorage.getItem('user');\n        const headers = {};\n        if (userStr) {\n          const user = JSON.parse(userStr);\n          if (user.token) {\n            headers.Authorization = `Bearer ${user.token}`;\n          }\n        }\n        const response = await axios.get('http://localhost:8080/api/test/user', {\n          headers\n        });\n        apiResponse.value = response.data;\n        ElMessage.success('测试用户API成功');\n      } catch (err) {\n        console.error('测试用户API失败:', err);\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message;\n        ElMessage.error('测试用户API失败');\n      }\n    };\n\n    // 测试管理员API\n    const testAdminApi = async () => {\n      try {\n        error.value = null;\n        const userStr = localStorage.getItem('user');\n        const headers = {};\n        if (userStr) {\n          const user = JSON.parse(userStr);\n          if (user.token) {\n            headers.Authorization = `Bearer ${user.token}`;\n          }\n        }\n        const response = await axios.get('http://localhost:8080/api/test/admin', {\n          headers\n        });\n        apiResponse.value = response.data;\n        ElMessage.success('测试管理员API成功');\n      } catch (err) {\n        console.error('测试管理员API失败:', err);\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message;\n        ElMessage.error('测试管理员API失败');\n      }\n    };\n    onMounted(() => {\n      loadStoredUser();\n      checkAuth();\n    });\n    return {\n      loginForm,\n      authStatus,\n      storedUser,\n      loginResponse,\n      error,\n      apiResponse,\n      handleLogin,\n      handleLogout,\n      checkAuth,\n      testPublicApi,\n      testUserApi,\n      testAdminApi\n    };\n  }\n};","map":{"version":3,"names":["ref","onMounted","ElMessage","authService","apiClient","axios","name","setup","loginForm","username","password","authStatus","storedUser","loginResponse","error","apiResponse","handleLogin","value","response","post","data","localStorage","setItem","JSON","stringify","success","loadStoredUser","console","log","token","err","message","handleLogout","removeItem","checkAuth","get","userStr","getItem","user","parse","roles","isLoggedIn","testPublicApi","testUserApi","headers","Authorization","testAdminApi"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\LoginTestView.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-test-container\">\r\n    <h1>登录测试</h1>\r\n    \r\n    <div class=\"card\">\r\n      <h2>登录</h2>\r\n      <el-form :model=\"loginForm\" label-width=\"100px\">\r\n        <el-form-item label=\"用户名\">\r\n          <el-input v-model=\"loginForm.username\" placeholder=\"请输入用户名\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"密码\">\r\n          <el-input v-model=\"loginForm.password\" type=\"password\" placeholder=\"请输入密码\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleLogin\">登录</el-button>\r\n          <el-button @click=\"handleLogout\">退出</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>API测试</h2>\r\n      <el-row :gutter=\"10\">\r\n        <el-col :span=\"8\">\r\n          <el-button @click=\"testPublicApi\">测试公开API</el-button>\r\n        </el-col>\r\n        <el-col :span=\"8\">\r\n          <el-button @click=\"testUserApi\">测试用户API</el-button>\r\n        </el-col>\r\n        <el-col :span=\"8\">\r\n          <el-button @click=\"testAdminApi\">测试管理员API</el-button>\r\n        </el-col>\r\n      </el-row>\r\n      <pre v-if=\"apiResponse\" class=\"mt-10\">{{ JSON.stringify(apiResponse, null, 2) }}</pre>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>API状态</h2>\r\n      <el-button @click=\"checkAuth\">检查API可用性</el-button>\r\n      <pre v-if=\"authStatus\">{{ JSON.stringify(authStatus, null, 2) }}</pre>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>当前存储的用户信息</h2>\r\n      <pre v-if=\"storedUser\">{{ JSON.stringify(storedUser, null, 2) }}</pre>\r\n      <p v-else>没有存储的用户信息</p>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>登录响应</h2>\r\n      <pre v-if=\"loginResponse\">{{ JSON.stringify(loginResponse, null, 2) }}</pre>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>错误信息</h2>\r\n      <pre v-if=\"error\" class=\"error\">{{ error }}</pre>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted } from 'vue'\r\nimport { ElMessage } from 'element-plus'\r\nimport authService from '@/api/auth'\r\nimport apiClient from '@/api/api'\r\nimport axios from 'axios'\r\n\r\nexport default {\r\n  name: 'LoginTestView',\r\n  setup() {\r\n    const loginForm = ref({\r\n      username: 'admin',\r\n      password: 'admin123'\r\n    })\r\n    \r\n    const authStatus = ref(null)\r\n    const storedUser = ref(null)\r\n    const loginResponse = ref(null)\r\n    const error = ref(null)\r\n    const apiResponse = ref(null)\r\n    \r\n    const handleLogin = async () => {\r\n      try {\r\n        error.value = null\r\n        const response = await axios.post('http://localhost:8080/api/auth/signin', {\r\n          username: loginForm.value.username,\r\n          password: loginForm.value.password\r\n        })\r\n        \r\n        loginResponse.value = response.data\r\n        \r\n        // 保存令牌到localStorage\r\n        localStorage.setItem('user', JSON.stringify(response.data))\r\n        \r\n        ElMessage.success('登录成功')\r\n        loadStoredUser()\r\n        \r\n        // 添加调试信息\r\n        console.log('登录成功，响应数据：', response.data)\r\n        console.log('存储的令牌：', response.data.token)\r\n      } catch (err) {\r\n        console.error('登录失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('登录失败')\r\n      }\r\n    }\r\n    \r\n    const handleLogout = () => {\r\n      localStorage.removeItem('user')\r\n      ElMessage.success('已退出登录')\r\n      loadStoredUser()\r\n      loginResponse.value = null\r\n    }\r\n    \r\n    const checkAuth = async () => {\r\n      try {\r\n        error.value = null\r\n        // 直接使用axios，而不是通过authService\r\n        const response = await axios.get('http://localhost:8080/api/test/public')\r\n        authStatus.value = {\r\n          message: '可以访问公开API',\r\n          response: response.data\r\n        }\r\n        \r\n        // 检查本地存储的用户信息\r\n        const userStr = localStorage.getItem('user')\r\n        if (userStr) {\r\n          const user = JSON.parse(userStr)\r\n          authStatus.value.user = {\r\n            username: user.username,\r\n            roles: user.roles || []\r\n          }\r\n          authStatus.value.isLoggedIn = true\r\n        } else {\r\n          authStatus.value.isLoggedIn = false\r\n        }\r\n        \r\n      } catch (err) {\r\n        console.error('检查API可用性失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('后端服务可能未启动')\r\n      }\r\n    }\r\n    \r\n    const loadStoredUser = () => {\r\n      const user = localStorage.getItem('user')\r\n      if (user) {\r\n        try {\r\n          storedUser.value = JSON.parse(user)\r\n        } catch (err) {\r\n          console.error('解析存储的用户信息失败:', err)\r\n        }\r\n      } else {\r\n        storedUser.value = null\r\n      }\r\n    }\r\n    \r\n    // 测试公开API\r\n    const testPublicApi = async () => {\r\n      try {\r\n        error.value = null\r\n        const response = await axios.get('http://localhost:8080/api/test/public')\r\n        apiResponse.value = response.data\r\n        ElMessage.success('测试公开API成功')\r\n      } catch (err) {\r\n        console.error('测试公开API失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('测试公开API失败')\r\n      }\r\n    }\r\n    \r\n    // 测试用户API\r\n    const testUserApi = async () => {\r\n      try {\r\n        error.value = null\r\n        const userStr = localStorage.getItem('user')\r\n        const headers = {}\r\n        \r\n        if (userStr) {\r\n          const user = JSON.parse(userStr)\r\n          if (user.token) {\r\n            headers.Authorization = `Bearer ${user.token}`\r\n          }\r\n        }\r\n        \r\n        const response = await axios.get('http://localhost:8080/api/test/user', { headers })\r\n        apiResponse.value = response.data\r\n        ElMessage.success('测试用户API成功')\r\n      } catch (err) {\r\n        console.error('测试用户API失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('测试用户API失败')\r\n      }\r\n    }\r\n    \r\n    // 测试管理员API\r\n    const testAdminApi = async () => {\r\n      try {\r\n        error.value = null\r\n        const userStr = localStorage.getItem('user')\r\n        const headers = {}\r\n        \r\n        if (userStr) {\r\n          const user = JSON.parse(userStr)\r\n          if (user.token) {\r\n            headers.Authorization = `Bearer ${user.token}`\r\n          }\r\n        }\r\n        \r\n        const response = await axios.get('http://localhost:8080/api/test/admin', { headers })\r\n        apiResponse.value = response.data\r\n        ElMessage.success('测试管理员API成功')\r\n      } catch (err) {\r\n        console.error('测试管理员API失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('测试管理员API失败')\r\n      }\r\n    }\r\n    \r\n    onMounted(() => {\r\n      loadStoredUser()\r\n      checkAuth()\r\n    })\r\n    \r\n    return {\r\n      loginForm,\r\n      authStatus,\r\n      storedUser,\r\n      loginResponse,\r\n      error,\r\n      apiResponse,\r\n      handleLogin,\r\n      handleLogout,\r\n      checkAuth,\r\n      testPublicApi,\r\n      testUserApi,\r\n      testAdminApi\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.login-test-container {\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n}\r\n\r\n.card {\r\n  background-color: #fff;\r\n  border-radius: 4px;\r\n  box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.1);\r\n  padding: 20px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\npre {\r\n  background-color: #f5f5f5;\r\n  padding: 10px;\r\n  border-radius: 4px;\r\n  overflow: auto;\r\n  max-height: 300px;\r\n}\r\n\r\n.error {\r\n  background-color: #fef0f0;\r\n  color: #f56c6c;\r\n}\r\n\r\n.mt-10 {\r\n  