r: _withCtx(() => _cache[12] || (_cache[12] = [_createElementVNode(\"div\", {\n          class: \"card-header\"\n        }, [_createElementVNode(\"span\", null, \"管理员API (需要ADMIN角色)\")], -1 /* HOISTED */)])),\n        default: _withCtx(() => [_createVNode(_component_el_button, {\n          type: \"danger\",\n          onClick: _ctx.testAdminApi\n        }, {\n          default: _withCtx(() => _cache[13] || (_cache[13] = [_createTextVNode(\"测试管理员API\")])),\n          _: 1 /* STABLE */\n        }, 8 /* PROPS */, [\"onClick\"]), _ctx.adminApiResult ? (_openBlock(), _createElementBlock(\"div\", _hoisted_10, [_createElementVNode(\"pre\", null, _toDisplayString(JSON.stringify(_ctx.adminApiResult, null, 2)), 1 /* TEXT */)])) : _createCommentVNode(\"v-if\", true)]),\n        _: 1 /* STABLE */\n      })]),\n      _: 1 /* STABLE */\n    })]),\n    _: 1 /* STABLE */\n  })])]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","_createElementVNode","_createVNode","_component_el_card","header","_withCtx","_cache","default","_hoisted_2","_createTextVNode","_toDisplayString","_ctx","isLoggedIn","_hoisted_3","currentUser","username","_createCommentVNode","_hoisted_4","roles","join","_hoisted_5","tokenExpiryFormatted","_hoisted_6","_createBlock","_component_el_button","type","onClick","handleLogin","_","handleLogout","_component_el_divider","_hoisted_7","_component_el_row","gutter","_component_el_col","span","testPublicApi","publicApiResult","_hoisted_8","JSON","stringify","testUserApi","userApiResult","_hoisted_9","testAdminApi","adminApiResult","_hoisted_10"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\LoginTestView.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-test-container\">\r\n    <h1>API访问权限测试</h1>\r\n    \r\n    <el-card class=\"auth-status-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <span>认证状态</span>\r\n        </div>\r\n      </template>\r\n      <div class=\"auth-status\">\r\n        <p><strong>登录状态:</strong> {{ isLoggedIn ? '已登录' : '未登录' }}</p>\r\n        <p v-if=\"isLoggedIn\"><strong>用户名:</strong> {{ currentUser.username }}</p>\r\n        <p v-if=\"isLoggedIn\"><strong>角色:</strong> {{ currentUser.roles.join(', ') }}</p>\r\n        <p v-if=\"isLoggedIn\"><strong>Token过期时间:</strong> {{ tokenExpiryFormatted }}</p>\r\n      </div>\r\n      <div class=\"auth-actions\">\r\n        <el-button type=\"primary\" @click=\"handleLogin\" v-if=\"!isLoggedIn\">登录</el-button>\r\n        <el-button type=\"danger\" @click=\"handleLogout\" v-else>登出</el-button>\r\n      </div>\r\n    </el-card>\r\n\r\n    <el-divider content-position=\"center\">API测试</el-divider>\r\n\r\n    <div class=\"api-test-section\">\r\n      <el-row :gutter=\"20\">\r\n        <el-col :span=\"8\">\r\n          <el-card>\r\n            <template #header>\r\n              <div class=\"card-header\">\r\n                <span>公开API (无需认证)</span>\r\n              </div>\r\n            </template>\r\n            <el-button type=\"success\" @click=\"testPublicApi\">测试公开API</el-button>\r\n            <div class=\"api-result\" v-if=\"publicApiResult\">\r\n              <pre>{{ JSON.stringify(publicApiResult, null, 2) }}</pre>\r\n            </div>\r\n          </el-card>\r\n        </el-col>\r\n        <el-col :span=\"8\">\r\n          <el-card>\r\n            <template #header>\r\n              <div class=\"card-header\">\r\n                <span>用户API (需要USER角色)</span>\r\n              </div>\r\n            </template>\r\n            <el-button type=\"warning\" @click=\"testUserApi\">测试用户API</el-button>\r\n            <div class=\"api-result\" v-if=\"userApiResult\">\r\n              <pre>{{ JSON.stringify(userApiResult, null, 2) }}</pre>\r\n            </div>\r\n          </el-card>\r\n        </el-col>\r\n        <el-col :span=\"8\">\r\n          <el-card>\r\n            <template #header>\r\n              <div class=\"card-header\">\r\n                <span>管理员API (需要ADMIN角色)</span>\r\n              </div>\r\n            </template>\r\n            <el-button type=\"danger\" @click=\"testAdminApi\">测试管理员API</el-button>\r\n            <div class=\"api-result\" v-if=\"adminApiResult\">\r\n              <pre>{{ JSON.stringify(adminApiResult, null, 2) }}</pre>\r\n            </div>\r\n          </el-card>\r\n        </el-col>\r\n      </el-row>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue';\r\nimport { ElMessage } from 'element-plus';\r\nimport axios from 'axios';\r\nimport authService from '@/services/auth.service';\r\n\r\n// 响应式状态\r\nconst isLoggedIn = ref(false);\r\nconst currentUser = ref({});\r\nconst publicApiResult = ref(null);\r\nconst userApiResult = ref(null);\r\nconst adminApiResult = ref(null);\r\n\r\n// Token过期时间计算\r\nconst tokenExpiryFormatted = computed(() => {\r\n  if (!currentUser.value.tokenExpiry) return 'N/A';\r\n  return new Date(currentUser.value.tokenExpiry).toLocaleString();\r\n});\r\n\r\n// 检查登录状态\r\nconst checkLoginStatus = () => {\r\n  isLoggedIn.value = authService.isLoggedIn();\r\n  if (isLoggedIn.value) {\r\n    currentUser.value = authService.getCurrentUser();\r\n    <div class=\"card\">\r\n      <h2>登录</h2>\r\n      <el-form :model=\"loginForm\" label-width=\"100px\">\r\n        <el-form-item label=\"用户名\">\r\n          <el-input v-model=\"loginForm.username\" placeholder=\"请输入用户名\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"密码\">\r\n          <el-input v-model=\"loginForm.password\" type=\"password\" placeholder=\"请输入密码\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleLogin\">登录</el-button>\r\n          <el-button @click=\"handleLogout\">退出</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>API测试</h2>\r\n      <el-row :gutter=\"10\">\r\n        <el-col :span=\"8\">\r\n          <el-button @click=\"testPublicApi\">测试公开API</el-button>\r\n        </el-col>\r\n        <el-col :span=\"8\">\r\n          <el-button @click=\"testUserApi\">测试用户API</el-button>\r\n        </el-col>\r\n        <el-col :span=\"8\">\r\n          <el-button @click=\"testAdminApi\">测试管理员API</el-button>\r\n        </el-col>\r\n      </el-row>\r\n      <pre v-if=\"apiResponse\" class=\"mt-10\">{{ JSON.stringify(apiResponse, null, 2) }}</pre>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>API状态</h2>\r\n      <el-button @click=\"checkAuth\">检查API可用性</el-button>\r\n      <pre v-if=\"authStatus\">{{ JSON.stringify(authStatus, null, 2) }}</pre>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>当前存储的用户信息</h2>\r\n      <pre v-if=\"storedUser\">{{ JSON.stringify(storedUser, null, 2) }}</pre>\r\n      <p v-else>没有存储的用户信息</p>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>登录响应</h2>\r\n      <pre v-if=\"loginResponse\">{{ JSON.stringify(loginResponse, null, 2) }}</pre>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>错误信息</h2>\r\n      <pre v-if=\"error\" class=\"error\">{{ error }}</pre>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted } from 'vue'\r\nimport { ElMessage } from 'element-plus'\r\nimport authService from '@/api/auth'\r\nimport apiClient from '@/api/api'\r\nimport axios from 'axios'\r\n\r\nexport default {\r\n  name: 'LoginTestView',\r\n  setup() {\r\n    const loginForm = ref({\r\n      username: 'admin',\r\n      password: 'admin123'\r\n    })\r\n    \r\n    const authStatus = ref(null)\r\n    const storedUser = ref(null)\r\n    const loginResponse = ref(null)\r\n    const error = ref(null)\r\n    const apiResponse = ref(null)\r\n    \r\n    const handleLogin = async () => {\r\n      try {\r\n        error.value = null\r\n        const response = await axios.post('http://localhost:8080/api/auth/signin', {\r\n          username: loginForm.value.username,\r\n          password: loginForm.value.password\r\n        })\r\n        \r\n        loginResponse.value = response.data\r\n        \r\n        // 保存令牌到localStorage\r\n        localStorage.setItem('user', JSON.stringify(response.data))\r\n        \r\n        ElMessage.success('登录成功')\r\n        loadStoredUser()\r\n        \r\n        // 添加调试信息\r\n        console.log('登录成功，响应数据：', response.data)\r\n        console.log('存储的令牌：', response.data.token)\r\n      } catch (err) {\r\n        console.error('登录失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('登录失败')\r\n      }\r\n    }\r\n    \r\n    const handleLogout = () => {\r\n      localStorage.removeItem('user')\r\n      ElMessage.success('已退出登录')\r\n      loadStoredUser()\r\n      loginResponse.value = null\r\n    }\r\n    \r\n    const checkAuth = async () => {\r\n      try {\r\n        error.value = null\r\n        // 直接使用axios，而不是通过authService\r\n        const response = await axios.get('http://localhost:8080/api/test/public')\r\n        authStatus.value = {\r\n          message: '可以访问公开API',\r\n          response: response.data\r\n        }\r\n        \r\n        // 检查本地存储的用户信息\r\n        const userStr = localStorage.getItem('user')\r\n        if (userStr) {\r\n          const user = JSON.parse(userStr)\r\n          authStatus.value.user = {\r\n            username: user.username,\r\n            roles: user.roles || []\r\n          }\r\n          authStatus.value.isLoggedIn = true\r\n        } else {\r\n          authStatus.value.isLoggedIn = false\r\n        }\r\n        \r\n      } catch (err) {\r\n        console.error('检查API可用性失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('后端服务可能未启动')\r\n      }\r\n    }\r\n    \r\n    const loadStoredUser = () => {\r\n      const user = localStorage.getItem('user')\r\n      if (user) {\r\n        try {\r\n          storedUser.value = JSON.parse(user)\r\n        } catch (err) {\r\n          console.error('解析存储的用户信息失败:', err)\r\n        }\r\n      } else {\r\n        storedUser.value = null\r\n      }\r\n    }\r\n    \r\n    // 测试公开API\r\n    const testPublicApi = async () => {\r\n      try {\r\n        error.value = null\r\n        const response = await axios.get('http://localhost:8080/api/test/public')\r\n        apiResponse.value = response.data\r\n        ElMessage.success('测试公开API成功')\r\n      } catch (err) {\r\n        console.error('测试公开API失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('测试公开API失败')\r\n      }\r\n    }\r\n    \r\n    // 测试用户API\r\n    const testUserApi = async () => {\r\n      try {\r\n        error.value = null\r\n        const userStr = localStorage.getItem('user')\r\n        const headers = {}\r\n        \r\n        if (userStr) {\r\n          const user = JSON.parse(userStr)\r\n          if (user.token) {\r\n            headers.Authorization = `Bearer ${user.token}`\r\n          }\r\n        }\r\n        \r\n        const response = await axios.get('http://localhost:8080/api/test/user', { headers })\r\n        apiResponse.value = response.data\r\n        ElMessage.success('测试用户API成功')\r\n      } catch (err) {\r\n        console.error('测试用户API失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('测试用户API失败')\r\n      }\r\n    }\r\n    \r\n    // 测试管理员API\r\n    const testAdminApi = async () => {\r\n      try {\r\n        error.value = null\r\n        const userStr = localStorage.getItem('user')\r\n        const headers = {}\r\n        \r\n        if (userStr) {\r\n          const user = JSON.parse(userStr)\r\n          if (user.token) {\r\n            headers.Authorization = `Bearer ${user.token}`\r\n          }\r\n        }\r\n        \r\n        const response = await axios.get('http://localhost:8080/api/test/admin', { headers })\r\n        apiResponse.value = response.data\r\n        ElMessage.success('测试管理员API成功')\r\n      } catch (err) {\r\n        console.error('测试管理员API失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('测试管理员API失败')\r\n      }\r\n    }\r\n    \r\n    onMounted(() => {\r\n      loadStoredUser()\r\n      checkAuth()\r\n    })\r\n    \r\n    return {\r\n      loginForm,\r\n      authStatus,\r\n      storedUser,\r\n      loginResponse,\r\n      error,\r\n      apiResponse,\r\n      handleLogin,\r\n      handleLogout,\r\n      checkAuth,\r\n      testPublicApi,\r\n      testUserApi,\r\n      testAdminApi\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.login-test-container {\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n}\r\n\r\n.card {\r\n  background-color: #fff;\r\n  border-radius: 4px;\r\n  box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.1);\r\n  padding: 20px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\npre {\r\n  background-color: #f5f5f5;\r\n  padding: 10px;\r\n  border-radius: 4px;\r\n  overflow: auto;\r\n  max-height: 300px;\r\n}\r\n\r\n.error {\r\n  background-color: #fef0f0;\r\n  color: #f56c6c;\r\n}\r\n\r\n.mt-10 {\r\n  margin-top: 10px;\r\n}\r\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAsB;;EASxBA,KAAK,EAAC;AAAa;;EAV9BC,GAAA;AAAA;;EAAAA,GAAA;AAAA;;EAAAA,GAAA;AAAA;;EAgBWD,KAAK,EAAC;AAAc;;EAQtBA,KAAK,EAAC;AAAkB;;EAxBjCC,GAAA;EAkCiBD,KAAK,EAAC;;;EAlCvBC,GAAA;EA+CiBD,KAAK,EAAC;;;EA/CvBC,GAAA;EA4DiBD,KAAK,EAAC;;;;;;;;uBA3DrBE,mBAAA,CAkEM,OAlENC,UAkEM,G,4BAjEJC,mBAAA,CAAkB,YAAd,WAAS,sBAEbC,YAAA,CAgBUC,kBAAA;IAhBDN,KAAK,EAAC;EAAkB;IACpBO,MAAM,EAAAC,QAAA,CACf,MAEMC,MAAA,QAAAA,MAAA,OAFNL,mBAAA,CAEM;MAFDJ,KAAK,EAAC;IAAa,IACtBI,mBAAA,CAAiB,cAAX,MAAI,E;IAPpBM,OAAA,EAAAF,QAAA,CAUM,MAKM,CALNJ,mBAAA,CAKM,OALNO,UAKM,GAJJP,mBAAA,CAA8D,Y,0BAA3DA,mBAAA,CAAsB,gBAAd,OAAK,sBAXxBQ,gBAAA,CAWiC,GAAC,GAAAC,gBAAA,CAAGC,IAA