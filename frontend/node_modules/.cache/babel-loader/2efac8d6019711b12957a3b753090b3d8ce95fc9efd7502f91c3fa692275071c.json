     type: \"danger\",\n          onClick: _withModifiers($event => $setup.deleteNovel(scope.row), [\"stop\"])\n        }, {\n          default: _withCtx(() => _cache[5] || (_cache[5] = [_createTextVNode(\" 删除 \")])),\n          _: 2 /* DYNAMIC */\n        }, 1032 /* PROPS, DYNAMIC_SLOTS */, [\"onClick\"])]),\n        _: 1 /* STABLE */\n      })]),\n      _: 1 /* STABLE */\n    }, 8 /* PROPS */, [\"data\"]), _createElementVNode(\"div\", _hoisted_6, [_createVNode(_component_el_pagination, {\n      background: \"\",\n      layout: \"prev, pager, next, sizes, total\",\n      total: $setup.totalNovels,\n      \"page-size\": $setup.pageSize,\n      \"page-sizes\": [10, 20, 50, 100],\n      onSizeChange: $setup.handleSizeChange,\n      onCurrentChange: $setup.handleCurrentChange\n    }, null, 8 /* PROPS */, [\"total\", \"page-size\"])])]))]),\n    _: 1 /* STABLE */\n  })]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","_createVNode","_component_el_card","header","_withCtx","_createElementVNode","_hoisted_2","_hoisted_3","_component_el_input","modelValue","$setup","searchQuery","_cache","$event","placeholder","clearable","onClear","filterNovels","onInput","style","prefix","_component_el_icon","default","_","_component_el_button","type","onClick","refreshNovels","_createTextVNode","loading","_hoisted_4","_component_el_skeleton","rows","animated","_hoisted_5","_component_el_table","data","displayNovels","border","stripe","onRowClick","handleRowClick","_component_el_table_column","prop","label","width","scope","_component_el_tag","getStatusType","row","status","_toDisplayString","formatStatus","chapterCount","formatWordCount","wordCount","formatDate","createdAt","fixed","size","_withModifiers","viewNovelDetail","id","reprocessNovel","disabled","deleteNovel","_hoisted_6","_component_el_pagination","background","layout","total","totalNovels","pageSize","onSizeChange","handleSizeChange","onCurrentChange","handleCurrentChange"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\admin\\NovelManagementView.vue"],"sourcesContent":["<template>\n  <div class=\"novel-management-container\">\n    <el-card class=\"novel-management-card\">\n      <template #header>\n        <div class=\"card-header\">\n          <h2>小说管理</h2>\n          <div class=\"header-actions\">\n            <el-input\n              v-model=\"searchQuery\"\n              placeholder=\"搜索小说标题或作者\"\n              clearable\n              @clear=\"filterNovels\"\n              @input=\"filterNovels\"\n              style=\"width: 300px; margin-right: 10px;\"\n            >\n              <template #prefix>\n                <el-icon><Search /></el-icon>\n              </template>\n            </el-input>\n            <el-button type=\"primary\" @click=\"refreshNovels\">刷新</el-button>\n          </div>\n        </div>\n      </template>\n      \n      <div v-if=\"loading\" class=\"loading-container\">\n        <el-skeleton :rows=\"10\" animated />\n      </div>\n      \n      <div v-else class=\"novel-table-container\">\n        <el-table\n          :data=\"displayNovels\"\n          style=\"width: 100%\"\n          border\n          stripe\n          highlight-current-row\n          @row-click=\"handleRowClick\"\n        >\n          <el-table-column prop=\"id\" label=\"ID\" width=\"80\" />\n          <el-table-column prop=\"title\" label=\"标题\" width=\"200\" />\n          <el-table-column prop=\"author\" label=\"作者\" width=\"150\" />\n          <el-table-column label=\"状态\" width=\"120\">\n            <template #default=\"scope\">\n              <el-tag :type=\"getStatusType(scope.row.status)\">\n                {{ formatStatus(scope.row.status) }}\n              </el-tag>\n            </template>\n          </el-table-column>\n          <el-table-column label=\"章节数\" width=\"100\">\n            <template #default=\"scope\">\n              {{ scope.row.chapterCount || 0 }}\n            </template>\n          </el-table-column>\n          <el-table-column label=\"字数\" width=\"120\">\n            <template #default=\"scope\">\n              {{ formatWordCount(scope.row.wordCount) }}\n            </template>\n          </el-table-column>\n          <el-table-column label=\"上传时间\" width=\"180\">\n            <template #default=\"scope\">\n              {{ formatDate(scope.row.createdAt) }}\n            </template>\n          </el-table-column>\n          <el-table-column label=\"操作\" width=\"220\" fixed=\"right\">\n            <template #default=\"scope\">\n              <el-button\n                size=\"small\"\n                type=\"primary\"\n                @click.stop=\"viewNovelDetail(scope.row.id)\"\n              >\n                查看\n              </el-button>\n              <el-button\n                size=\"small\"\n                type=\"warning\"\n                @click.stop=\"reprocessNovel(scope.row)\"\n                :disabled=\"scope.row.status === 'PROCESSING'\"\n              >\n                重新处理\n              </el-button>\n              <el-button\n                size=\"small\"\n                type=\"danger\"\n                @click.stop=\"deleteNovel(scope.row)\"\n              >\n                删除\n              </el-button>\n            </template>\n          </el-table-column>\n        </el-table>\n        \n        <div class=\"pagination-container\">\n          <el-pagination\n            background\n            layout=\"prev, pager, next, sizes, total\"\n            :total=\"totalNovels\"\n            :page-size=\"pageSize\"\n            :page-sizes=\"[10, 20, 50, 100]\"\n            @size-change=\"handleSizeChange\"\n            @current-change=\"handleCurrentChange\"\n          />\n        </div>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted } from 'vue'\nimport { useRouter } from 'vue-router'\nimport { ElMessage, ElMessageBox } from 'element-plus'\nimport { Search } from '@element-plus/icons-vue'\nimport adminService from '@/api/admin'\n\nconst router = useRouter()\nconst loading = ref(true)\nconst novels = ref([])\nconst searchQuery = ref('')\nconst currentPage = ref(1)\nconst pageSize = ref(20)\nconst totalNovels = ref(0)\n\n// 获取所有小说列表\nconst fetchNovels = async () => {\n  loading.value = true\n  try {\n    const response = await adminService.getAllNovels()\n    \n    // 打印API响应以便调试\n    console.log('获取小说列表响应:', response);\n    \n    // apiClient已经提取了response.data，直接检查novels字段\n    if (response && response.novels) {\n      novels.value = response.novels\n      totalNovels.value = response.total || novels.value.length\n    } else if (Array.isArray(response)) {\n      // 如果response本身就是数组，直接使用\n      novels.value = response\n      totalNovels.value = response.length\n    } else {\n      console.warn('小说列表API返回格式异常:', response)\n      // 使用模拟数据\n      useMockData()\n    }\n  } catch (error) {\n    console.error('获取小说列表失败:', error)\n    ElMessage.error('获取小说列表失败: ' + (error.message || '未知错误'))\n    // 在请求失败时使用模拟数据\n    useMockData()\n  } finally {\n    loading.value = false\n  }\n}\n\n// 使用模拟数据\nconst useMockData = () => {\n  const mockNovels = [\n    {\n      id: 1,\n      title: '三体',\n      author: '刘慈欣',\n      status: 'COMPLETED',\n      chapterCount: 40,\n      totalChapters: 40,\n      wordCount: 350000,\n      createdAt: new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString(),\n      updatedAt: new Date().toISOString()\n    },\n    {\n      id: 2,\n      title: '红楼梦',\n      author: '曹雪芹',\n      status: 'COMPLETED',\n      chapterCount: 120,\n      totalChapters: 120,\n      wordCount: 750000,\n      createdAt: new Date(Date.now() - 25 * 24 * 60 * 60 * 1000).toISOString(),\n      updatedAt: new Date().toISOString()\n    },\n    {\n      id: 3,\n      title: '哈利·波特与魔法石',\n      author: 'J.K.罗琳',\n      status: 'COMPLETED',\n      chapterCount: 17,\n      totalChapters: 17,\n      wordCount: 120000,\n      createdAt: new Date(Date.now() - 15 * 24 * 60 * 60 * 1000).toISOString(),\n      updatedAt: new Date().toISOString()\n    },\n    {\n      id: 4,\n      title: '西游记',\n      author: '吴承恩',\n      status: 'PROCESSING',\n      chapterCount: 50,\n      totalChapters: 100,\n      wordCount: 250000,\n      createdAt: new Date(Date.now() - 5 * 24 * 60 * 60 * 1000).toISOString(),\n      updatedAt: new Date().toISOString()\n    }\n  ]\n  \n  novels.value = mockNovels\n  totalNovels.value = mockNovels.length\n  console.log('使用模拟数据:', mockNovels)\n}\n\n// 刷新小说列表\nconst refreshNovels = () => {\n  fetchNovels()\n}\n\n// 过滤小说列表\nconst filterNovels = () => {\n  // 这里简单实现前端过滤，实际项目中可能需要发送请求到后端进行过滤\n  const query = searchQuery.value.toLowerCase().trim()\n  if (!query) {\n    return novels.value\n  }\n  \n  return novels.value.filter(novel => \n    novel.title.toLowerCase().includes(query) ||\n    (novel.author && novel.author.toLowerCase().includes(query))\n  )\n}\n\n// 计算属性：根据搜索条件显示小说\nconst displayNovels = computed(() => {\n  const query = searchQuery.value.toLowerCase().trim()\n  if (!query) {\n    return novels.value\n  }\n  \n  return novels.value.filter(novel => \n    novel.title.toLowerCase().includes(query) ||\n    (novel.author && novel.author.toLowerCase().includes(query))\n  )\n})\n\n// 格式化日期\nconst formatDate = (dateString) => {\n  if (!dateString) return '未知'\n  try {\n    const date = new Date(dateString)\n    if (isNaN(date.getTime())) {\n      // 如果日期无效，返回当前时间的格式化字符串\n      return new Date().toLocaleString()\n    }\n    return date.toLocaleString()\n  } catch (e) {\n    console.warn('日期格式化错误:', e, dateString)\n    return new Date().toLocaleString() // 返回当前时间作为后备\n  }\n}\n\n// 格式化状态\nconst formatStatus = (status) => {\n  switch (status) {\n    case 'PROCESSING':\n      return '处理中'\n    case 'COMPLETED':\n      return '已完成'\n    case 'FAILED':\n      return '处理失败'\n    case 'QUEUED':\n      return '等待处理'\n    default:\n      return status\n  }\n}\n\n// 获取状态对应的类型\nconst getStatusType = (status) => {\n  switch (status) {\n    case 'PROCESSING':\n      return 'warning'\n    case 'COMPLETED':\n      return 'success'\n    case 'FAILED':\n      return 'danger'\n    case 'QUEUED':\n      return 'info'\n    default:\n      return 'info'\n  }\n}\n\n// 格式化字数\nconst formatWordCount = (count) => {\n  if (!count) return '0'\n  if (count < 10000) {\n    return count.toString()\n  }\n  return (count / 10000).toFixed(2) + '万'\n}\n\n// 查看小说详情\nconst viewNovelDetail = (id) => {\n  router.push(`/novel/${id}`)\n}\n\n// 重新处理小说\nconst reprocessNovel = (novel) => {\n  ElMessageBox.confirm(\n    `确定要重新处理小说\"${novel.title}\"吗？`,\n    '确认操作',\n    {\n      confirmButtonText: '确定',\n      cancelButtonText: '取消',\n      type: 'warning'\n    }\n  )\n  .then(() => {\n    ElMessage.success('已发送重新处理请求')\n    // 实际项目中这里应该调用API来重新处理小说\n  })\n  .catch(() => {})\n}\n\n// 删除小说\nconst deleteNovel = (novel) => {\n  ElMessageBox.confirm(\n    `确定要删除小说\"${novel.title}\"吗？此操作不可恢复！`,\n    '危险操作',\n    {\n      confirmButtonText: '确定删除',\n      cancelButtonText: '取消',\n      type: 'error'\n    }\n  )\n  .then(async () => {\n    try {\n      await adminService.deleteNovel(novel.id)\n      ElMessage.success('小说删除成功')\n      fetchNovels() // 刷新列表\n    } catch (error) {\n      console.error('删除小说失败:', error)\n      ElMessage.error('删除小说失败')\n    }\n  })\n  .catch(() => {})\n}\n\n// 处理行点击\nconst handleRowClick = (row) => {\n  viewNovelDetail(row.id)\n}\n\n// 处理每页数量变化\nconst handleSizeChange = (size) => {\n  pageSize.value = size\n  // 这里需要根据实际情况重新获取数据\n}\n\n// 处理页码变化\nconst handleCurrentChange = (page) => {\n  currentPage.value = page\n  // 这里需要根据实际情况重新获取数据\n}\n\n// 组件挂载时获取数据\nonMounted(() => {\n  fetchNovels()\n})\n</script>\n\n<style scoped>\n.novel-management-container {\n  padding: 20px;\n}\n\n.novel-management-card {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.loading-container {\n  padding: 20px;\n}\n\n.novel-table-container {\n  overflow-x: auto;\n}\n\n.pagination-container {\n  margin-top: 20px;\n  display: flex;\n  justify-content: center;\n}\n</style> \n "],"mappings":";;EACOA,KAAK,EAAC;AAA4B;;EAG5BA,KAAK,EAAC;AAAa;;EAEjBA,KAAK,EAAC;AAAgB;;EANrCC,GAAA;EAwB0BD,KAAK,EAAC;;;EAxBhCC,GAAA;EA4BkBD,KAAK,EAAC;;;EA8DXA,KAAK,EAAC;AAAsB;;;;;;;;;;;uBAzFvCE,mBAAA,CAsGM,OAtGNC,UAsGM,GArGJC,YAAA,CAoGUC,kBAAA;IApGDL,KAAK,EAAC;EAAuB;IACzBM,MAAM,EAAAC,QAAA,CACf,MAiBM,CAjBNC,mBAAA,CAiBM,OAjBNC,UAiBM,G,0BAhBJD,mBAAA,CAAa,YAAT,MAAI,sBACRA,mBAAA,CAcM,OAdNE,UAcM,GAbJN,YAAA,CAWWO,mBAAA;MAlBvBC,UAAA,EAQuBC,MAAA,CAAAC,WAAW;MARlC,uBAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAQuBH,MAAA,CAAAC,WAAW,GAAAE,MAAA;MACpBC,WAAW,EAAC,WAAW;MACvBC,SAAS,EAAT,EAAS;MACRC,OAAK,EAAEN,MAAA,CAAAO,YAAY;MACnBC,OAAK,EAAER,MAAA,CAAAO,YAAY;MACpBE,KAAyC,EAAzC;QAAA;QAAA;MAAA;;MAEWC,MAAM,EAAAhB,QAAA,CACf,MAA6B,CAA7BH,YAAA,CAA6BoB,kBAAA;QAhB7CC,OAAA,EAAAlB,QAAA,CAgByB,MAAU,CAAVH,YAAA,CAAUS,MAAA,Y;QAhBnCa,CAAA;;MAAAA,CAAA;uCAmBYtB,YAAA,CAA+DuB,oBAAA;MAApDC,IAAI,EAAC,SAAS;MAAEC,OAAK,EAAEhB,MAAA,CAAAiB;;MAnB9CL,OAAA,EAAAlB,QAAA,CAmB6D,MAAEQ,MAAA,QAAAA,MAAA,OAnB/DgB,gBAAA,CAmB6D,IAAE,E;MAnB/DL,CAAA;;IAAAD,OAAA,EAAAlB,QAAA,CAwBM,MAEM,CAFKM,MAAA,CAAAmB,OAAO,I,cAAlB9B,mBAAA,CAEM,OAFN+B,UAEM,GADJ7B,YAAA,CAAmC8B,sBAAA;MAArBC,IAAI,EAAE,EAAE;MAAEC,QAAQ,EAAR;2BAG1BlC,mBAAA,CAyEM,OAzENmC,UAyEM,GAxEJjC,YAAA,CA2DWkC,mBAAA;MA1DRC,IAAI,EAAE1B,MAAA,CAAA2B,aAAa;MACpBlB,KAAmB,EAAnB;QAAA;MAAA,CAAmB;MACnBmB,MAAM,EAAN,EAAM;MACNC,MAAM,EAAN,EAAM;MACN,uBAAqB,EAArB,EAAqB;MACpBC,UAAS,EAAE9B,MAAA,CAAA+B;;MAnCtBnB,OAAA,EAAAlB,QAAA,CAqCU,MAAmD,CAAnDH,YAAA,CAAmDyC,0BAAA;QAAlCC,IAAI,EAAC,IAAI;QAACC,KAAK,EAAC,IAAI;QAACC,KAAK,EAAC;UAC5C5C,YAAA,CAAuDyC,0BAAA;QAAtCC,IAAI,EAAC,OAAO;QAACC,KAAK,EAAC,IAAI;QAACC,KAAK,EAAC;UAC/C5C,YAAA,CAAwDyC,0BAAA;QAAvCC,IAAI,EAAC,QAAQ;QAACC,KAAK,EAAC,IAAI;QAACC,KAAK,EAAC;UAChD5C,YAAA,CAMkByC,0BAAA;QANDE,KAAK,EAAC,IAAI;QAACC,KAAK,EAAC;;QACrBvB,OAAO,EAAAlB,QAAA,CAGP0C,KAHc,KACvB7C,YAAA,CAES8C,iBAAA;UAFAtB,IAAI,EAAEf,MAAA,CAAAsC,aAAa,CAACF,