sted_3","_toDisplayString","statusText","processingStatus","_hoisted_4","_hoisted_5","currentChapter","totalChapters","_hoisted_6","estimatedTime","_createCommentVNode","_hoisted_7","_component_el_alert","title","type","description","_component_el_button","onClick","retry","_createTextVNode","_","_hoisted_8","viewResults","backToHome"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\AnalyzeView.vue"],"sourcesContent":["<template>\r\n  <div class=\"analyze-container\">\r\n    <el-card class=\"analyze-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <h2>小说处理中</h2>\r\n        </div>\r\n      </template>\r\n      \r\n      <div class=\"progress-info\">\r\n        <el-progress :percentage=\"percentage\" :status=\"progressStatus\"></el-progress>\r\n        <p class=\"status-text\">{{ statusText }}</p>\r\n        \r\n        <div class=\"details-container\" v-if=\"processingStatus !== 'FAILED'\">\r\n          <div class=\"detail-item\">\r\n            <h4>处理章节</h4>\r\n            <p>{{ currentChapter }} / {{ totalChapters }}</p>\r\n          </div>\r\n          <div class=\"detail-item\">\r\n            <h4>预计完成时间</h4>\r\n            <p>{{ estimatedTime }}</p>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"error-container\" v-if=\"processingStatus === 'FAILED'\">\r\n          <el-alert\r\n            title=\"处理失败\"\r\n            type=\"error\"\r\n            description=\"小说处理过程中出现错误，请重试或联系客服。\"\r\n            show-icon\r\n          >\r\n          </el-alert>\r\n          <el-button type=\"primary\" @click=\"retry\" class=\"retry-btn\">重新尝试</el-button>\r\n        </div>\r\n      </div>\r\n      \r\n      <div class=\"action-buttons\" v-if=\"processingStatus === 'COMPLETED'\">\r\n        <el-button type=\"primary\" @click=\"viewResults\">查看分析结果</el-button>\r\n        <el-button @click=\"backToHome\">返回首页</el-button>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, computed, onMounted, onBeforeUnmount } from 'vue'\r\nimport { useStore } from 'vuex'\r\nimport { useRouter } from 'vue-router'\r\n\r\nexport default {\r\n  name: 'AnalyzeView',\r\n  setup() {\r\n    const store = useStore()\r\n    const router = useRouter()\r\n    \r\n    // 模拟处理状态相关变量\r\n    const processingStatus = computed(() => store.state.processingStatus || 'PROCESSING')\r\n    const percentage = computed(() => store.getters.processingPercentage)\r\n    const currentChapter = ref(0)\r\n    const totalChapters = ref(100)\r\n    const estimatedTime = ref('约5分钟')\r\n    \r\n    // 根据处理状态显示不同的状态文本\r\n    const statusText = computed(() => {\r\n      switch (processingStatus.value) {\r\n        case 'UPLOADING': return '正在上传小说文件...'\r\n        case 'PROCESSING': return '正在分析小说内容...'\r\n        case 'COMPLETED': return '分析完成！'\r\n        case 'FAILED': return '处理失败'\r\n        default: return '准备中...'\r\n      }\r\n    })\r\n    \r\n    // 进度条状态\r\n    const progressStatus = computed(() => {\r\n      if (processingStatus.value === 'COMPLETED') return 'success'\r\n      if (processingStatus.value === 'FAILED') return 'exception'\r\n      return ''\r\n    })\r\n    \r\n    // 模拟进度更新\r\n    let interval = null\r\n    \r\n    onMounted(() => {\r\n      if (processingStatus.value === 'PROCESSING') {\r\n        // 模拟章节处理进度\r\n        currentChapter.value = 0\r\n        interval = setInterval(() => {\r\n          if (currentChapter.value < totalChapters.value) {\r\n            currentChapter.value += 1\r\n            \r\n            // 模拟完成\r\n            if (currentChapter.value >= totalChapters.value) {\r\n              store.commit('SET_PROCESSING_STATUS', 'COMPLETED')\r\n              clearInterval(interval)\r\n            }\r\n          }\r\n        }, 100)\r\n      }\r\n    })\r\n    \r\n    onBeforeUnmount(() => {\r\n      if (interval) {\r\n        clearInterval(interval)\r\n      }\r\n    })\r\n    \r\n    // 查看结果\r\n    const viewResults = () => {\r\n      router.push({ name: 'novel-detail', params: { id: 3 } })\r\n    }\r\n    \r\n    // 返回首页\r\n    const backToHome = () => {\r\n      router.push({ name: 'home' })\r\n    }\r\n    \r\n    // 重试\r\n    const retry = () => {\r\n      store.commit('SET_PROCESSING_STATUS', 'PROCESSING')\r\n      currentChapter.value = 0\r\n      \r\n      // 重启模拟进度\r\n      interval = setInterval(() => {\r\n        if (currentChapter.value < totalChapters.value) {\r\n          currentChapter.value += 1\r\n          \r\n          if (currentChapter.value >= totalChapters.value) {\r\n            store.commit('SET_PROCESSING_STATUS', 'COMPLETED')\r\n            clearInterval(interval)\r\n          }\r\n        }\r\n      }, 100)\r\n    }\r\n    \r\n    return {\r\n      processingStatus,\r\n      percentage,\r\n      currentChapter,\r\n      totalChapters,\r\n      estimatedTime,\r\n      statusText,\r\n      progressStatus,\r\n      viewResults,\r\n      backToHome,\r\n      retry\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.analyze-container {\r\n  max-width: 800px;\r\n  margin: 40px auto;\r\n}\r\n\r\n.analyze-card {\r\n  border-radius: 8px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.progress-info {\r\n  padding: 20px;\r\n}\r\n\r\n.status-text {\r\n  text-align: center;\r\n  font-size: 16px;\r\n  margin: 20px 0;\r\n  color: #606266;\r\n}\r\n\r\n.details-container {\r\n  display: flex;\r\n  justify-content: space-around;\r\n  margin: 30px 0;\r\n}\r\n\r\n.detail-item {\r\n  text-align: center;\r\n}\r\n\r\n.detail-item h4 {\r\n  margin-bottom: 8px;\r\n  color: #909399;\r\n}\r\n\r\n.error-container {\r\n  margin: 20px 0;\r\n}\r\n\r\n.retry-btn {\r\n  margin-top: 20px;\r\n  width: 100%;\r\n}\r\n\r\n.action-buttons {\r\n  display: flex;\r\n  justify-content: center;\r\n  gap: 20px;\r\n  margin-top: 20px;\r\n}\r\n</style> "],"mappings":";;EACOA,KAAK,EAAC;A