{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, onMounted } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { ElMessage } from 'element-plus';\nimport { DataAnalysis, InfoFilled } from '@element-plus/icons-vue';\nimport adminService from '@/api/admin';\nexport default {\n  __name: 'VisualizationView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const loading = ref(true);\n    const novels = ref([]);\n    const total = ref(0);\n    const currentPage = ref(1);\n    const pageSize = ref(10);\n\n    // 获取小说列表\n    const fetchNovels = async () => {\n      loading.value = true;\n      try {\n        const response = await adminService.getAllNovels();\n        if (response && response.novels) {\n          novels.value = response.novels;\n          total.value = response.total || response.novels.length;\n        } else {\n          novels.value = [];\n          total.value = 0;\n          console.warn('获取小说列表返回格式异常');\n        }\n      } catch (error) {\n        console.error('获取小说列表失败:', error);\n        ElMessage.error('获取小说列表失败: ' + (error.message || '未知错误'));\n        novels.value = [];\n        total.value = 0;\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 刷新数据\n    const refreshData = () => {\n      fetchNovels();\n    };\n\n    // 格式化日期时间\n    const formatDateTime = dateTime => {\n      if (!dateTime) return '未知';\n      const date = new Date(dateTime);\n      return date.toLocaleString();\n    };\n\n    // 获取状态类型\n    const getStatusType = status => {\n      switch (status) {\n        case 'COMPLETED':\n          return 'success';\n        case 'PROCESSING':\n          return 'warning';\n        case 'FAILED':\n          return 'danger';\n        case 'PENDING':\n          return 'info';\n        default:\n          return 'info';\n      }\n    };\n\n    // 获取状态文本\n    const getStatusText = status => {\n      switch (status) {\n        case 'COMPLETED':\n          return '已完成';\n        case 'PROCESSING':\n          return '处理中';\n        case 'FAILED':\n          return '处理失败';\n        case 'PENDING':\n          return '等待处理';\n        default:\n          return '未知状态';\n      }\n    };\n\n    // 检查小说是否已完成分析\n    const isNovelComplete = status => {\n      return status === 'COMPLETED';\n    };\n\n    // 跳转到小说可视化分析页面\n    const showNovelVisualization = novelId => {\n      router.push(`/admin/novel/${novelId}/visualization`);\n    };\n\n    // 处理页码变化\n    const handleCurrentChange = page => {\n      currentPage.value = page;\n      fetchNovels();\n    };\n\n    // 处理每页数量变化\n    const handleSizeChange = size => {\n      pageSize.value = size;\n      fetchNovels();\n    };\n\n    // 组件挂载时获取数据\n    onMounted(() => {\n      fetchNovels();\n    });\n    const __returned__ = {\n      router,\n      loading,\n      novels,\n      total,\n      currentPage,\n      pageSize,\n      fetchNovels,\n      refreshData,\n      formatDateTime,\n      getStatusType,\n      getStatusText,\n      isNovelComplete,\n      showNovelVisualization,\n      handleCurrentChange,\n      handleSizeChange,\n      ref,\n      onMounted,\n      get useRouter() {\n        return useRouter;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get DataAnalysis() {\n        return DataAnalysis;\n      },\n      get InfoFilled() {\n        return InfoFilled;\n      },\n      get adminService() {\n        return adminService;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useRouter","ElMessage","DataAnalysis","InfoFilled","adminService","router","loading","novels","total","currentPage","pageSize","fetchNovels","value","response","getAllNovels","length","console","warn","error","message","refreshData","formatDateTime","dateTime","date","Date","toLocaleString","getStatusType","status","getStatusText","isNovelComplete","showNovelVisualization","novelId","push","handleCurrentChange","page","handleSizeChange","size"],"sources":["E:/Novel_Wonderful generation/novel-assistant/frontend/src/views/admin/VisualizationView.vue"],"sourcesContent":["<template>\n  <div class=\"visualization-container\">\n    <el-card class=\"visualization-card\">\n      <template #header>\n        <div class=\"card-header\">\n          <h2>小说可视化分析</h2>\n          <el-button type=\"primary\" @click=\"refreshData\">刷新数据</el-button>\n        </div>\n      </template>\n      \n      <div v-if=\"loading\" class=\"loading-container\">\n        <el-skeleton :rows=\"10\" animated />\n      </div>\n      \n      <div v-else>\n        <el-alert\n          v-if=\"novels.length === 0\"\n          title=\"暂无小说数据\"\n          type=\"info\"\n          show-icon\n          :closable=\"false\"\n        >\n          系统中目前没有可供可视化分析的小说数据\n        </el-alert>\n        \n        <el-table v-else :data=\"novels\" border style=\"width: 100%\">\n          <el-table-column prop=\"id\" label=\"ID\" width=\"80\" />\n          <el-table-column prop=\"title\" label=\"小说标题\" min-width=\"200\" />\n          <el-table-column prop=\"author\" label=\"作者\" width=\"150\" />\n          <el-table-column prop=\"totalChapters\" label=\"章节数\" width=\"100\" />\n          <el-table-column prop=\"status\" label=\"状态\" width=\"120\">\n            <template #default=\"scope\">\n              <el-tag :type=\"getStatusType(scope.row.status)\">\n                {{ getStatusText(scope.row.status) }}\n              </el-tag>\n            </template>\n          </el-table-column>\n          <el-table-column prop=\"createTime\" label=\"上传时间\" width=\"180\">\n            <template #default=\"scope\">\n              {{ formatDateTime(scope.row.createTime) }}\n            </template>\n          </el-table-column>\n          <el-table-column label=\"操作\" width=\"300\">\n            <template #default=\"scope\">\n              <el-button \n                type=\"primary\" \n                size=\"small\" \n                @click=\"showNovelVisualization(scope.row.id)\"\n                :disabled=\"!isNovelComplete(scope.row.status)\"\n              >\n                <el-icon><DataAnalysis /></el-icon>\n                可视化分析\n              </el-button>\n              <el-popover\n                placement=\"top\"\n                width=\"200\"\n                trigger=\"hover\"\n              >\n                <template #reference>\n                  <el-button\n                    size=\"small\"\n                    type=\"info\"\n                    :disabled=\"!isNovelComplete(scope.row.status)\"\n                  >\n                    <el-icon><InfoFilled /></el-icon>\n                    详情\n                  </el-button>\n                </template>\n                <div class=\"visualization-popover-content\">\n                  <p><b>可视化内容包括：</b></p>\n                  <ul>\n                    <li>关键词云图</li>\n                    <li>情节波动图</li>\n                    <li>人物关系网络</li>\n                    <li>小说结构分析</li>\n                    <li>章节情感分析</li>\n                  </ul>\n                </div>\n              </el-popover>\n            </template>\n          </el-table-column>\n        </el-table>\n        \n        <div class=\"pagination-container\">\n          <el-pagination\n            background\n            layout=\"prev, pager, next, sizes, total\"\n            :total=\"total\"\n            :page-size=\"pageSize\"\n            :page-sizes=\"[10, 20, 50, 100]\"\n            @size-change=\"handleSizeChange\"\n            @current-change=\"handleCurrentChange\"\n          />\n        </div>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from 'vue'\nimport { useRouter } from 'vue-router'\nimport { ElMessage } from 'element-plus'\nimport { DataAnalysis, InfoFilled } from '@element-plus/icons-vue'\nimport adminService from '@/api/admin'\n\nconst router = useRouter()\nconst loading = ref(true)\nconst novels = ref([])\nconst total = ref(0)\nconst currentPage = ref(1)\nconst pageSize = ref(10)\n\n// 获取小说列表\nconst fetchNovels = async () => {\n  loading.value = true\n  try {\n    const response = await adminService.getAllNovels()\n    if (response && response.novels) {\n      novels.value = response.novels\n      total.value = response.total || response.novels.length\n    } else {\n      novels.value = []\n      total.value = 0\n      console.warn('获取小说列表返回格式异常')\n    }\n  } catch (error) {\n    console.error('获取小说列表失败:', error)\n    ElMessage.error('获取小说列表失败: ' + (error.message || '未知错误'))\n    novels.value = []\n    total.value = 0\n  } finally {\n    loading.value = false\n  }\n}\n\n// 刷新数据\nconst refreshData = () => {\n  fetchNovels()\n}\n\n// 格式化日期时间\nconst formatDateTime = (dateTime) => {\n  if (!dateTime) return '未知'\n  const date = new Date(dateTime)\n  return date.toLocaleString()\n}\n\n// 获取状态类型\nconst getStatusType = (status) => {\n  switch (status) {\n    case 'COMPLETED':\n      return 'success'\n    case 'PROCESSING':\n      return 'warning'\n    case 'FAILED':\n      return 'danger'\n    case 'PENDING':\n      return 'info'\n    default:\n      return 'info'\n  }\n}\n\n// 获取状态文本\nconst getStatusText = (status) => {\n  switch (status) {\n    case 'COMPLETED':\n      return '已完成'\n    case 'PROCESSING':\n      return '处理中'\n    case 'FAILED':\n      return '处理失败'\n    case 'PENDING':\n      return '等待处理'\n    default:\n      return '未知状态'\n  }\n}\n\n// 检查小说是否已完成分析\nconst isNovelComplete = (status) => {\n  return status === 'COMPLETED'\n}\n\n// 跳转到小说可视化分析页面\nconst showNovelVisualization = (novelId) => {\n  router.push(`/admin/novel/${novelId}/visualization`)\n}\n\n// 处理页码变化\nconst handleCurrentChange = (page) => {\n  currentPage.value = page\n  fetchNovels()\n}\n\n// 处理每页数量变化\nconst handleSizeChange = (size) => {\n  pageSize.value = size\n  fetchNovels()\n}\n\n// 组件挂载时获取数据\nonMounted(() => {\n  fetchNovels()\n})\n</script>\n\n<style scoped>\n.visualization-container {\n  padding: 20px;\n}\n\n.visualization-card {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.loading-container {\n  padding: 20px;\n}\n\n.pagination-container {\n  margin-top: 20px;\n  display: flex;\n  justify-content: center;\n}\n\n.visualization-popover-content ul {\n  padding-left: 20px;\n  margin-top: 5px;\n}\n\n.visualization-popover-content li {\n  margin-bottom: 5px;\n}\n</style> "],"mappings":";AAoGA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAI;AACnC,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,SAAS,QAAQ,cAAa;AACvC,SAASC,YAAY,EAAEC,UAAU,QAAQ,yBAAwB;AACjE,OAAOC,YAAY,MAAM,aAAY;;;;;;;IAErC,MAAMC,MAAM,GAAGL,SAAS,CAAC;IACzB,MAAMM,OAAO,GAAGR,GAAG,CAAC,IAAI;IACxB,MAAMS,MAAM,GAAGT,GAAG,CAAC,EAAE;IACrB,MAAMU,KAAK,GAAGV,GAAG,CAAC,CAAC;IACnB,MAAMW,WAAW,GAAGX,GAAG,CAAC,CAAC;IACzB,MAAMY,QAAQ,GAAGZ,GAAG,CAAC,EAAE;;IAEvB;IACA,MAAMa,WAAW,GAAG,MAAAA,CAAA,KAAY;MAC9BL,OAAO,CAACM,KAAK,GAAG,IAAG;MACnB,IAAI;QACF,MAAMC,QAAQ,GAAG,MAAMT,YAAY,CAACU,YAAY,CAAC;QACjD,IAAID,QAAQ,IAAIA,QAAQ,CAACN,MAAM,EAAE;UAC/BA,MAAM,CAACK,KAAK,GAAGC,QAAQ,CAACN,MAAK;UAC7BC,KAAK,CAACI,KAAK,GAAGC,QAAQ,CAACL,KAAK,IAAIK,QAAQ,CAACN,MAAM,CAACQ,MAAK;QACvD,CAAC,MAAM;UACLR,MAAM,CAACK,KAAK,GAAG,EAAC;UAChBJ,KAAK,CAACI,KAAK,GAAG;UACdI,OAAO,CAACC,IAAI,CAAC,cAAc;QAC7B;MACF,CAAC,CAAC,OAAOC,KAAK,EAAE;QACdF,OAAO,CAACE,KAAK,CAAC,WAAW,EAAEA,KAAK;QAChCjB,SAAS,CAACiB,KAAK,CAAC,YAAY,IAAIA,KAAK,CAACC,OAAO,IAAI,MAAM,CAAC;QACxDZ,MAAM,CAACK,KAAK,GAAG,EAAC;QAChBJ,KAAK,CAACI,KAAK,GAAG;MAChB,CAAC,SAAS;QACRN,OAAO,CAACM,KAAK,GAAG,KAAI;MACtB;IACF;;IAEA;IACA,MAAMQ,WAAW,GAAGA,CAAA,KAAM;MACxBT,WAAW,CAAC;IACd;;IAEA;IACA,MAAMU,cAAc,GAAIC,QAAQ,IAAK;MACnC,IAAI,CAACA,QAAQ,EAAE,OAAO,IAAG;MACzB,MAAMC,IAAI,GAAG,IAAIC,IAAI,CAACF,QAAQ;MAC9B,OAAOC,IAAI,CAACE,cAAc,CAAC;IAC7B;;IAEA;IACA,MAAMC,aAAa,GAAIC,MAAM,IAAK;MAChC,QAAQA,MAAM;QACZ,KAAK,WAAW;UACd,OAAO,SAA