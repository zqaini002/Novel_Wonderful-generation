80px;\r\n  margin: 0 auto;\r\n  width: 100%;\r\n}\r\n\r\n.el-footer {\r\n  padding: 30px 0;\r\n  background-color: #fff;\r\n  border-top: 1px solid var(--border-color);\r\n}\r\n\r\n/* 卡片样式优化 */\r\n.el-card {\r\n  border-radius: var(--radius);\r\n  border: none;\r\n  box-shadow: var(--shadow-sm) !important;\r\n  transition: box-shadow 0.3s;\r\n  overflow: hidden;\r\n}\r\n\r\n.el-card:hover {\r\n  box-shadow: var(--shadow-md) !important;\r\n}\r\n\r\n/* 按钮样式优化 */\r\n.el-button {\r\n  border-radius: 4px;\r\n  font-weight: 500;\r\n}\r\n\r\n.el-button--primary {\r\n  background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);\r\n  border: none;\r\n}\r\n\r\n/* 动画效果 */\r\n.fade-enter-active,\r\n.fade-leave-active {\r\n  transition: opacity 0.3s ease;\r\n}\r\n\r\n.fade-enter-from,\r\n.fade-leave-to {\r\n  opacity: 0;\r\n}\r\n\r\n/* 移动设备适配 */\r\n@media (max-width: 768px) {\r\n  .el-main {\r\n    padding: 16px;\r\n  }\r\n}\r\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAe;;;;;;;;;;uBAA1BC,mBAAA,CAkBM,OAlBNC,UAkBM,GAjBJC,YAAA,CAgBqBC,6BAAA;IAhBAC,MAAM,EAAEC,IAAA,CAAAC;EAAI;IAFrCC,OAAA,EAAAC,QAAA,CAGM,MAce,CAdfN,YAAA,CAceO,uBAAA;MAjBrBF,OAAA,EAAAC,QAAA,CAIQ,MAEY,CAFZN,YAAA,CAEYQ,oBAAA;QANpBH,OAAA,EAAAC,QAAA,CAKU,MAAoB,CAApBN,YAAA,CAAoBS,2BAAA,E;QAL9BC,CAAA;UAOQV,YAAA,CAMUW,kBAAA;QAblBN,OAAA,EAAAC,QAAA,CAQU,MAIc,CAJdN,YAAA,CAIcY,sBAAA;UAZxBP,OAAA,EAAAC,QAAA,CASY,CAEa;YAHQO;UAAS,OAC9Bb,YAAA,CAEac,WAAA;YAFDC,IAAI,EAAC,MAAM;YAACC,IAAI,EAAC;;YATzCX,OAAA,EAAAC,QAAA,CAUc,MAA6B,E,cAA7BW,YAAA,CAA6BC,wBAV3C,CAU8BL,SAAS,I;YAVvCH,CAAA;;UAAAA,CAAA;;QAAAA,CAAA;UAcQV,YAAA,CAEYmB,oBAAA;QAhBpBd,OAAA,EAAAC,QAAA,CAeU,MAAoB,CAApBN,YAAA,CAAoBoB,2BAAA,E;QAf9BV,CAAA;;MAAAA,CAAA;;IAAAA,CAAA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}