{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport { ElMessage } from 'element-plus';\nimport authService from '@/api/auth';\nexport default {\n  name: 'LoginTestView',\n  setup() {\n    const loginForm = ref({\n      username: 'admin',\n      password: 'admin123'\n    });\n    const authStatus = ref(null);\n    const storedUser = ref(null);\n    const loginResponse = ref(null);\n    const error = ref(null);\n    const handleLogin = async () => {\n      try {\n        error.value = null;\n        const response = await authService.login(loginForm.value.username, loginForm.value.password);\n        loginResponse.value = response.data;\n        ElMessage.success('登录成功');\n        loadStoredUser();\n      } catch (err) {\n        console.error('登录失败:', err);\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message;\n        ElMessage.error('登录失败');\n      }\n    };\n    const checkAuth = async () => {\n      try {\n        error.value = null;\n        const response = await authService.checkAuth();\n        authStatus.value = response.data;\n      } catch (err) {\n        console.error('检查认证状态失败:', err);\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message;\n        ElMessage.error('检查认证状态失败');\n      }\n    };\n    const loadStoredUser = () => {\n      const user = localStorage.getItem('user');\n      if (user) {\n        try {\n          storedUser.value = JSON.parse(user);\n        } catch (err) {\n          console.error('解析存储的用户信息失败:', err);\n        }\n      } else {\n        storedUser.value = null;\n      }\n    };\n    onMounted(() => {\n      loadStoredUser();\n      checkAuth();\n    });\n    return {\n      loginForm,\n      authStatus,\n      storedUser,\n      loginResponse,\n      error,\n      handleLogin,\n      checkAuth\n    };\n  }\n};","map":{"version":3,"names":["ref","onMounted","ElMessage","authService","name","setup","loginForm","username","password","authStatus","storedUser","loginResponse","error","handleLogin","value","response","login","data","success","loadStoredUser","err","console","JSON","stringify","message","checkAuth","user","localStorage","getItem","parse"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\LoginTestView.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-test-container\">\r\n    <h1>登录测试</h1>\r\n    \r\n    <div class=\"card\">\r\n      <h2>登录</h2>\r\n      <el-form :model=\"loginForm\" label-width=\"100px\">\r\n        <el-form-item label=\"用户名\">\r\n          <el-input v-model=\"loginForm.username\" placeholder=\"请输入用户名\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"密码\">\r\n          <el-input v-model=\"loginForm.password\" type=\"password\" placeholder=\"请输入密码\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleLogin\">登录</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>认证状态</h2>\r\n      <el-button @click=\"checkAuth\">检查认证状态</el-button>\r\n      <pre v-if=\"authStatus\">{{ JSON.stringify(authStatus, null, 2) }}</pre>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>当前存储的用户信息</h2>\r\n      <pre v-if=\"storedUser\">{{ JSON.stringify(storedUser, null, 2) }}</pre>\r\n      <p v-else>没有存储的用户信息</p>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>登录响应</h2>\r\n      <pre v-if=\"loginResponse\">{{ JSON.stringify(loginResponse, null, 2) }}</pre>\r\n    </div>\r\n    \r\n    <div class=\"card\">\r\n      <h2>错误信息</h2>\r\n      <pre v-if=\"error\" class=\"error\">{{ error }}</pre>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted } from 'vue'\r\nimport { ElMessage } from 'element-plus'\r\nimport authService from '@/api/auth'\r\n\r\nexport default {\r\n  name: 'LoginTestView',\r\n  setup() {\r\n    const loginForm = ref({\r\n      username: 'admin',\r\n      password: 'admin123'\r\n    })\r\n    \r\n    const authStatus = ref(null)\r\n    const storedUser = ref(null)\r\n    const loginResponse = ref(null)\r\n    const error = ref(null)\r\n    \r\n    const handleLogin = async () => {\r\n      try {\r\n        error.value = null\r\n        const response = await authService.login(loginForm.value.username, loginForm.value.password)\r\n        loginResponse.value = response.data\r\n        ElMessage.success('登录成功')\r\n        loadStoredUser()\r\n      } catch (err) {\r\n        console.error('登录失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('登录失败')\r\n      }\r\n    }\r\n    \r\n    const checkAuth = async () => {\r\n      try {\r\n        error.value = null\r\n        const response = await authService.checkAuth()\r\n        authStatus.value = response.data\r\n      } catch (err) {\r\n        console.error('检查认证状态失败:', err)\r\n        error.value = err.response ? JSON.stringify(err.response.data, null, 2) : err.message\r\n        ElMessage.error('检查认证状态失败')\r\n      }\r\n    }\r\n    \r\n    const loadStoredUser = () => {\r\n      const user = localStorage.getItem('user')\r\n      if (user) {\r\n        try {\r\n          storedUser.value = JSON.parse(user)\r\n        } catch (err) {\r\n          console.error('解析存储的用户信息失败:', err)\r\n        }\r\n      } else {\r\n        storedUser.value = null\r\n      }\r\n    }\r\n    \r\n    onMounted(() => {\r\n      loadStoredUser()\r\n      checkAuth()\r\n    })\r\n    \r\n    return {\r\n      loginForm,\r\n      authStatus,\r\n      storedUser,\r\n      loginResponse,\r\n      error,\r\n      handleLogin,\r\n      checkAuth\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.login-test-container {\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n}\r\n\r\n.card {\r\n  background-color: #fff;\r\n  border-radius: 4px;\r\n  box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.1);\r\n  padding: 20px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\npre {\r\n  background-color: #f5f5f5;\r\n  padding: 10px;\r\n  border-radius: 4px;\r\n  overflow: auto;\r\n  max-height: 300px;\r\n}\r\n\r\n.error {\r\n  background-color: #fef0f0;\r\n  color: #f56c6c;\r\n}\r\n</style> "],"mappings":"AA4CA,SAASA,GAAG,EAAEC,SAAQ,QAAS,KAAI;AACnC,SAASC,SAAQ,QAAS,cAAa;AACvC,OAAOC,WAAU,MAAO,YAAW;AAEnC,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,KAAKA,CAAA,EAAG;IACN,MAAMC,SAAQ,GAAIN,GAAG,CAAC;MACpBO,QAAQ,EAAE,OAAO;MACjBC,QAAQ,EAAE;IACZ,CAAC;IAED,MAAMC,UAAS,GAAIT,GAAG,CAAC,IAAI;IAC3B,MAAMU,UAAS,GAAIV,GAAG,CAAC,IAAI;IAC3B,MAAMW,aAAY,GAAIX,GAAG,CAAC,IAAI;IAC9B,MAAMY,KAAI,GAAIZ,GAAG,CAAC,IAAI;IAEtB,MAAMa,WAAU,GAAI,MAAAA,CAAA,KAAY;MAC9B,IAAI;QACFD,KAAK,CAACE,KAAI,GAAI,IAAG;QACjB,MAAMC,QAAO,GAAI,MAAMZ,WAAW,CAACa,KAAK,CAACV,SAAS,CAACQ,KAAK,CAACP,QAAQ,EAAED,SAAS,CAACQ,KAAK,CAACN,QAAQ;QAC3FG,aAAa,CAACG,KAAI,GAAIC,QAAQ,CAACE,IAAG;QAClCf,SAAS,CAACgB,OAAO,CAAC,MAAM;QACxBC,cAAc,CAAC;MACjB,EAAE,OAAOC,GAAG,EAAE;QACZC,OAAO,CAACT,KAAK,CAAC,OAAO,EAAEQ,GAAG;QAC1BR,KAAK,CAACE,KAAI,GAAIM,GAAG,CAACL,QAAO,GAAIO,IAAI,CAACC,SAAS,CAACH,GAAG,CAACL,QAAQ,CAACE,IAAI,EAAE,IAAI,EAAE,CAAC,IAAIG,GAAG,CAACI,OAAM;QACpFtB,SAAS,CAACU,KAAK,CAAC,MAAM;MACxB;IACF;IAEA,MAAMa,SAAQ,GAAI,MAAAA,CAAA,KAAY;MAC5B,IAAI;QACFb,KAAK,CAACE,KAAI,GAAI,IAAG;QACjB,MAAMC,QAAO,GAAI,MAAMZ,WAAW,CAACsB,SAAS,CAAC;QAC7ChB,UAAU,CAACK,KAAI,GAAIC,QAAQ,CAACE,IAAG;MACjC,EAAE,OAAOG,GAAG,EAAE;QACZC,OAAO,CAACT,KAAK,CAAC,WAAW,EAAEQ,GAAG;QAC9BR,KAAK,CAACE,KAAI,GAAIM,GAAG,CAACL,QAAO,GAAIO,IAAI,CAACC,SAAS,CAACH,GAAG,CAACL,QAAQ,CAACE,IAAI,EAAE,IAAI,EAAE,CAAC,IAAIG,GAAG,CAACI,OAAM;QACpFtB,SAAS,CAACU,KAAK,CAAC,UAAU;MAC5B;IACF;IAEA,MAAMO,cAAa,GAAIA,CAAA,KAAM;MAC3B,MAAMO,IAAG,GAAIC,YAAY,CAACC,OAAO,CAAC,MAAM;MACxC,IAAIF,IAAI,EAAE;QACR,IAAI;UACFhB,UAAU,CAACI,KAAI,GAAIQ,IAAI,CAACO,KAAK,CAACH,IAAI;QACpC,EAAE,OAAON,GAAG,EAAE;UACZC,OAAO,CAACT,KAAK,CAAC,cAAc,EAAEQ,GAAG;QACnC;MACF,OAAO;QACLV,UAAU,CAACI,KAAI,GAAI,IAAG;MACxB;IACF;IAEAb,SAAS,CAAC,M