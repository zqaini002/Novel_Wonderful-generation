{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, onMounted } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { ElMessage, ElMessageBox } from 'element-plus';\nimport { User, UserFilled, Reading, Loading, Check, Document, Delete } from '@element-plus/icons-vue';\nimport adminService from '@/api/admin';\nexport default {\n  __name: 'DashboardView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const loading = ref(true);\n    const stats = ref({\n      totalUsers: 0,\n      newUsers: 0,\n      totalNovels: 0,\n      processingNovels: 0,\n      completedNovels: 0\n    });\n\n    // 获取仪表盘数据\n    const fetchDashboardData = async () => {\n      loading.value = true;\n      try {\n        const response = await adminService.getDashboardStats();\n        stats.value = response.data;\n      } catch (error) {\n        console.error('获取仪表盘数据失败:', error);\n        ElMessage.error('获取仪表盘数据失败');\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 刷新数据\n    const refreshData = () => {\n      fetchDashboardData();\n    };\n\n    // 导航到用户管理\n    const goToUserManagement = () => {\n      router.push('/admin/users');\n    };\n\n    // 导航到小说管理\n    const goToNovelManagement = () => {\n      router.push('/admin/novels');\n    };\n\n    // 导航到系统日志\n    const goToSystemLogs = () => {\n      router.push('/admin/logs');\n    };\n\n    // 清理缓存\n    const clearCache = async () => {\n      try {\n        // 确认提示\n        await ElMessageBox.confirm('确定要清理系统缓存吗？这可能会暂时影响系统性能。', '确认操作', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n\n        // 执行清理\n        await adminService.clearSystemCache();\n        ElMessage.success('缓存清理成功');\n      } catch (err) {\n        if (err !== 'cancel') {\n          console.error('清理缓存失败:', err);\n          ElMessage.error('清理缓存失败');\n        }\n      }\n    };\n\n    // 组件挂载时获取数据\n    onMounted(() => {\n      fetchDashboardData();\n    });\n    const __returned__ = {\n      router,\n      loading,\n      stats,\n      fetchDashboardData,\n      refreshData,\n      goToUserManagement,\n      goToNovelManagement,\n      goToSystemLogs,\n      clearCache,\n      ref,\n      onMounted,\n      get useRouter() {\n        return useRouter;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get ElMessageBox() {\n        return ElMessageBox;\n      },\n      get User() {\n        return User;\n      },\n      get UserFilled() {\n        return UserFilled;\n      },\n      get Reading() {\n        return Reading;\n      },\n      get Loading() {\n        return Loading;\n      },\n      get Check() {\n        return Check;\n      },\n      get Document() {\n        return Document;\n      },\n      get Delete() {\n        return Delete;\n      },\n      get adminService() {\n        return adminService;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useRouter","ElMessage","ElMessageBox","User","UserFilled","Reading","Loading","Check","Document","Delete","adminService","router","loading","stats","totalUsers","newUsers","totalNovels","processingNovels","completedNovels","fetchDashboardData","value","response","getDashboardStats","data","error","console","refreshData","goToUserManagement","push","goToNovelManagement","goToSystemLogs","clearCache","confirm","confirmButtonText","cancelButtonText","type","clearSystemCache","success","err"],"sources":["E:/Novel_Wonderful generation/novel-assistant/frontend/src/views/admin/DashboardView.vue"],"sourcesContent":["<template>\n  <div class=\"dashboard-container\">\n    <el-card class=\"dashboard-card\">\n      <template #header>\n        <div class=\"card-header\">\n          <h2>系统仪表盘</h2>\n          <el-button type=\"primary\" @click=\"refreshData\">刷新数据</el-button>\n        </div>\n      </template>\n      \n      <div v-if=\"loading\" class=\"loading-container\">\n        <el-skeleton :rows=\"6\" animated />\n      </div>\n      \n      <div v-else class=\"dashboard-content\">\n        <!-- 数据统计卡片 -->\n        <div class=\"stats-cards\">\n          <el-card class=\"stat-card\" shadow=\"hover\">\n            <template #header>\n              <div class=\"stat-header\">\n                <span>总用户数</span>\n                <el-icon><User /></el-icon>\n              </div>\n            </template>\n            <div class=\"stat-value\">{{ stats.totalUsers }}</div>\n          </el-card>\n          \n          <el-card class=\"stat-card\" shadow=\"hover\">\n            <template #header>\n              <div class=\"stat-header\">\n                <span>新增用户</span>\n                <el-icon><UserFilled /></el-icon>\n              </div>\n            </template>\n            <div class=\"stat-value\">{{ stats.newUsers }}</div>\n            <div class=\"stat-desc\">过去7天</div>\n          </el-card>\n          \n          <el-card class=\"stat-card\" shadow=\"hover\">\n            <template #header>\n              <div class=\"stat-header\">\n                <span>小说总数</span>\n                <el-icon><Reading /></el-icon>\n              </div>\n            </template>\n            <div class=\"stat-value\">{{ stats.totalNovels }}</div>\n          </el-card>\n          \n          <el-card class=\"stat-card\" shadow=\"hover\">\n            <template #header>\n              <div class=\"stat-header\">\n                <span>处理中</span>\n                <el-icon><Loading /></el-icon>\n              </div>\n            </template>\n            <div class=\"stat-value\">{{ stats.processingNovels }}</div>\n          </el-card>\n          \n          <el-card class=\"stat-card\" shadow=\"hover\">\n            <template #header>\n              <div class=\"stat-header\">\n                <span>已完成</span>\n                <el-icon><Check /></el-icon>\n              </div>\n            </template>\n            <div class=\"stat-value\">{{ stats.completedNovels }}</div>\n          </el-card>\n        </div>\n        \n        <!-- 快捷功能区 -->\n        <el-card class=\"quick-actions\" shadow=\"hover\">\n          <template #header>\n            <div class=\"card-header\">\n              <h3>快捷操作</h3>\n            </div>\n          </template>\n          \n          <div class=\"actions-grid\">\n            <el-button @click=\"goToUserManagement\">\n              <el-icon><User /></el-icon>\n              用户管理\n            </el-button>\n            \n            <el-button @click=\"goToNovelManagement\">\n              <el-icon><Reading /></el-icon>\n              小说管理\n            </el-button>\n            \n            <el-button @click=\"goToSystemLogs\">\n              <el-icon><Document /></el-icon>\n              系统日志\n            </el-button>\n            \n            <el-button @click=\"clearCache\">\n              <el-icon><Delete /></el-icon>\n              清理缓存\n            </el-button>\n          </div>\n        </el-card>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from 'vue'\nimport { useRouter } from 'vue-router'\nimport { ElMessage, ElMessageBox } from 'element-plus'\nimport { User, UserFilled, Reading, Loading, Check, Document, Delete } from '@element-plus/icons-vue'\nimport adminService from '@/api/admin'\n\nconst router = useRouter()\nconst loading = ref(true)\nconst stats = ref({\n  totalUsers: 0,\n  newUsers: 0,\n  totalNovels: 0,\n  processingNovels: 0,\n  completedNovels: 0\n})\n\n// 获取仪表盘数据\nconst fetchDashboardData = async () => {\n  loading.value = true\n  try {\n    const response = await adminService.getDashboardStats()\n    stats.value = response.data\n  } catch (error) {\n    console.error('获取仪表盘数据失败:', error)\n    ElMessage.error('获取仪表盘数据失败')\n  } finally {\n    loading.value = false\n  }\n}\n\n// 刷新数据\nconst refreshData = () => {\n  fetchDashboardData()\n}\n\n// 导航到用户管理\nconst goToUserManagement = () => {\n  router.push('/admin/users')\n}\n\n// 导航到小说管理\nconst goToNovelManagement = () => {\n  router.push('/admin/novels')\n}\n\n// 导航到系统日志\nconst goToSystemLogs = () => {\n  router.push('/admin/logs')\n}\n\n// 清理缓存\nconst clearCache = async () => {\n  try {\n    // 确认提示\n    await ElMessageBox.confirm(\n      '确定要清理系统缓存吗？这可能会暂时影响系统性能。',\n      '确认操作',\n      {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }\n    )\n    \n    // 执行清理\n    await adminService.clearSystemCache()\n    ElMessage.success('缓存清理成功')\n  } catch (err) {\n    if (err !== 'cancel') {\n      console.error('清理缓存失败:', err)\n      ElMessage.error('清理缓存失败')\n    }\n  }\n}\n\n// 组件挂载时获取数据\nonMounted(() => {\n  fetchDashboardData()\n})\n</script>\n\n<style scoped>\n.dashboard-container {\n  padding: 20px;\n}\n\n.dashboard-card {\n  margin-bottom: 20px;\n}\n\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.loading-container {\n  padding: 20px;\n}\n\n.dashboard-content {\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n\n.stats-cards {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\n  gap: 15px;\n}\n\n.stat-card {\n  text-align: center;\n}\n\n.stat-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.stat-value {\n  font-size: 36px;\n  font-weight: bold;\n  margin: 10px 0;\n}\n\n.stat-desc {\n  color: #909399;\n  font-size: 12px;\n}\n\n.quick-actions {\n  margin-top: 10px;\n}\n\n.actions-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));\n  gap: 10px;\n}\n\n.actions-grid .el-button {\n  display: flex;\n  flex-direction: column;\n  height: 80px;\n  justify-content: center;\n  align-items: center;\n}\n\n.actions-grid .el-icon {\n  font-size: 24px;\n  margin-bottom: 5px;\n}\n</style> \n "],"mappings":";AAyGA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAI;AACnC,SAASC,SAAS,QAAQ,YAAW;AACrC,SAASC,SAAS,EAAEC,YAAY,QAAQ,cAAa;AACrD,SAASC,IAAI,EAAEC,UAAU,EAAEC,OAAO,EAAEC,OAAO,EAAEC,KAAK,EAAEC,QAAQ,EAAEC,MAAM,QAAQ,yBAAwB;AACpG,OAAOC,YAAY,MAAM,aAAY;;;;;;;IAErC,MAAMC,MAAM,GAAGX,SAAS,CAAC;IACzB,MAAMY,OAAO,GAAGd,GAAG,CAAC,IAAI;IACxB,MAAMe,KAAK,GAAGf,GAAG,CAAC;MAChBgB,UAAU,EAAE,CAAC;MACbC,QAAQ,EAAE,CAAC;MACXC,WAAW,EAAE,CAAC;MACdC,gBAAgB,EAAE,CAAC;MACnBC,eAAe,EAAE;IACnB,CAAC;;IAED;IACA,MAAMC,kBAAkB,GAAG,MAAAA,CAAA,KAAY;MACrCP,OAAO,CAACQ,KAAK,GAAG,IAAG;MACnB,IAAI;QACF,MAAMC,QAAQ,GAAG,MAAMX,YAAY,CAACY,iBAAiB,CAAC;QACtDT,KAAK,CAACO,KAAK,GAAGC,QAAQ,CAACE,IAAG;MAC5B,CAAC,CAAC,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,YAAY,EAAEA,KAAK;QACjCvB,SAAS,CAACuB,KAAK,CAAC,WAAW;MAC7B,CAAC,SAAS;QACRZ,OAAO,CAACQ,KAAK,GAAG,KAAI;MACtB;IACF;;IAEA;IACA,MAAMM,WAAW,GAAGA,CAAA,KAAM;MACxBP,kBAAkB,CAAC;IACrB;;IAEA;IACA,MAAMQ,kBAAkB,GAAGA,CAAA,KAAM;MAC/BhB,MAAM,CAACiB,IAAI,CAAC,cAAc;IAC5B;;IAEA;IACA,MAAMC,mBAAmB,GAAGA,CAAA,KAAM;MAChClB,MAAM,CAACiB,IAAI,CAAC,eAAe;IAC7B;;IAEA;IACA,MAAME,cAAc,GAAGA,CAAA,KAAM;MAC3BnB,MAAM,CAACiB,IAAI,CAAC,aAAa;IAC3B;;IAEA;IACA,MAAMG,UAAU,GAAG,MAAAA,CAAA,KAAY;MAC7B,IAAI;QACF;QACA,MAAM7B,YAAY,CAAC8B,OAAO,CACxB,0BAA0B,EAC1B,MAAM,EACN;UACEC,iBAAiB,EAAE,IAAI;UACvBC,gBAAgB,EAAE,IAAI;UACtBC,IAAI,EAAE;QACR,CACF;;QAEA;QACA,MAAMzB,YAAY,CAAC0B,gBAAgB,CAAC;QACpCnC,SAAS,CAACoC,OAAO,CAAC,QAAQ;MAC5B,CAAC,CAAC,OAAOC,GAAG,EAAE;QACZ,IAAIA,GAAG,KAAK,QAAQ,EAAE;UACpBb,OAAO,CAACD,KAAK,CAAC,SAAS,EAAEc,GAAG;UAC5BrC,SAAS,CAACuB,KAAK,CAAC,QAAQ;QAC1B;MACF;IACF;;IAEA;IACAzB,SAAS,CAAC,MAAM;MACdoB,kBAAkB,CAAC;IACrB,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}