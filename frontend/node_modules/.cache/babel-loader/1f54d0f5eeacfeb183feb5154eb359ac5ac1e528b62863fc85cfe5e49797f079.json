     goToUpload,\r\n      learnMore\r\n    }\r\n  }\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.home-container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n}\r\n\r\n.hero {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin: 40px 0 60px;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.hero-content {\r\n  flex: 1;\r\n  min-width: 300px;\r\n  padding-right: 40px;\r\n}\r\n\r\n.hero-content h1 {\r\n  font-size: 48px;\r\n  margin: 0 0 10px;\r\n  color: #409EFF;\r\n}\r\n\r\n.hero-content h2 {\r\n  font-size: 24px;\r\n  font-weight: normal;\r\n  margin: 0 0 20px;\r\n}\r\n\r\n.hero-content p {\r\n  font-size: 18px;\r\n  color: #606266;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.cta-buttons {\r\n  display: flex;\r\n  gap: 15px;\r\n}\r\n\r\n.hero-image {\r\n  flex: 1;\r\n  min-width: 300px;\r\n  display: flex;\r\n  justify-content: center;\r\n}\r\n\r\n.hero-image img {\r\n  max-width: 100%;\r\n  max-height: 400px;\r\n  object-fit: contain;\r\n}\r\n\r\n.features {\r\n  padding: 60px 0;\r\n}\r\n\r\n.features h2 {\r\n  text-align: center;\r\n  margin-bottom: 40px;\r\n  font-size: 32px;\r\n}\r\n\r\n.feature-cards {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  flex-wrap: wrap;\r\n  gap: 20px;\r\n}\r\n\r\n.feature-card {\r\n  flex: 1;\r\n  min-width: 300px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  align-items: center;\r\n  font-size: 18px;\r\n}\r\n\r\n.card-header i {\r\n  margin-right: 8px;\r\n  font-size: 24px;\r\n  color: #409EFF;\r\n}\r\n\r\n.card-content {\r\n  color: #606266;\r\n}\r\n\r\n.how-it-works {\r\n  padding: 60px 0;\r\n  text-align: center;\r\n}\r\n\r\n.how-it-works h2 {\r\n  margin-bottom: 40px;\r\n  font-size: 32px;\r\n}\r\n\r\n.action-button {\r\n  margin-top: 40px;\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .hero {\r\n    flex-direction: column;\r\n  }\r\n  \r\n  .hero-content {\r\n    padding-right: 0;\r\n    margin-bottom: 30px;\r\n    text-align: center;\r\n  }\r\n  \r\n  .cta-b