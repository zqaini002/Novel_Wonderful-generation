{"ast":null,"code":"import { defineComponent } from 'vue';\nimport { useRouter } from 'vue-router';\nexport default defineComponent({\n  name: 'HomeView',\n  setup() {\n    const router = useRouter();\n    const goToUpload = () => {\n      router.push('/upload');\n    };\n    const learnMore = () => {\n      document.getElementById('features').scrollIntoView({\n        behavior: 'smooth'\n      });\n    };\n    return {\n      goToUpload,\n      learnMore\n    };\n  }\n});","map":{"version":3,"names":["defineComponent","useRouter","name","setup","router","goToUpload","push","learnMore","document","getElementById","scrollIntoView","behavior"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\HomeView.vue"],"sourcesContent":["<template>\r\n  <div class=\"home-container\">\r\n    <section class=\"hero\">\r\n      <div class=\"hero-content\">\r\n        <h1>小说精读助手</h1>\r\n        <h2>AI驱动的小说内容分析与摘要生成系统</h2>\r\n        <p>快速了解小说内容，做出明智的阅读决策</p>\r\n        <div class=\"cta-buttons\">\r\n          <el-button type=\"primary\" size=\"large\" @click=\"goToUpload\">开始使用</el-button>\r\n          <el-button size=\"large\" @click=\"learnMore\">了解更多</el-button>\r\n        </div>\r\n      </div>\r\n      <div class=\"hero-image\">\r\n        <img src=\"../assets/hero-image.png\" alt=\"小说精读助手\" />\r\n      </div>\r\n    </section>\r\n\r\n    <section class=\"features\" id=\"features\">\r\n      <h2>核心功能</h2>\r\n      <div class=\"feature-cards\">\r\n        <el-card class=\"feature-card\">\r\n          <template #header>\r\n            <div class=\"card-header\">\r\n              <i class=\"el-icon-document\"></i>\r\n              <span>自动化文本处理</span>\r\n            </div>\r\n          </template>\r\n          <div class=\"card-content\">\r\n            <p>支持网页链接解析和本地文件上传（TXT/EPUB格式）</p>\r\n            <p>自动识别章节标题，过滤广告内容</p>\r\n          </div>\r\n        </el-card>\r\n\r\n        <el-card class=\"feature-card\">\r\n          <template #header>\r\n  