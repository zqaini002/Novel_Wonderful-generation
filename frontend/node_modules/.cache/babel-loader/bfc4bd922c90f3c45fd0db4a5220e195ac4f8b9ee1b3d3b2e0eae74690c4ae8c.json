\", {\n      key: novel.id\n    }, [_createElementVNode(\"td\", null, _toDisplayString(novel.id), 1 /* TEXT */), _createElementVNode(\"td\", null, _toDisplayString(novel.title), 1 /* TEXT */), _createElementVNode(\"td\", null, _toDisplayString(novel.author), 1 /* TEXT */), _createElementVNode(\"td\", null, [_createElementVNode(\"span\", {\n      class: _normalizeClass(['status-badge', novel.analysisStatus === 'COMPLETED' ? 'status-success' : novel.analysisStatus === 'PROCESSING' ? 'status-warning' : 'status-danger'])\n    }, _toDisplayString($setup.getStatusText(novel.analysisStatus)), 3 /* TEXT, CLASS */)]), _createElementVNode(\"td\", null, _toDisplayString($setup.formatDate(novel.analysisTime)), 1 /* TEXT */), _createElementVNode(\"td\", null, [_createElementVNode(\"button\", {\n      class: \"btn btn-primary btn-sm\",\n      onClick: $event => $setup.viewVisualization(novel.id)\n    }, \" 查看可视化 \", 8 /* PROPS */, _hoisted_17)])]);\n  }), 128 /* KEYED_FRAGMENT */))])])])])]), _createElementVNode(\"div\", _hoisted_18, [_createElementVNode(\"div\", _hoisted_19, [_cache[7] || (_cache[7] = _createElementVNode(\"h3\", null, \"小说类型分布\", -1 /* HOISTED */)), _createElementVNode(\"div\", _hoisted_20, null, 512 /* NEED_PATCH */)]), _createElementVNode(\"div\", _hoisted_21, [_cache[8] || (_cache[8] = _createElementVNode(\"h3\", null, \"每月分析数量\", -1 /* HOISTED */)), _createElementVNode(\"div\", _hoisted_22, null, 512 /* NEED_PATCH */)])])]);\n}","map":{"version":3,"names":["class","ref","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_hoisted_3","_hoisted_4","_hoisted_5","_hoisted_6","_toDisplayString","$setup","stats","totalNovels","_hoisted_7","_hoisted_8","analyzedNovels","_hoisted_9","_hoisted_10","totalUsers","_hoisted_11","_hoisted_12","totalAnalysis","_hoisted_13","_hoisted_14","_hoisted_15","_hoisted_16","_Fragment","_renderList","recentNovels","novel","key","id","title","author","_normalizeClass","analysisStatus","getStatusText","formatDate","analysisTime","onClick","$event","viewVisualization","_hoisted_17","_hoisted_18","_hoisted_19","_hoisted_20","_hoisted_21","_hoisted_22"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\admin\\VisualizationView.vue"],"sourcesContent":["<template>\n  <div class=\"visualization-container\">\n    <h1 class=\"page-title\">小说可视化总览</h1>\n    \n    <div class=\"card stats-card\">\n      <div class=\"card-header\">\n        <h2>平台数据总览</h2>\n      </div>\n      <div class=\"card-body\">\n        <div class=\"stats-grid\">\n          <div class=\"stat-item\">\n            <div class=\"stat-value\">{{ stats.totalNovels }}</div>\n            <div class=\"stat-label\">小说总数</div>\n          </div>\n          <div class=\"stat-item\">\n            <div class=\"stat-value\">{{ stats.analyzedNovels }}</div>\n            <div class=\"stat-label\">已分析小说</div>\n          </div>\n          <div class=\"stat-item\">\n            <div class=\"stat-value\">{{ stats.totalUsers }}</div>\n            <div class=\"stat-label\">用户总数</div>\n          </div>\n          <div class=\"stat-item\">\n            <div class=\"stat-value\">{{ stats.totalAnalysis }}</div>\n            <div class=\"stat-label\">分析总次数</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <div class=\"card-header\">\n        <h2>最近分析的小说</h2>\n      </div>\n      <div class=\"card-body\">\n        <div class=\"table-responsive\">\n          <table class=\"data-table\">\n            <thead>\n              <tr>\n                <th>ID</th>\n                <th>书名</th>\n                <th>作者</th>\n                <th>分析状态</th>\n                <th>分析时间</th>\n                <th>操作</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr v-for=\"novel in recentNovels\" :key=\"novel.id\">\n                <td>{{ novel.id }}</td>\n                <td>{{ novel.title }}</td>\n                <td>{{ novel.author }}</td>\n                <td>\n                  <span :class=\"['status-badge', novel.analysisStatus === 'COMPLETED' ? 'status-success' : \n                    novel.analysisStatus === 'PROCESSING' ? 'status-warning' : 'status-danger']\">\n                    {{ getStatusText(novel.analysisStatus) }}\n                  </span>\n                </td>\n                <td>{{ formatDate(novel.analysisTime) }}</td>\n                <td>\n                  <button class=\"btn btn-primary btn-sm\" @click=\"viewVisualization(novel.id)\">\n                    查看可视化\n                  </button>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"visualization-grid\">\n      <div class=\"chart-container\">\n        <h3>小说类型分布</h3>\n        <div ref=\"genreChartRef\" class=\"chart\"></div>\n      </div>\n      <div class=\"chart-container\">\n        <h3>每月分析数量</h3>\n        <div ref=\"monthlyAnalysisRef\" class=\"chart\"></div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, reactive } from 'vue';\nimport { useRouter } from 'vue-router';\nimport * as echarts from 'echarts';\nimport adminService from '@/api/admin';\n\nconst router = useRouter();\nconst genreChartRef = ref(null);\nconst monthlyAnalysisRef = ref(null);\nconst recentNovels = ref([]);\n\nconst stats = reactive({\n  totalNovels: 0,\n  analyzedNovels: 0,\n  totalUsers: 0,\n  totalAnalysis: 0\n});\n\nonMounted(async () => {\n  try {\n    // 获取仪表盘数据\n    const dashboardData = await adminService.getDashboardStats();\n    stats.totalNovels = dashboardData.totalNovels || 0;\n    stats.analyzedNovels = dashboardData.analyzedNovels || 0;\n    stats.totalUsers = dashboardData.totalUsers || 0;\n    stats.totalAnalysis = dashboardData.totalAnalysis || 0;\n    \n    // 获取最近分析的小说\n    const novelsResponse = await adminService.getRecentAnalyzedNovels();\n    recentNovels.value = novelsResponse.data || [];\n    \n    // 获取图表数据\n    const chartData = await adminService.getVisualizationData();\n    \n    // 初始化图表\n    initGenreChart(chartData.genreDistribution || []);\n    initMonthlyAnalysisChart(chartData.monthlyAnalysis || []);\n  } catch (error) {\n    console.error('获取可视化数据失败:', error);\n  }\n});\n\n// 初始化小说类型分布图表\nfunction initGenreChart(data) {\n  if (!genreChartRef.value) return;\n  \n  const chart = echarts.init(genreChartRef.value);\n  const option = {\n    tooltip: {\n      trigger: 'item',\n      formatter: '{a} <br/>{b}: {c} ({d}%)'\n    },\n    legend: {\n      orient: 'vertical',\n      right: 10,\n      top: 'center',\n      data: data.map(item => item.name)\n    },\n    series: [\n      {\n        name: '小说类型',\n        type: 'pie',\n        radius: ['50%', '70%'],\n        avoidLabelOverlap: false,\n        itemStyle: {\n          borderRadius: 10,\n          borderColor: '#fff',\n          borderWidth: 2\n        },\n        label: {\n          show: false,\n          position: 'center'\n        },\n        emphasis: {\n          label: {\n            show: true,\n            fontSize: '18',\n            fontWeight: 'bold'\n          }\n        },\n        labelLine: {\n          show: false\n        },\n        data: data\n      }\n    ]\n  };\n  \n  chart.setOption(option);\n  window.addEventListener('resize', () => {\n    chart.resize();\n  });\n}\n\n// 初始化每月分析数量图表\nfunction initMonthlyAnalysisChart(data) {\n  if (!monthlyAnalysisRef.value) return;\n  \n  const chart = echarts.init(monthlyAnalysisRef.value);\n  const months = data.map(item => item.month);\n  const counts = data.map(item => item.count);\n  \n  const option = {\n    tooltip: {\n      trigger: 'axis',\n      axisPointer: {\n        type: 'shadow'\n      }\n    },\n    grid: {\n      left: '3%',\n      right: '4%',\n      bottom: '3%',\n      containLabel: true\n    },\n    xAxis: [\n      {\n        type: 'category',\n        data: months,\n        axisTick: {\n          alignWithLabel: true\n        }\n      }\n    ],\n    yAxis: [\n      {\n        type: 'value'\n      }\n    ],\n    series: [\n      {\n        name: '分析数量',\n        type: 'bar',\n        barWidth: '60%',\n        data: counts\n      }\n    ]\n  };\n  \n  chart.setOption(option);\n  window.addEventListener('resize', () => {\n    chart.resize();\n  });\n}\n\n// 格式化日期\nfunction formatDate(dateString) {\n  if (!dateString) return '未知';\n  const date = new Date(dateString);\n  return date.toLocaleString('zh-CN', {\n    year: 'numeric',\n    month: '2-digit',\n    day: '2-digit',\n    hour: '2-digit',\n    minute: '2-digit'\n  });\n}\n\n// 获取状态文本\nfunction getStatusText(status) {\n  const statusMap = {\n    'COMPLETED': '已完成',\n    'PROCESSING': '处理中',\n    'FAILED': '失败',\n    'PENDING': '等待中'\n  };\n  return statusMap[status] || status;\n}\n\n// 查看小说可视化\nfunction viewVisualization(novelId) {\n  router.push(`/admin/novel/${novelId}/visualization`);\n}\n</script>\n\n<style scoped>\n.visualization-container {\n  padding: 20px;\n}\n\n.page-title {\n  font-size: 24px;\n  margin-bottom: 20px;\n  color: var(--primary-color);\n}\n\n.card {\n  background: #fff;\n  border-radius: 8px;\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);\n  margin-bottom: 24px;\n  overflow: hidden;\n}\n\n.card-header {\n  padding: 15px 20px;\n  background: rgba(0, 0, 0, 0.03);\n  border-bottom: 1px solid rgba(0, 0, 0, 0.125);\n}\n\n.card-header h2 {\n  margin: 0;\n  font-size: 18px;\n  font-weight: 600;\n}\n\n.card-body {\n  padding: 20px;\n}\n\n.stats-grid {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 20px;\n}\n\n.stat-item {\n  text-align: center;\n  padding: 15px;\n  background: var(--secondary-bg);\n  border-radius: 8px;\n}\n\n.stat-value {\n  font-size: 28px;\n  font-weight: 700;\n  color: var(--primary-color);\n  margin-bottom: 5px;\n}\n\n.stat-label {\n  font-size: 14px;\n  color: #666;\n}\n\n.data-table {\n  width: 100%;\n  border-collapse: collapse;\n}\n\n.data-table th,\n.data-table td {\n  padding: 12px 15px;\n  text-align: left;\n  border-bottom: 1px solid #eee;\n}\n\n.data-table th {\n  background-color: var(--secondary-bg);\n  font-weight: 600;\n}\n\n.status-badge {\n  padding: 4px 8px;\n  border-radius: 4px;\n  font-size: 12px;\n  font-weight: 500;\n}\n\n.status-success {\n  background-color: #e6f7e6;\n  color: #28a745;\n}\n\n.status-warning {\n  background-color: #fff8e1;\n  color: #ffc107;\n}\n\n.status-danger {\n  background-color: #ffebee;\n  color: #dc3545;\n}\n\n.btn {\n  padding: 5px 12px;\n  border: none;\n  border-radius: 4px;\n  cursor: pointer;\n  font-weight: 500;\n  transition: background-color 0.2s;\n}\n\n.btn-primary {\n  background-color: var(--primary-color);\n  color: white;\n}\n\n.btn-sm {\n  font-size: 12px;\n  padding: 4px 8px;\n}\n\n.visualization-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 24px;\n  margin-top: 24px;\n}\n\n.chart-container {\n  background: #fff;\n  border-radius: 8px;\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);\n  padding: 20px;\n}\n\n.chart-container h3 {\n  margin-top: 0;\n  margin-bottom: 15px;\n  font-size: 16px;\n  color: #333;\n}\n\n.chart {\n  height: 300px;\n  width: 100%;\n}\n\n@media (max-width: 768px) {\n  .stats-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n  \n  .visualization-grid {\n    grid-template-columns: 1fr;\n  }\n  \n  .table-responsive {\n    overflow-x: auto;\n  }\n}\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAyB;;EAG7BA,KAAK,EAAC;AAAiB;;EAIrBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAChBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAGpBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAGpBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAGpBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAY;;EAO1BA,KAAK,EAAC;AAAM;;EAIVA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAkB;;EACpBA,KAAK,EAAC;AAAY;oBApCnC;;EAuESA,KAAK,EAAC;AAAoB;;EACxBA,KAAK,EAAC;AAAiB;;EAErBC,GAAG,EAAC,eAAe;EAACD,KAAK,EAAC;;;EAE5BA,KAAK,EAAC;AAAiB;;EAErBC,GAAG,EAAC,oBAAoB;EAACD,KAAK,EAAC;;;uBA7E1CE,mBAAA,