{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport { ref, onMounted, onBeforeUnmount, watch, computed } from 'vue';\nimport * as echarts from 'echarts';\nconst __default__ = {\n  name: 'CharacterNetworkChart',\n  props: {\n    networkData: {\n      type: Object,\n      required: true,\n      default: () => ({\n        nodes: [],\n        links: []\n      })\n    },\n    title: {\n      type: String,\n      default: '人物关系网络'\n    },\n    height: {\n      type: String,\n      default: '500px'\n    },\n    width: {\n      type: String,\n      default: '100%'\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  setup(props) {\n    const chartRef = ref(null);\n    let chart = null;\n\n    // 计算是否有数据\n    const hasData = computed(() => {\n      return props.networkData && props.networkData.nodes && props.networkData.nodes.length > 0 && props.networkData.links && props.networkData.links.length > 0;\n    });\n\n    // 初始化图表\n    const initChart = () => {\n      // 确保DOM已挂载\n      if (!chartRef.value) return;\n\n      // 检查DOM元素是否有尺寸\n      if (chartRef.value.clientWidth === 0 || chartRef.value.clientHeight === 0) {\n        // 如果没有尺寸，延迟初始化\n        setTimeout(() => {\n          initChart();\n        }, 300);\n        return;\n      }\n\n      // 销毁旧图表\n      if (chart) {\n        chart.dispose();\n      }\n\n      // 初始化图表实例\n      chart = echarts.init(chartRef.value);\n\n      // 如果没有数据\n      if (!hasData.value) {\n        return;\n      }\n\n      // 格式化关系网络数据\n      const formattedData = formatNetworkData(props.networkData);\n\n      // 设置图表选项\n      const option = {\n        title: {\n          text: props.title,\n          left: 'center',\n          textStyle: {\n            fontWeight: 'normal',\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'item',\n          formatter: function (params) {\n            if (params.dataType === 'node') {\n              return `<div style=\"font-weight:bold\">${params.name}</div>` + `<div>重要度: ${params.value}</div>` + `${params.data.desc ? `<div>${params.data.desc}</div>` : ''}`;\n            } else {\n              return `${params.data.source} → ${params.data.target}<br/>` + `关系: ${params.data.relation || '未知'}` + `${params.data.desc ? `<br/>${params.data.desc}` : ''}`;\n            }\n          }\n        },\n        legend: {\n          data: formattedData.categories.map(category => category.name),\n          orient: 'vertical',\n          right: 10,\n          top: 'center'\n        },\n        animationDuration: 1500,\n        animationEasingUpdate: 'quinticInOut',\n        series: [{\n          name: '人物关系',\n          type: 'graph',\n          layout: 'force',\n          data: formattedData.nodes,\n          links: formattedData.links,\n          categories: formattedData.categories,\n          roam: true,\n          draggable: true,\n          label: {\n            position: 'right',\n            show: true,\n            formatter: '{b}'\n          },\n          force: {\n            repulsion: 200,\n            edgeLength: [50, 100],\n            layoutAnimation: true\n          },\n          lineStyle: {\n            color: 'source',\n            curveness: 0.3\n          },\n          emphasis: {\n            focus: 'adjacency',\n            lineStyle: {\n              width: 4\n            }\n          }\n        }]\n      };\n\n      // 渲染图表\n      chart.setOption(option);\n\n      // 添加双击节点事件 - 显示角色详细信息\n      chart.on('dblclick', params => {\n        if (params.dataType === 'node') {\n          showCharacterDetails(params.data);\n        }\n      });\n    };\n\n    // 显示角色详细信息\n    const showCharacterDetails = character => {\n      // 通知父组件显示角色详情\n      if (character) {\n        console.log('角色详情:', character);\n        // 触发事件将角色信息传递给父组件\n        // 父组件可以根据这些信息显示详细弹窗\n        // 这里只是简单的console.log\n      }\n    };\n\n    // 格式化网络数据，添加必要的视觉元素\n    const formatNetworkData = data => {\n      if (!data || !data.nodes || !data.links) {\n        return {\n          nodes: [],\n          links: [],\n          categories: []\n        };\n      }\n\n      // 提取所有角色类型作为分类\n      const categoryMap = new Map();\n      data.nodes.forEach(node => {\n        if (node.category && !categoryMap.has(node.category)) {\n          categoryMap.set(node.category, {\n            name: node.category\n          });\n        }\n      });\n\n      // 转换为数组\n      const categories = Array.from(categoryMap.values());\n\n      // 如果没有定义类别，添加默认分类\n      if (categories.length === 0) {\n        categories.push({\n          name: '主要角色'\n        });\n        categories.push({\n          name: '次要角色'\n        });\n      }\n\n      // 处理节点数据 - 添加视觉元素\n      const nodes = data.nodes.map((node, index) => {\n        // 确保每个节点有值且有分类\n        const value = node.value !== undefined ? node.value : Math.random() * 30 + 20;\n        const categoryIndex = node.category ? categories.findIndex(c => c.name === node.category) : value > 30 ? 0 : 1; // 大值为主要角色，小值为次要角色\n\n        // 生成随机颜色，如果节点没有指定颜色\n        const getRandomColor = () => {\n          const colors = ['#4992ff', '#7cffb2', '#fddd60', '#ff6e76', '#58d9f9', '#05c091', '#ff8a45', '#8d48e3', '#dd79ff'];\n          return colors[Math.floor(Math.random() * colors.length)];\n        };\n        return {\n          ...node,\n          id: node.id || index,\n          name: node.name,\n          value: value,\n          symbolSize: Math.sqrt(value) * 5,\n          // 根据重要度计算节点大小\n          category: categoryIndex,\n          itemStyle: {\n            color: node.color || getRandomColor()\n          }\n        };\n      });\n\n      // 处理关系数据 - 添加视觉元素\n      const links = data.links.map(link => {\n        // 计算线宽，基于关系强度\n        const value = link.value !== undefined ? link.value : 1;\n        const width = value * 2 > 5 ? 5 : value * 2 < 1 ? 1 : value * 2;\n        return {\n          ...link,\n          lineStyle: {\n            width: width\n          },\n          label: {\n            show: !!link.relation,\n            formatter: link.relation || ''\n          }\n        };\n      });\n      return {\n        nodes,\n        links,\n        categories\n      };\n    };\n\n    // 处理窗口大小改变\n    const handleResize = () => {\n      chart && chart.resize();\n    };\n\n    // 监听数据变化\n    watch(() => props.networkData, newVal => {\n      if (chart) {\n        const formattedData = formatNetworkData(newVal);\n        chart.setOption({\n          legend: {\n            data: formattedData.categories.map(category => category.name)\n          },\n          series: [{\n            data: formattedData.nodes,\n            links: formattedData.links,\n            categories: formattedData.categories\n          }]\n        });\n      } else if (chartRef.value && hasData.value) {\n        // 如果图表还未初始化，则初始化\n        initChart();\n      }\n    }, {\n      deep: true\n    });\n\n    // 监听加载状态\n    watch(() => props.loading, newVal => {\n      if (!newVal && !chart && chartRef.value && hasData.value) {\n        // 加载完成且图表未初始化\n        initChart();\n      }\n    });\n\n    // 组件挂载时初始化图表\n    onMounted(() => {\n      // 使用nextTick确保DOM已渲染\n      // 如果窗口已经加载完成\n      if (document.readyState === 'complete') {\n        setTimeout(() => {\n          if (!props.loading && hasData.value) {\n            initChart();\n          }\n        }, 300);\n      } else {\n        // 否则等待窗口完全加载\n        window.addEventListener('load', () => {\n          setTimeout(() => {\n            if (!props.loading && hasData.value) {\n              initChart();\n            }\n          }, 300);\n        });\n      }\n\n      // 确保在组件销毁时移除事件监听\n      window.addEventListener('resize', handleResize);\n    });\n\n    // 组件卸载前销毁图表\n    onBeforeUnmount(() => {\n      if (chart) {\n        chart.dispose();\n        chart = null;\n      }\n      window.removeEventListener('resize', handleResize);\n    });\n    return {\n      chartRef,\n      hasData,\n      chart\n    };\n  }\n};\nimport { useCssVars as _useCssVars } from 'vue';\nconst __injectCSSVars__ = () => {\n  _useCssVars(_ctx => ({\n    \"663d606e-width\": _ctx.width,\n    \"663d606e-height\": _ctx.height\n  }));\n};\nconst __setup__ = __default__.setup;\n__default__.setup = __setup__ ? (props, ctx) => {\n  __injectCSSVars__();\n  return __setup__(props, ctx);\n} : __injectCSSVars__;\nexport default __default__;","map":{"version":3,"names":["ref","onMounted","onBeforeUnmount","watch","computed","echarts","__default__","name","props","networkData","type","Object","required","default","nodes","links","title","String","height","width","loading","Boolean","setup","chartRef","chart","hasData","length","initChart","value","clientWidth","clientHeight","setTimeout","dispose","init","formattedData","formatNetworkData","option","text","left","textStyle","fontWeight","fontSize","tooltip","trigger","formatter","params","dataType","data","desc","source","target","relation","legend","categories","map","category","orient","right","top","animationDuration","animationEasingUpdate","series","layout","roam","draggable","label","position","show","force","repulsion","edgeLength","layoutAnimation","lineStyle","color","curveness","emphasis","focus","setOption","on","showCharacterDetails","character","console","log","categoryMap","Map","forEach","node","has","set","Array","from","values","push","index","undefined","Math","random","categoryIndex","findIndex","c","getRandomColor","colors","floor","id","symbolSize","sqrt","itemStyle","link","handleResize","resize","newVal","deep","document","readyState","window","addEventListener","removeEventListener"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\components\\visualization\\CharacterNetworkChart.vue"],"sourcesContent":["<template>\r\n  <div class=\"chart-container\">\r\n    <div v-if=\"loading\" class=\"loading-overlay\">\r\n      <div class=\"loading-spinner\"></div>\r\n      <div class=\"loading-text\">加载中...</div>\r\n    </div>\r\n    <div v-else-if=\"!hasData\" class=\"no-data-message\">\r\n      <i class=\"el-icon-warning-outline\"></i>\r\n      <p>暂无人物关系数据</p>\r\n    </div>\r\n    <div ref=\"chartRef\" class=\"character-network-chart\" :style=\"{ opacity: hasData ? 1 : 0 }\"></div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted, onBeforeUnmount, watch, computed } from 'vue'\r\nimport * as echarts from 'echarts'\r\n\r\nexport default {\r\n  name: 'CharacterNetworkChart',\r\n  props: {\r\n    networkData: {\r\n      type: Object,\r\n      required: true,\r\n      default: () => ({ nodes: [], links: [] })\r\n    },\r\n    title: {\r\n      type: String,\r\n      default: '人物关系网络'\r\n    },\r\n    height: {\r\n      type: String,\r\n      default: '500px'\r\n    },\r\n    width: {\r\n      type: String,\r\n      default: '100%'\r\n    },\r\n    loading: {\r\n      type: Boolean,\r\n      default: false\r\n    }\r\n  },\r\n  setup(props) {\r\n    const chartRef = ref(null)\r\n    let chart = null\r\n    \r\n    // 计算是否有数据\r\n    const hasData = computed(() => {\r\n      return props.networkData && \r\n             props.networkData.nodes && \r\n             props.networkData.nodes.length > 0 &&\r\n             props.networkData.links &&\r\n             props.networkData.links.length > 0;\r\n    });\r\n\r\n    // 初始化图表\r\n    const initChart = () => {\r\n      // 确保DOM已挂载\r\n      if (!chartRef.value) return\r\n\r\n      // 检查DOM元素是否有尺寸\r\n      if (chartRef.value.clientWidth === 0 || chartRef.value.clientHeight === 0) {\r\n        // 如果没有尺寸，延迟初始化\r\n        setTimeout(() => {\r\n          initChart();\r\n        }, 300);\r\n        return;\r\n      }\r\n\r\n      // 销毁旧图表\r\n      if (chart) {\r\n        chart.dispose()\r\n      }\r\n\r\n      // 初始化图表实例\r\n      chart = echarts.init(chartRef.value)\r\n      \r\n      // 如果没有数据\r\n      if (!hasData.value) {\r\n        return;\r\n      }\r\n      \r\n      // 格式化关系网络数据\r\n      const formattedData = formatNetworkData(props.networkData)\r\n      \r\n      // 设置图表选项\r\n      const option = {\r\n        title: {\r\n          text: props.title,\r\n          left: 'center',\r\n          textStyle: {\r\n            fontWeight: 'normal',\r\n            fontSize: 16\r\n          }\r\n        },\r\n        tooltip: {\r\n          trigger: 'item',\r\n          formatter: function(params) {\r\n            if (params.dataType === 'node') {\r\n              return `<div style=\"font-weight:bold\">${params.name}</div>` +\r\n                     `<div>重要度: ${params.value}</div>` + \r\n                     `${params.data.desc ? `<div>${params.data.desc}</div>` : ''}`;\r\n            } else {\r\n              return `${params.data.source} → ${params.data.target}<br/>` +\r\n                     `关系: ${params.data.relation || '未知'}` +\r\n                     `${params.data.desc ? `<br/>${params.data.desc}` : ''}`;\r\n            }\r\n          }\r\n        },\r\n        legend: {\r\n          data: formattedData.categories.map(category => category.name),\r\n          orient: 'vertical',\r\n          right: 10,\r\n          top: 'center'\r\n        },\r\n        animationDuration: 1500,\r\n        animationEasingUpdate: 'quinticInOut',\r\n        series: [{\r\n          name: '人物关系',\r\n          type: 'graph',\r\n          layout: 'force',\r\n          data: formattedData.nodes,\r\n          links: formattedData.links,\r\n          categories: formattedData.categories,\r\n          roam: true,\r\n          draggable: true,\r\n          label: {\r\n            position: 'right',\r\n            show: true,\r\n            formatter: '{b}'\r\n          },\r\n          force: {\r\n            repulsion: 200,\r\n            edgeLength: [50, 100],\r\n            layoutAnimation: true\r\n          },\r\n          lineStyle: {\r\n            color: 'source',\r\n            curveness: 0.3\r\n          },\r\n          emphasis: {\r\n            focus: 'adjacency',\r\n            lineStyle: {\r\n              width: 4\r\n            }\r\n          }\r\n        }]\r\n      };\r\n\r\n      // 渲染图表\r\n      chart.setOption(option)\r\n      \r\n      // 添加双击节点事件 - 显示角色详细信息\r\n      chart.on('dblclick', (params) => {\r\n        if (params.dataType === 'node') {\r\n          showCharacterDetails(params.data);\r\n        }\r\n      });\r\n    }\r\n    \r\n    // 显示角色详细信息\r\n    const showCharacterDetails = (character) => {\r\n      // 通知父组件显示角色详情\r\n      if (character) {\r\n        console.log('角色详情:', character);\r\n        // 触发事件将角色信息传递给父组件\r\n        // 父组件可以根据这些信息显示详细弹窗\r\n        // 这里只是简单的console.log\r\n      }\r\n    }\r\n    \r\n    // 格式化网络数据，添加必要的视觉元素\r\n    const formatNetworkData = (data) => {\r\n      if (!data || !data.nodes || !data.links) {\r\n        return { nodes: [], links: [], categories: [] };\r\n      }\r\n      \r\n      // 提取所有角色类型作为分类\r\n      const categoryMap = new Map();\r\n      data.nodes.forEach(node => {\r\n        if (node.category && !categoryMap.has(node.category)) {\r\n          categoryMap.set(node.category, {\r\n            name: node.category\r\n          });\r\n        }\r\n      });\r\n      \r\n      // 转换为数组\r\n      const categories = Array.from(categoryMap.values());\r\n      \r\n      // 如果没有定义类别，添加默认分类\r\n      if (categories.length === 0) {\r\n        categories.push({ name: '主要角色' });\r\n        categories.push({ name: '次要角色' });\r\n      }\r\n      \r\n      // 处理节点数据 - 添加视觉元素\r\n      const nodes = data.nodes.map((node, index) => {\r\n        // 确保每个节点有值且有分类\r\n        const value = node.value !== undefined ? node.value : Math.random() * 30 + 20;\r\n        const categoryIndex = node.category ? \r\n                            categories.findIndex(c => c.name === node.category) : \r\n                            (value > 30 ? 0 : 1); // 大值为主要角色，小值为次要角色\r\n        \r\n        // 生成随机颜色，如果节点没有指定颜色\r\n        const getRandomColor = () => {\r\n          const colors = [\r\n            '#4992ff', '#7cffb2', '#fddd60', '#ff6e76', '#58d9f9', \r\n            '#05c091', '#ff8a45', '#8d48e3', '#dd79ff'\r\n          ];\r\n          return colors[Math.floor(Math.random() * colors.length)];\r\n        };\r\n        \r\n        return {\r\n          ...node,\r\n          id: node.id || index,\r\n          name: node.name,\r\n          value: value,\r\n          symbolSize: Math.sqrt(value) * 5, // 根据重要度计算节点大小\r\n          category: categoryIndex,\r\n          itemStyle: {\r\n            color: node.color || getRandomColor()\r\n          }\r\n        };\r\n      });\r\n      \r\n      // 处理关系数据 - 添加视觉元素\r\n      const links = data.links.map(link => {\r\n        // 计算线宽，基于关系强度\r\n        const value = link.value !== undefined ? link.value : 1;\r\n        const width = value * 2 > 5 ? 5 : value * 2 < 1 ? 1 : value * 2;\r\n        \r\n        return {\r\n          ...link,\r\n          lineStyle: {\r\n            width: width\r\n          },\r\n          label: {\r\n            show: !!link.relation,\r\n            formatter: link.relation || ''\r\n          }\r\n        };\r\n      });\r\n      \r\n      return {\r\n        nodes,\r\n        links,\r\n        categories\r\n      };\r\n    }\r\n\r\n    // 处理窗口大小改变\r\n    const handleResize = () => {\r\n      chart && chart.resize()\r\n    }\r\n\r\n    // 监听数据变化\r\n    watch(() => props.networkData, (newVal) => {\r\n      if (chart) {\r\n        const formattedData = formatNetworkData(newVal)\r\n        chart.setOption({\r\n          legend: {\r\n            data: formattedData.categories.map(category => category.name)\r\n          },\r\n          series: [{\r\n            data: formattedData.nodes,\r\n            links: formattedData.links,\r\n            categories: formattedData.categories\r\n          }]\r\n        })\r\n      } else if (chartRef.value && hasData.value) {\r\n        // 如果图表还未初始化，则初始化\r\n        initChart()\r\n      }\r\n    }, { deep: true })\r\n    \r\n    // 监听加载状态\r\n    watch(() => props.loading, (newVal) => {\r\n      if (!newVal && !chart && chartRef.value && hasData.value) {\r\n        // 加载完成且图表未初始化\r\n        initChart()\r\n      }\r\n    })\r\n\r\n    // 组件挂载时初始化图表\r\n    onMounted(() => {\r\n      // 使用nextTick确保DOM已渲染\r\n      // 如果窗口已经加载完成\r\n      if (document.readyState === 'complete') {\r\n        setTimeout(() => {\r\n          if (!props.loading && hasData.value) {\r\n            initChart();\r\n          }\r\n        }, 300);\r\n      } else {\r\n        // 否则等待窗口完全加载\r\n        window.addEventListener('load', () => {\r\n          setTimeout(() => {\r\n            if (!props.loading && hasData.value) {\r\n              initChart();\r\n            }\r\n          }, 300);\r\n        });\r\n      }\r\n      \r\n      // 确保在组件销毁时移除事件监听\r\n      window.addEventListener('resize', handleResize)\r\n    })\r\n\r\n    // 组件卸载前销毁图表\r\n    onBeforeUnmount(() => {\r\n      if (chart) {\r\n        chart.dispose()\r\n        chart = null\r\n      }\r\n      window.removeEventListener('resize', handleResize)\r\n    })\r\n\r\n    return {\r\n      chartRef,\r\n      hasData,\r\n      chart\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.chart-container {\r\n  width: v-bind(width);\r\n  height: v-bind(height);\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.character-network-chart {\r\n  width: 100%;\r\n  height: 100%;\r\n  transition: opacity 0.3s ease;\r\n}\r\n\r\n.loading-overlay {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n  align-items: center;\r\n  background-color: rgba(255, 255, 255, 0.8);\r\n  z-index: 10;\r\n}\r\n\r\n.loading-spinner {\r\n  width: 40px;\r\n  height: 40px;\r\n  border: 3px solid #f3f3f3;