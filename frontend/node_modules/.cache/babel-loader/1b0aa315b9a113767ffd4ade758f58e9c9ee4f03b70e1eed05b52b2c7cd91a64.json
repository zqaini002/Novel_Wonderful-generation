{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { defineComponent, ref, reactive } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { useStore } from 'vuex';\nimport { ElMessage } from 'element-plus';\nimport { UploadFilled } from '@element-plus/icons-vue';\nexport default defineComponent({\n  name: 'UploadView',\n  components: {\n    UploadFilled\n  },\n  setup() {\n    const router = useRouter();\n    const store = useStore();\n\n    // 当前激活的标签页\n    const activeTab = ref('file');\n\n    // 文件上传相关\n    const uploadRef = ref(null);\n    const fileList = ref([]);\n    const uploadForm = reactive({\n      title: '',\n      author: ''\n    });\n\n    // URL解析相关\n    const urlForm = reactive({\n      url: '',\n      title: '',\n      author: ''\n    });\n\n    // 上传状态\n    const loading = ref(false);\n\n    // 对话框状态\n    const dialogVisible = ref(false);\n\n    // 返回首页\n    const goBack = () => {\n      router.push('/');\n    };\n\n    // 文件变更处理\n    const handleFileChange = (file, fileList) => {\n      // 只保留最新的文件\n      if (fileList && fileList.length > 0) {\n        fileList.value = [fileList[fileList.length - 1]];\n      }\n\n      // 尝试从文件名中提取标题\n      if (file && file.name && !uploadForm.title) {\n        const fileName = file.name.replace(/\\.(txt|epub)$/i, '');\n        uploadForm.title = fileName;\n      }\n    };\n\n    // 表单提交处理\n    const handleSubmit = () => {\n      if (activeTab.value === 'file') {\n        // 验证文件上传表单\n        if (!fileList.value || fileList.value.length === 0) {\n          ElMessage.warning('请上传小说文件');\n          return;\n        }\n        if (!uploadForm.title) {\n          ElMessage.warning('请输入小说标题');\n          return;\n        }\n\n        // 显示版权提醒\n        dialogVisible.value = true;\n      } else {\n        // 验证URL表单\n        if (!urlForm.url) {\n          ElMessage.warning('请输入小说链接');\n          return;\n        }\n        if (!urlForm.title) {\n          ElMessage.warning('请输入小说标题');\n          return;\n        }\n\n        // 显示版权提醒\n        dialogVisible.value = true;\n      }\n    };\n\n    // 确认上传\n    const confirmUpload = async () => {\n      dialogVisible.value = false;\n      loading.value = true;\n      try {\n        let params;\n        if (activeTab.value === 'file') {\n          // 确保文件列表存在并且有文件\n          if (!fileList.value || fileList.value.length === 0) {\n            throw new Error('未找到上传文件');\n          }\n\n          // 获取文件对象\n          const file = fileList.value[0];\n          const rawFile = file.raw || file;\n          if (!rawFile) {\n            throw new Error('无法获取文件对象');\n          }\n          params = {\n            file: rawFile,\n            title: uploadForm.title,\n            author: uploadForm.author\n          };\n        } else {\n          params = {\n            url: urlForm.url,\n            title: urlForm.title,\n            author: urlForm.author\n          };\n        }\n        console.log('上传参数:', params);\n\n        // 使用API上传\n        await store.dispatch('uploadNovel', params);\n        ElMessage.success('提交成功，正在处理中...');\n        router.push('/analyze');\n      } catch (error) {\n        ElMessage.error('提交失败，请重试: ' + (error.message || '未知错误'));\n        console.error('上传失败:', error);\n      } finally {\n        loading.value = false;\n      }\n    };\n    return {\n      activeTab,\n      uploadRef,\n      fileList,\n      uploadForm,\n      urlForm,\n      loading,\n      dialogVisible,\n      goBack,\n      handleFileChange,\n      handleSubmit,\n      confirmUpload\n    };\n  }\n});","map":{"version":3,"names":["defineComponent","ref","reactive","useRouter","useStore","ElMessage","UploadFilled","name","components","setup","router","store","activeTab","uploadRef","fileList","uploadForm","title","author","urlForm","url","loading","dialogVisible","goBack","push","handleFileChange","file","length","value","fileName","replace","handleSubmit","warning","confirmUpload","params","Error","rawFile","raw","console","log","dispatch","success","error","message"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\UploadView.vue"],"sourcesContent":["<template>\r\n  <div class=\"upload-container\">\r\n    <h1>上传小说</h1>\r\n    <p class=\"description\">上传小说文件或输入小说链接，系统将自动分析内容并生成摘要、标签等</p>\r\n    \r\n    <el-tabs v-model=\"activeTab\">\r\n      <el-tab-pane label=\"本地文件上传\" name=\"file\">\r\n        <div class=\"upload-area\">\r\n          <el-upload\r\n            class=\"upload-dragger\"\r\n            drag\r\n            action=\"\"\r\n            :auto-upload=\"false\"\r\n            :on-change=\"handleFileChange\"\r\n            :limit=\"1\"\r\n            :file-list=\"fileList\"\r\n            :multiple=\"false\"\r\n            ref=\"uploadRef\">\r\n            <el-icon><upload-filled /></el-icon>\r\n            <div class=\"el-upload__text\">拖拽文件到此处或 <em>点击上传</em></div>\r\n            <template #tip>\r\n              <div class=\"el-upload__tip\">\r\n                支持 TXT、EPUB 格式的小说文件，文件大小不超过 20MB\r\n              </div>\r\n            </template>\r\n          </el-upload>\r\n        </div>\r\n        \r\n        <div class=\"upload-form\">\r\n          <el-form :model=\"uploadForm\" label-width=\"100px\">\r\n            <el-form-item label=\"小说标题\" required>\r\n              <el-input v-model=\"uploadForm.title\" placeholder=\"请输入小说标题\"></el-input>\r\n            </el-form-item>\r\n            <el-form-item label=\"作者\">\r\n              <el-input v-model=\"uploadForm.author\" placeholder=\"请输入作者名（可选）\"></el-input>\r\n            </el-form-item>\r\n          </el-form>\r\n        </div>\r\n      </el-tab-pane>\r\n      \r\n      <el-tab-pane label=\"网页链接解析\" name=\"url\">\r\n        <div class=\"url-form\">\r\n          <el-form :model=\"urlForm\" label-width=\"100px\">\r\n            <el-form-item label=\"小说链接\" required>\r\n              <el-input v-model=\"urlForm.url\" placeholder=\"请输入小说目录页链接\"></el-input>\r\n              <div class=\"form-tip\">\r\n                支持主流小说网站，请确保链接指向小说目录页或章节页\r\n              </div>\r\n            </el-form-item>\r\n            <el-form-item label=\"小说标题\" required>\r\n              <el-input v-model=\"urlForm.title\" placeholder=\"请输入小说标题\"></el-input>\r\n            </el-form-item>\r\n            <el-form-item label=\"作者\">\r\n              <el-input v-model=\"urlForm.author\" placeholder=\"请输入作者名（可选）\"></el-input>\r\n            </el-form-item>\r\n          </el-form>\r\n        </div>\r\n      </el-tab-pane>\r\n    </el-tabs>\r\n    \r\n    <div class=\"upload-actions\">\r\n      <el-button @click=\"goBack\">取消</el-button>\r\n      <el-button type=\"primary\" @click=\"handleSubmit\" :loading=\"loading\">开始分析</el-button>\r\n    </div>\r\n    \r\n    <el-dialog\r\n      v-model=\"dialogVisible\"\r\n      title=\"版权提醒\"\r\n      width=\"30%\">\r\n      <span>请确保您有合法权利使用上传的小说内容，本工具仅供个人学习和研究使用，请勿用于侵犯版权的目的。</span>\r\n      <template #footer>\r\n        <span class=\"dialog-footer\">\r\n          <el-button @click=\"dialogVisible = false\">取消</el-button>\r\n          <el-button type=\"primary\" @click=\"confirmUpload\">确认上传</el-button>\r\n        </span>\r\n      </template>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { defineComponent, ref, reactive } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\nimport { useStore } from 'vuex'\r\nimport { ElMessage } from 'element-plus'\r\nimport { UploadFilled } from '@element-plus/icons-vue'\r\n\r\nexport default defineComponent({\r\n  name: 'UploadView',\r\n  components: {\r\n    UploadFilled\r\n  },\r\n  setup() {\r\n    const router = useRouter()\r\n    const store = useStore()\r\n    \r\n    // 当前激活的标签页\r\n    const activeTab = ref('file')\r\n    \r\n    // 文件上传相关\r\n    const uploadRef = ref(null)\r\n    const fileList = ref([])\r\n    const uploadForm = reactive({\r\n      title: '',\r\n      author: ''\r\n    })\r\n    \r\n    // URL解析相关\r\n    const urlForm = reactive({\r\n      url: '',\r\n      title: '',\r\n      author: ''\r\n    })\r\n    \r\n    // 上传状态\r\n    const loading = ref(false)\r\n    \r\n    // 对话框状态\r\n    const dialogVisible = ref(false)\r\n    \r\n    // 返回首页\r\n    const goBack = () => {\r\n      router.push('/')\r\n    }\r\n    \r\n    // 文件变更处理\r\n    const handleFileChange = (file, fileList) => {\r\n      // 只保留最新的文件\r\n      if (fileList && fileList.length > 0) {\r\n        fileList.value = [fileList[fileList.length - 1]]\r\n      }\r\n      \r\n      // 尝试从文件名中提取标题\r\n      if (file && file.name && !uploadForm.title) {\r\n        const fileName = file.name.replace(/\\.(txt|epub)$/i, '')\r\n        uploadForm.title = fileName\r\n      }\r\n    }\r\n    \r\n    // 表单提交处理\r\n    const handleSubmit = () => {\r\n      if (activeTab.value === 'file') {\r\n        // 验证文件上传表单\r\n        if (!fileList.value || fileList.value.length === 0) {\r\n          ElMessage.warning('请上传小说文件')\r\n          return\r\n        }\r\n        \r\n        if (!uploadForm.title) {\r\n          ElMessage.warning('请输入小说标题')\r\n          return\r\n        }\r\n        \r\n        // 显示版权提醒\r\n        dialogVisible.value = true\r\n      } else {\r\n        // 验证URL表单\r\n        if (!urlForm.url) {\r\n          ElMessage.warning('请输入小说链接')\r\n          return\r\n        }\r\n        \r\n        if (!urlForm.title) {\r\n          ElMessage.warning('请输入小说标题')\r\n          return\r\n        }\r\n        \r\n        // 显示版权提醒\r\n        dialogVisible.value = true\r\n      }\r\n    }\r\n    \r\n    // 确认上传\r\n    const confirmUpload = async () => {\r\n      dialogVisible.value = false\r\n      loading.value = true\r\n      \r\n      try {\r\n        let params;\r\n        \r\n        if (activeTab.value === 'file') {\r\n          // 确保文件列表存在并且有文件\r\n          if (!fileList.value || fileList.value.length === 0) {\r\n            throw new Error('未找到上传文件');\r\n          }\r\n          \r\n          // 获取文件对象\r\n          const file = fileList.value[0];\r\n          const rawFile = file.raw || file;\r\n          \r\n          if (!rawFile) {\r\n            throw new Error('无法获取文件对象');\r\n          }\r\n          \r\n          params = { \r\n            file: rawFile, \r\n            title: uploadForm.title,\r\n            author: uploadForm.author\r\n          };\r\n        } else {\r\n          params = { \r\n            url: urlForm.url, \r\n            title: urlForm.title,\r\n            author: urlForm.author\r\n          };\r\n        }\r\n        \r\n        console.log('上传参数:', params);\r\n        \r\n        // 使用API上传\r\n        await store.dispatch('uploadNovel', params)\r\n        \r\n        ElMessage.success('提交成功，正在处理中...')\r\n        router.push('/analyze')\r\n      } catch (error) {\r\n        ElMessage.error('提交失败，请重试: ' + (error.message || '未知错误'))\r\n        console.error('上传失败:', error)\r\n      } finally {\r\n        loading.value = false\r\n      }\r\n    }\r\n    \r\n    return {\r\n      activeTab,\r\n      uploadRef,\r\n      fileList,\r\n      uploadForm,\r\n      urlForm,\r\n      loading,\r\n      dialogVisible,\r\n      goBack,\r\n      handleFileChange,\r\n      handleSubmit,\r\n      confirmUpload\r\n    }\r\n  }\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.upload-container {\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n}\r\n\r\nh1 {\r\n  text-align: center;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.description {\r\n  text-align: center;\r\n  color: #606266;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.upload-area {\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.upload-dragger {\r\n  width: 100%;\r\n}\r\n\r\n.form-tip {\r\n  font-size: 12px;\r\n  color: #909399;\r\n  margin-top: 5px;\r\n}\r\n\r\n.upload-actions {\r\n  margin-top: 30px;\r\n  display: flex;\r\n  justify-content: center;\r\n  gap: 20px;\r\n}\r\n</style> "],"mappings":";AAiFA,SAASA,eAAe,EAAEC,GAAG,EAAEC,QAAO,QAAS,KAAI;AACnD,SAASC,SAAQ,QAAS,YAAW;AACrC,SAASC,QAAO,QAAS,MAAK;AAC9B,SAASC,SAAQ,QAAS,cAAa;AACvC,SAASC,YAAW