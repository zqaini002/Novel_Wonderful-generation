nd, \r\n    Share, \r\n    Position, \r\n    HomeFilled, \r\n    Upload, \r\n    InfoFilled, \r\n    Document, \r\n    QuestionFilled, \r\n    ChatLineSquare, \r\n    Message, \r\n    Promotion, \r\n    Link\r\n  },\r\n  setup() {\r\n    // 获取当前年份\r\n    const currentYear = computed(() => new Date().getFullYear())\r\n    \r\n    return {\r\n      currentYear\r\n    }\r\n  }\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.footer-container {\r\n  width: 100%;\r\n  color: #606266;\r\n  position: relative;\r\n}\r\n\r\n.footer-wave {\r\n  position: absolute;\r\n  top: -60px;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 60px;\r\n  overflow: hidden;\r\n}\r\n\r\n.footer-content {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  padding: 40px 24px;\r\n  max-width: 1280px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.footer-logo {\r\n  flex: 1;\r\n  min-width: 250px;\r\n  margin-right: 40px;\r\n}\r\n\r\n.logo-wrapper {\r\n  display: flex;\r\n  align-items: center;\r\n  margin-bottom: 12px;\r\n}\r\n\r\n.logo-icon {\r\n  font-size: 24px;\r\n  color: var(--primary-color);\r\n  margin-right: 10px;\r\n}\r\n\r\n.footer-logo h2 {\r\n  margin: 0;\r\n  color: var(--primary-color);\r\n  font-weight: 600;\r\n}\r\n\r\n.footer-logo p {\r\n  margin: 0 0 20px 0;\r\n  color: #909399;\r\n  line-height: 1.6;\r\n}\r\n\r\n.social-icons {\r\n  display: flex;\r\n  margin-top: 15px;\r\n  gap: 12px;\r\n}\r\n\r\n.social-icon {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: 36px;\r\n  height: 36px;\r\n  border-radius: 50%;\r\n  background-color: rgba(77, 123, 239, 0.1);\r\n  color: var(--primary-color);\r\n  transition: all 0.3s;\r\n}\r\n\r\n.social-icon:hover {\r\n  background-color: var(--primary-color);\r\n  color: white;\r\n  transform: translateY(-2px);\r\n}\r\n\r\n.footer-links {\r\n  flex: 2;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  justify-content: space-between;\r\n}\r\n\r\n.link-group {\r\n  min-width: 180px;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.link-group h3