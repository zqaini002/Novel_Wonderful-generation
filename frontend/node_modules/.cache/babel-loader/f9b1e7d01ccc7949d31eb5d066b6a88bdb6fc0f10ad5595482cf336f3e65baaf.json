{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport { ElMessage } from 'element-plus';\nimport { Search } from '@element-plus/icons-vue';\nimport adminService from '@/api/admin';\nexport default {\n  __name: 'SystemLogsView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const loading = ref(true);\n    const logs = ref([]);\n    const searchQuery = ref('');\n    const logLevel = ref('ALL');\n    const dateRange = ref(null);\n    const currentPage = ref(0);\n    const pageSize = ref(20);\n    const totalLogs = ref(0);\n\n    // 获取系统日志\n    const fetchLogs = async () => {\n      loading.value = true;\n      try {\n        const filters = {};\n        if (logLevel.value) {\n          filters.level = logLevel.value;\n        }\n        if (dateRange.value && dateRange.value.length === 2) {\n          filters.startDate = dateRange.value[0].toISOString().split('T')[0];\n          filters.endDate = dateRange.value[1].toISOString().split('T')[0];\n        }\n        if (searchQuery.value) {\n          filters.query = searchQuery.value;\n        }\n        const response = await adminService.getSystemLogs(currentPage.value, pageSize.value, filters);\n\n        // 打印API响应以便调试\n        console.log('获取系统日志响应:', response);\n\n        // apiClient已经提取了response.data，直接检查logs字段\n        if (response && response.logs) {\n          logs.value = response.logs;\n          totalLogs.value = response.total || 0;\n        } else {\n          logs.value = [];\n          totalLogs.value = 0;\n          console.warn('系统日志API返回格式异常:', response);\n        }\n      } catch (error) {\n        console.error('获取系统日志失败:', error);\n        ElMessage.error('获取系统日志失败: ' + (error.message || '未知错误'));\n        logs.value = [];\n        totalLogs.value = 0;\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 格式化日期\n    const formatDate = timestamp => {\n      if (!timestamp) return '未知';\n      const date = new Date(timestamp);\n      return date.toLocaleString();\n    };\n\n    // 获取日志级别对应的类型\n    const getLogLevelType = level => {\n      switch (level) {\n        case 'ERROR':\n          return 'danger';\n        case 'WARN':\n          return 'warning';\n        case 'INFO':\n          return 'info';\n        case 'DEBUG':\n          return 'success';\n        default:\n          return '';\n      }\n    };\n\n    // 处理每页数量变化\n    const handleSizeChange = size => {\n      pageSize.value = size;\n      fetchLogs();\n    };\n\n    // 处理页码变化\n    const handleCurrentChange = page => {\n      currentPage.value = page - 1; // 后端分页从0开始\n      fetchLogs();\n    };\n\n    // 组件挂载时获取数据\n    onMounted(() => {\n      // 设置默认日期范围为最近7天\n      const endDate = new Date();\n      const startDate = new Date();\n      startDate.setDate(endDate.getDate() - 7);\n      dateRange.value = [startDate, endDate];\n      fetchLogs();\n    });\n    const __returned__ = {\n      loading,\n      logs,\n      searchQuery,\n      logLevel,\n      dateRange,\n      currentPage,\n      pageSize,\n      totalLogs,\n      fetchLogs,\n      formatDate,\n      getLogLevelType,\n      handleSizeChange,\n      handleCurrentChange,\n      ref,\n      onMounted,\n      get ElMessage() {\n        return ElMessage;\n      },\n      get Search() {\n        return Search;\n      },\n      get adminService() {\n        return adminService;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","ElMessage","Search","adminService","loading","logs","searchQuery","logLevel","dateRange","currentPage","pageSize","totalLogs","fetchLogs","value","filters","level","length","startDate","toISOString","split","endDate","query","response","getSystemLogs","console","log","total","warn","error","message","formatDate","timestamp","date","Date","toLocaleString","getLogLevelType","handleSizeChange","size","handleCurrentChange","page","setDate","getDate"],"sources":["E:/Novel_Wonderful generation/novel-assistant/frontend/src/views/admin/SystemLogsView.vue"],"sourcesContent":["<template>\r\n  <div class=\"system-logs-container\">\r\n    <el-card class=\"system-logs-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <h2>系统日志</h2>\r\n          <div class=\"header-actions\">\r\n            <el-select \r\n              v-model=\"logLevel\" \r\n              placeholder=\"日志级别\" \r\n              style=\"width: 120px; margin-right: 10px;\"\r\n              @change=\"fetchLogs\"\r\n            >\r\n              <el-option label=\"全部\" value=\"ALL\" />\r\n              <el-option label=\"INFO\" value=\"INFO\" />\r\n              <el-option label=\"WARN\" value=\"WARN\" />\r\n              <el-option label=\"ERROR\" value=\"ERROR\" />\r\n              <el-option label=\"DEBUG\" value=\"DEBUG\" />\r\n            </el-select>\r\n            <el-date-picker\r\n              v-model=\"dateRange\"\r\n              type=\"daterange\"\r\n              range-separator=\"至\"\r\n              start-placeholder=\"开始日期\"\r\n              end-placeholder=\"结束日期\"\r\n              format=\"YYYY-MM-DD\"\r\n              style=\"width: 300px; margin-right: 10px;\"\r\n              @change=\"fetchLogs\"\r\n            />\r\n            <el-input\r\n              v-model=\"searchQuery\"\r\n              placeholder=\"搜索日志内容\"\r\n              clearable\r\n              @clear=\"fetchLogs\"\r\n              style=\"width: 200px; margin-right: 10px;\"\r\n            >\r\n              <template #prefix>\r\n                <el-icon><Search /></el-icon>\r\n              </template>\r\n            </el-input>\r\n            <el-button type=\"primary\" @click=\"fetchLogs\">刷新</el-button>\r\n          </div>\r\n        </div>\r\n      </template>\r\n      \r\n      <div v-if=\"loading\" class=\"loading-container\">\r\n        <el-skeleton :rows=\"10\" animated />\r\n      </div>\r\n      \r\n      <div v-else class=\"logs-table-container\">\r\n        <el-table\r\n          :data=\"logs\"\r\n          style=\"width: 100%\"\r\n          border\r\n          stripe\r\n        >\r\n          <el-table-column type=\"expand\">\r\n            <template #default=\"props\">\r\n              <div class=\"log-details\">\r\n                <div class=\"log-stack\" v-if=\"props.row.stackTrace\">\r\n                  <p class=\"stack-title\">堆栈跟踪:</p>\r\n                  <pre>{{ props.row.stackTrace }}</pre>\r\n                </div>\r\n                <div class=\"log-params\" v-if=\"props.row.params\">\r\n                  <p class=\"params-title\">参数:</p>\r\n                  <pre>{{ JSON.stringify(props.row.params, null, 2) }}</pre>\r\n                </div>\r\n              </div>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"时间\" width=\"180\">\r\n            <template #default=\"scope\">\r\n              {{ formatDate(scope.row.timestamp) }}\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column prop=\"level\" label=\"级别\" width=\"100\">\r\n            <template #default=\"scope\">\r\n              <el-tag :type=\"getLogLevelType(scope.row.level)\">\r\n                {{ scope.row.level }}\r\n              </el-tag>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column prop=\"logger\" label=\"Logger\" width=\"180\" />\r\n          <el-table-column prop=\"thread\" label=\"线程\" width=\"150\" />\r\n          <el-table-column prop=\"message\" label=\"消息\" min-width=\"300\" show-overflow-tooltip />\r\n          <el-table-column prop=\"userId\" label=\"用户\" width=\"120\" />\r\n          <el-table-column prop=\"ip\" label=\"IP地址\" width=\"130\" />\r\n        </el-table>\r\n        \r\n        <div class=\"pagination-container\">\r\n          <el-pagination\r\n            background\r\n            layout=\"prev, pager, next, sizes, total\"\r\n            :total=\"totalLogs\"\r\n            :page-size=\"pageSize\"\r\n            :page-sizes=\"[20, 50, 100, 200]\"\r\n            @size-change=\"handleSizeChange\"\r\n            @current-change=\"handleCurrentChange\"\r\n          />\r\n        </div>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport { ElMessage } from 'element-plus'\r\nimport { Search } from '@element-plus/icons-vue'\r\nimport adminService from '@/api/admin'\r\n\r\nconst loading = ref(true)\r\nconst logs = ref([])\r\nconst searchQuery = ref('')\r\nconst logLevel = ref('ALL')\r\nconst dateRange = ref(null)\r\nconst currentPage = ref(0)\r\nconst pageSize = ref(20)\r\nconst totalLogs = ref(0)\r\n\r\n// 获取系统日志\r\nconst fetchLogs = async () => {\r\n  loading.value = true\r\n  try {\r\n    const filters = {}\r\n    \r\n    if (logLevel.value) {\r\n      filters.level = logLevel.value\r\n    }\r\n    \r\n    if (dateRange.value && dateRange.value.length === 2) {\r\n      filters.startDate = dateRange.value[0].toISOString().split('T')[0]\r\n      filters.endDate = dateRange.value[1].toISOString().split('T')[0]\r\n    }\r\n    \r\n    if (searchQuery.value) {\r\n      filters.query = searchQuery.value\r\n    }\r\n    \r\n    const response = await adminService.getSystemLogs(currentPage.value, pageSize.value, filters)\r\n    \r\n    // 打印API响应以便调试\r\n    console.log('获取系统日志响应:', response);\r\n    \r\n    // apiClient已经提取了response.data，直接检查logs字段\r\n    if (response && response.logs) {\r\n      logs.value = response.logs\r\n      totalLogs.value = response.total || 0\r\n    } else {\r\n      logs.value = []\r\n      totalLogs.value = 0\r\n      console.warn('系统日志API返回格式异常:', response)\r\n    }\r\n  } catch (error) {\r\n    console.error('获取系统日志失败:', error)\r\n    ElMessage.error('获取系统日志失败: ' + (error.message || '未知错误'))\r\n    logs.value = []\r\n    totalLogs.value = 0\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\n// 格式化日期\r\nconst formatDate = (timestamp) => {\r\n  if (!timestamp) return '未知'\r\n  const date = new Date(timestamp)\r\n  return date.toLocaleString()\r\n}\r\n\r\n// 获取日志级别对应的类型\r\nconst getLogLevelType = (level) => {\r\n  switch (level) {\r\n    case 'ERROR':\r\n      return 'danger'\r\n    case 'WARN':\r\n      return 'warning'\r\n    case 'INFO':\r\n      return 'info'\r\n    case 'DEBUG':\r\n      return 'success'\r\n    default:\r\n      return ''\r\n  }\r\n}\r\n\r\n// 处理每页数量变化\r\nconst handleSizeChange = (size) => {\r\n  pageSize.value = size\r\n  fetchLogs()\r\n}\r\n\r\n// 处理页码变化\r\nconst handleCurrentChange = (page) => {\r\n  currentPage.value = page - 1 // 后端分页从0开始\r\n  fetchLogs()\r\n}\r\n\r\n// 组件挂载时获取数据\r\nonMounted(() => {\r\n  // 设置默认日期范围为最近7天\r\n  const endDate = new Date()\r\n  const startDate = new Date()\r\n  startDate.setDate(endDate.getDate() - 7)\r\n  dateRange.value = [startDate, endDate]\r\n  \r\n  fetchLogs()\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.system-logs-container {\r\n  padding: 20px;\r\n}\r\n\r\n.system-logs-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.header-actions {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.loading-container {\r\n  padding: 20px;\r\n}\r\n\r\n.logs-table-container {\r\n  overflow-x: auto;\r\n}\r\n\r\n.log-details {\r\n  padding: 10px 20px;\r\n  background-color: #f8f8f8;\r\n  border-radius: 4px;\r\n}\r\n\r\n.log-stack, .log-params {\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.stack-title, .params-title {\r\n  font-weight: bold;\r\n  margin-bottom: 5px;\r\n}\r\n\r\npre {\r\n  background-color: #f0f0f0;\r\n  padding: 10px;\r\n  border-radius: 4px;\r\n  overflow-x: auto;\r\n  font-family: monospace;\r\n  font-size: 12px;\r\n  white-space: pre-wrap;\r\n}\r\n\r\n.pagination-container {\r\n  margin-top: 20px;\r\n  display: flex;\r\n  justify-content: center;\r\n}\r\n</style> \r\n "],"mappings":"AA0GA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,SAAS,QAAQ,cAAc;AACxC,SAASC,MAAM,QAAQ,yBAAyB;AAChD,OAAOC,YAAY,MAAM,aAAa;;;;;;;IAEtC,MAAMC,OAAO,GAAGL,GAAG,CAAC,IAAI,CAAC;IACzB,MAAMM,IAAI,GAAGN,GAAG,CAAC,EAAE,CAAC;IACpB,MAAMO,WAAW,GAAGP,GAAG,CAAC,EAAE,CAAC;IAC3B,MAAMQ,QAAQ,GAAGR,GAAG,CAAC,KAAK,CAAC;IAC3B,MAAMS,SAAS,GAAGT,GAAG,CAAC,IAAI,CAAC;IAC3B,MAAMU,WAAW,GAAGV,GAAG,CAAC,CAAC,CAAC;IAC1B,MAAMW,QAAQ,GAAGX,GAAG,CAAC,EAAE,CAAC;IACxB,MAAMY,SAAS,GAAGZ,GAAG,CAAC,CAAC,CAAC;;IAExB;IACA,MAAMa,SAAS,GAAG,MAAAA,CAAA,KAAY;MAC5BR,OAAO,CAACS,KAAK,GAAG,IAAI;MACpB,IAAI;QACF,MAAMC,OAAO,GAAG,CAAC,CAAC;QAElB,IAAIP,QAAQ,CAACM,KAAK,EAAE;UAClBC,OAAO,CAACC,KAAK,GAAGR,QAAQ,CAACM,KAAK;QAChC;QAEA,IAAIL,SAAS,CAACK,KAAK,IAAIL,SAAS,CAACK,KAAK,CAACG,MAAM,KAAK,CAAC,EAAE;UACnDF,OAAO,CAACG,SAAS,GAAGT,SAAS,CAACK,KAAK,CAAC,CAAC,CAAC,CAACK,WAAW,CAAC,CAAC,CAACC,KAAK,CAAC,GAAG,CAAC,CAAC,CAAC,CAAC;UAClEL,OAAO,CAACM,OAAO,GAAGZ,SAAS,CAACK,KAAK,CAAC,CAAC,CAAC,CAACK,WAAW,CAAC,CAAC,CAACC,KAAK,CAAC,GAAG,CAAC,CAAC,CAAC,CAAC;QAClE;QAEA,IAAIb,WAAW,CAACO,KAAK,EAAE;UACrBC,OAAO,CAACO,KAAK,GAAGf,WAAW,CAACO,KAAK;QACnC;QAEA,MAAMS,QAAQ,GAAG,MAAMnB,YAAY,CAACoB,aAAa,CAACd,WAAW,CAACI,KAAK,EAAEH,QAAQ,CAACG,KAAK,EAAEC,OAAO,CAAC;;QAE7F;QACAU,OAAO,CAACC,GAAG,CAAC,WAAW,EAAEH,QAAQ,CAAC;;QAElC;QACA,IAAIA,QAAQ,IAAIA,QAAQ,CAACjB,IAAI,EAAE;UAC7BA,IAAI,CAACQ,KAAK,GAAGS,QAAQ,CAACjB,IAAI;UAC1BM,SAAS,CAACE,KAAK,GAAGS,QAAQ,CAACI,KAAK,IAAI,CAAC;QACvC,CAAC,MAAM;UACLrB,IAAI,CAACQ,KAAK,GAAG,EAAE;UACfF,SAAS,CAACE,KAAK,GAAG,CAAC;UACnBW,OAAO,CAACG,IAAI,CAAC,gBAAgB,EAAEL,QAAQ,CAAC;QAC1C;MACF,CAAC,CAAC,OAAOM,KAAK,EAAE;QACdJ,OAAO,CAACI,KAAK,CAAC,WAAW,EAAEA,KAAK,CAAC;QACjC3B,SAAS,CAAC2B,KAAK,CAAC,YAAY,IAAIA,KAAK,CAACC,OAAO,IAAI,MAAM,CAAC,CAAC;QACzDxB,IAAI,CAACQ,KAAK,GAAG,EAAE;QACfF,SAAS,CAACE,KAAK,GAAG,CAAC;MACrB,CAAC,SAAS;QACRT,OAAO,CAACS,KAAK,GAAG,KAAK;MACvB;IACF,CAAC;;IAED;IACA,MAAMiB,UAAU,GAAIC,SAAS,IAAK;MAChC,IAAI,CAACA,SAAS,EAAE,OAAO,IAAI;MAC3B,MAAMC,IAAI,GAAG,IAAIC,IAAI,CAACF,SAAS,CAAC;MAChC,OAAOC,IAAI,C