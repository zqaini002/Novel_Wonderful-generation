{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport { Modal } from 'bootstrap';\nimport userService from '@/services/user';\nimport novelService from '@/services/novel';\nexport default {\n  name: 'MyNovelsView',\n  data() {\n    return {\n      novels: [],\n      loading: true,\n      error: null,\n      selectedNovel: null,\n      deleteModal: null\n    };\n  },\n  created() {\n    this.fetchUserNovels();\n  },\n  mounted() {\n    this.deleteModal = new Modal(document.getElementById('deleteConfirmModal'));\n  },\n  methods: {\n    async fetchUserNovels() {\n      this.loading = true;\n      this.error = null;\n      try {\n        const response = await userService.getUserNovels();\n        this.novels = response.data.novels || [];\n      } catch (error) {\n        console.error('获取小说列表失败:', error);\n        this.error = error.response?.data?.error || '获取小说列表失败，请稍后重试';\n      } finally {\n        this.loading = false;\n      }\n    },\n    formatDate(dateString) {\n      if (!dateString) return '未知';\n      const date = new Date(dateString);\n      return date.toLocaleDateString('zh-CN', {\n        year: 'numeric',\n        month: '2-digit',\n        day: '2-digit',\n        hour: '2-digit',\n        minute: '2-digit'\n      });\n    },\n    getStatusText(status) {\n      const statusMap = {\n        'PENDING': '待处理',\n        'PROCESSING': '处理中',\n        'COMPLETED': '已完成',\n        'FAILED': '处理失败'\n      };\n      return statusMap[status] || status;\n    },\n    getStatusBadgeClass(status) {\n      const classMap = {\n        'PENDING': 'badge bg-warning',\n        'PROCESSING': 'badge bg-info',\n        'COMPLETED': 'badge bg-success',\n        'FAILED': 'badge bg-danger'\n      };\n      return classMap[status] || 'badge bg-secondary';\n    },\n    goToAnalyze(novelId) {\n      this.$router.push(`/analyze/${novelId}`);\n    },\n    confirmDelete(novel) {\n      this.selectedNovel = novel;\n      this.deleteModal.show();\n    },\n    async deleteNovel() {\n      if (!this.selectedNovel) return;\n      try {\n        await novelService.deleteNovel(this.selectedNovel.id);\n        this.novels = this.novels.filter(novel => novel.id !== this.selectedNovel.id);\n        this.$toast.success('小说删除成功');\n      } catch (error) {\n        console.error('删除小说失败:', error);\n        this.$toast.error(error.response?.data?.error || '删除小说失败，请稍后重试');\n      } finally {\n        this.deleteModal.hide();\n        this.selectedNovel = null;\n      }\n    }\n  }\n};","map":{"version":3,"names":["Modal","userService","novelService","name","data","novels","loading","error","selectedNovel","deleteModal","created","fetchUserNovels","mounted","document","getElementById","methods","response","getUserNovels","console","formatDate","dateString","date","Date","toLocaleDateString","year","month","day","hour","minute","getStatusText","status","statusMap","getStatusBadgeClass","classMap","goToAnalyze","novelId","$router","push","confirmDelete","novel","show","deleteNovel","id","filter","$toast","success","hide"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\views\\MyNovelsView.vue"],"sourcesContent":["<template>\r\n  <div class=\"my-novels-container\">\r\n    <h1>我的小说</h1>\r\n    \r\n    <div v-if=\"loading\" class=\"loading-container\">\r\n      <div class=\"spinner-border text-primary\" role=\"status\">\r\n        <span class=\"visually-hidden\">加载中...</span>\r\n      </div>\r\n      <p>正在加载您的小说列表...</p>\r\n    </div>\r\n    \r\n    <div v-else-if=\"error\" class=\"error-container\">\r\n      <div class=\"alert alert-danger\" role=\"alert\">\r\n        <i class=\"bi bi-exclamation-triangle-fill me-2\"></i>\r\n        {{ error }}\r\n      </div>\r\n      <button class=\"btn btn-primary mt-3\" @click=\"fetchUserNovels\">\r\n        <i class=\"bi bi-arrow-clockwise me-1\"></i> 重试\r\n      </button>\r\n    </div>\r\n    \r\n    <div v-else-if=\"novels.length === 0\" class=\"empty-container\">\r\n      <div class=\"alert alert-info\" role=\"alert\">\r\n        <i class=\"bi bi-info-circle-fill me-2\"></i>\r\n        您还没有上传任何小说。\r\n      </div>\r\n      <router-link to=\"/upload\" class=\"btn btn-primary mt-3\">\r\n        <i class=\"bi bi-upload me-1\"></i> 去上传小说\r\n      </router-link>\r\n    </div>\r\n    \r\n    <div v-else class=\"novels-list\">\r\n      <div class=\"row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4\">\r\n        <div v-for=\"novel in novels\" :key=\"novel.id\" class=\"col\">\r\n          <div class=\"card h-100 novel-card\">\r\n            <div class=\"card-body\">\r\n              <h5 class=\"card-title\">{{ novel.title }}</h5>\r\n              <p class=\"card-text text-muted\">\r\n                <small>\r\n                  <i class=\"bi bi-calendar-event me-1\"></i>\r\n                  上传时间: {{ formatDate(novel.createTime) }}\r\n                </small>\r\n              </p>\r\n              <p class=\"card-text status-badge\">\r\n                <span :class=\"getStatusBadgeClass(novel.status)\">{{ getStatusText(novel.status) }}</span>\r\n              </p>\r\n              <p class=\"card-text description\">{{ novel.description || '暂无简介' }}</p>\r\n            </div>\r\n            <div class=\"card-footer bg-transparent border-top-0\">\r\n              <router-link :to=\"`/novel/${novel.id}`\" class=\"btn btn-outline-primary btn-sm me-2\">\r\n                <i class=\"bi bi-book me-1\"></i> 查看详情\r\n              </router-link>\r\n              <button \r\n                v-if=\"novel.status === 'COMPLETED'\" \r\n                class=\"btn btn-outline-success btn-sm me-2\"\r\n                @click=\"goToAnalyze(novel.id)\"\r\n              >\r\n                <i class=\"bi bi-graph-up me-1\"></i> 查看分析\r\n              </button>\r\n              <button \r\n                class=\"btn btn-outline-danger btn-sm\"\r\n                @click=\"confirmDelete(novel)\"\r\n              >\r\n                <i class=\"bi bi-trash me-1\"></i> 删除\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    \r\n    <!-- 删除确认对话框 -->\r\n    <div class=\"modal fade\" id=\"deleteConfirmModal\" tabindex=\"-1\" aria-labelledby=\"deleteConfirmModalLabel\" aria-hidden=\"true\">\r\n      <div class=\"modal-dialog\">\r\n        <div class=\"modal-content\">\r\n          <div class=\"modal-header\">\r\n            <h5 class=\"modal-title\" id=\"deleteConfirmModalLabel\">确认删除</h5>\r\n            <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\" aria-label=\"Close\"></button>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            <p>您确定要删除小说 <strong>{{ selectedNovel?.title }}</strong> 吗？</p>\r\n            <p class=\"text-danger\">此操作不可逆，删除后将无法恢复！</p>\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">取消</button>\r\n            <button type=\"button\" class=\"btn btn-danger\" @click=\"deleteNovel\">确认删除</button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { Modal } from 'bootstrap';\r\nimport userService from '@/services/user';\r\nimport novelService from '@/services/novel';\r\n\r\nexport default {\r\n  name: 'MyNovelsView',\r\n  data() {\r\n    return {\r\n      novels: [],\r\n      loading: true,\r\n      error: null,\r\n      selectedNovel: null,\r\n      deleteModal: null\r\n    };\r\n  },\r\n  created() {\r\n    this.fetchUserNovels();\r\n  },\r\n  mounted() {\r\n    this.deleteModal = new Modal(document.getElementById('deleteConfirmModal'));\r\n  },\r\n  methods: {\r\n    async fetchUserNovels() {\r\n      this.loading = true;\r\n      this.error = null;\r\n      \r\n      try {\r\n        const response = await userService.getUserNovels();\r\n        this.novels = response.data.novels || [];\r\n      } catch (error) {\r\n        console.error('获取小说列表失败:', error);\r\n        this.error = error.response?.data?.error || '获取小说列表失败，请稍后重试';\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n    formatDate(dateString) {\r\n      if (!dateString) return '未知';\r\n      const date = new Date(dateString);\r\n      return date.toLocaleDateString('zh-CN', {\r\n        year: 'numeric',\r\n        month: '2-digit',\r\n        day: '2-digit',\r\n        hour: '2-digit',\r\n        minute: '2-digit'\r\n      });\r\n    },\r\n    getStatusText(status) {\r\n      const statusMap = {\r\n        'PENDING': '待处理',\r\n        'PROCESSING': '处理中',\r\n        'COMPLETED': '已完成',\r\n        'FAILED': '处理失败'\r\n      };\r\n      return statusMap[status] || status;\r\n    },\r\n    getStatusBadgeClass(status) {\r\n      const classMap = {\r\n        'PENDING': 'badge bg-warning',\r\n        'PROCESSING': 'badge bg-info',\r\n        'COMPLETED': 'badge bg-success',\r\n        'FAILED': 'badge bg-danger'\r\n      };\r\n      return classMap[status] || 'badge bg-secondary';\r\n    },\r\n    goToAnalyze(novelId) {\r\n      this.$router.push(`/analyze/${novelId}`);\r\n    },\r\n    confirmDelete(novel) {\r\n      this.selectedNovel = novel;\r\n      this.deleteModal.show();\r\n    },\r\n    async deleteNovel() {\r\n      if (!this.selectedNovel) return;\r\n      \r\n      try {\r\n        await novelService.deleteNovel(this.selectedNovel.id);\r\n        this.novels = this.novels.filter(novel => novel.id !== this.selectedNovel.id);\r\n        this.$toast.success('小说删除成功');\r\n      } catch (error) {\r\n        console.error('删除小说失败:', error);\r\n        this.$toast.error(error.response?.data?.error || '删除小说失败，请稍后重试');\r\n      } finally {\r\n        this.deleteModal.hide();\r\n        this.selectedNovel = null;\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.my-novels-container {\r\n  padding: 2rem 0;\r\n}\r\n\r\n.loading-container, .error-container, .empty-container {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  min-height: 300px;\r\n  text-align: center;\r\n}\r\n\r\n.novel-card {\r\n  transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;\r\n}\r\n\r\n.novel-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 6px 12px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.status-badge {\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n.description {\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 3;\r\n  -webkit-box-orient: vertical;\r\n  min-height: 4.5rem;\r\n}\r\n</style> "],"mappings":";;;AA8FA,SAASA,KAAI,QAAS,WAAW;AACjC,OAAOC,WAAU,MAAO,iBAAiB;AACzC,OAAOC,YAAW,MAAO,kBAAkB;AAE3C,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAE,EAAE;MACVC,OAAO,EAAE,IAAI;MACbC,KAAK,EAAE,IAAI;MACXC,aAAa,EAAE,IAAI;MACnBC,WAAW,EAAE;IACf,CAAC;EACH,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,eAAe,CAAC,CAAC;EACxB,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACH,WAAU,GAAI,IAAIT,KAAK,CAACa,QAAQ,CAACC,cAAc,CAAC,oBAAoB,CAAC,CAAC;EAC7E,CAAC;EACDC,OAAO,EAAE;IACP,MAAMJ,eAAeA,CAAA,EAAG;MACtB,IAAI,CAACL,OAAM,GAAI,IAAI;MACnB,IAAI,CAACC,KAAI,GAAI,IAAI;MAEjB,IAAI;QACF,MAAMS,QAAO,GAAI,MAAMf,WAAW,CAACgB,aAAa,CAAC,CAAC;QAClD,IAAI,CAACZ,MAAK,GAAIW,QAAQ,CAACZ,IAAI,CAACC,MAAK,IAAK,EAAE;MAC1C,EAAE,OAAOE,KAAK,EAAE;QACdW,OAAO,CAACX,KAAK,CAAC,WAAW,EAAEA,KAAK,CAAC;QACjC,IAAI,CAACA,KAAI,GAAIA,KAAK,CAACS,QAAQ,EAAEZ,IAAI,EAAEG,KAAI,IAAK,gBAAgB;MAC9D,UAAU;QACR,IAAI,CAACD,OAAM,GAAI,KAAK;MACtB;IACF,CAAC;IACDa,UAAUA,CAACC,UAAU,EAAE;MACrB,IAAI,CAACA,UAAU,EAAE,OAAO,IAAI;MAC5B,MAAMC,IAAG,GAAI,IAAIC,IAAI,CAACF,UAAU,CAAC;MACjC,OAAOC,IAAI,CAACE,kBAAkB,CAAC,OAAO,EAAE;QACtCC,IAAI,EAAE,SAAS;QACfC,KAAK,EAAE,SAAS;QAChBC,GAAG,EAAE,SAAS;QACdC,IAAI,EAAE,SAAS;QACfC,MAAM,EAAE;MACV,CAAC,CAAC;IACJ,CAAC;IACDC,aAAaA,CAACC,MAAM,EAAE;MACpB,MAAMC,SAAQ,GAAI;QAChB,SAAS,EAAE,KAA