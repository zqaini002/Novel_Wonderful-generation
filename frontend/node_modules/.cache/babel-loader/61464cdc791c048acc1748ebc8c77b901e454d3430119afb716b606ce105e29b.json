{"ast":null,"code":"import { createElementVNode as _createElementVNode, openBlock as _openBlock, createElementBlock as _createElementBlock, createCommentVNode as _createCommentVNode, normalizeStyle as _normalizeStyle } from \"vue\";\nconst _hoisted_1 = {\n  class: \"chart-container\"\n};\nconst _hoisted_2 = {\n  key: 0,\n  class: \"loading-overlay\"\n};\nconst _hoisted_3 = {\n  key: 1,\n  class: \"no-data-message\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", _hoisted_1, [$props.loading ? (_openBlock(), _createElementBlock(\"div\", _hoisted_2, _cache[0] || (_cache[0] = [_createElementVNode(\"div\", {\n    class: \"loading-spinner\"\n  }, null, -1 /* HOISTED */), _createElementVNode(\"div\", {\n    class: \"loading-text\"\n  }, \"加载中...\", -1 /* HOISTED */)]))) : !$setup.hasData ? (_openBlock(), _createElementBlock(\"div\", _hoisted_3, _cache[1] || (_cache[1] = [_createElementVNode(\"i\", {\n    class: \"el-icon-warning-outline\"\n  }, null, -1 /* HOISTED */), _createElementVNode(\"p\", null, \"暂无人物关系数据\", -1 /* HOISTED */)]))) : _createCommentVNode(\"v-if\", true), _createElementVNode(\"div\", {\n    ref: \"chartRef\",\n    class: \"character-network-chart\",\n    style: _normalizeStyle({\n      opacity: $setup.hasData ? 1 : 0\n    })\n  }, null, 4 /* STYLE */)]);\n}","map":{"version":3,"names":["class","key","_createElementBlock","_hoisted_1","$props","loading","_hoisted_2","_cache","_createElementVNode","$setup","hasData","_hoisted_3","_createCommentVNode","ref","style","_normalizeStyle","opacity"],"sources":["E:\\Novel_Wonderful generation\\novel-assistant\\frontend\\src\\components\\visualization\\CharacterNetworkChart.vue"],"sourcesContent":["<template>\r\n  <div class=\"chart-container\">\r\n    <div v-if=\"loading\" class=\"loading-overlay\">\r\n      <div class=\"loading-spinner\"></div>\r\n      <div class=\"loading-text\">加载中...</div>\r\n    </div>\r\n    <div v-else-if=\"!hasData\" class=\"no-data-message\">\r\n      <i class=\"el-icon-warning-outline\"></i>\r\n      <p>暂无人物关系数据</p>\r\n    </div>\r\n    <div ref=\"chartRef\" class=\"character-network-chart\" :style=\"{ opacity: hasData ? 1 : 0 }\"></div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted, onBeforeUnmount, watch, computed } from 'vue'\r\nimport * as echarts from 'echarts'\r\n\r\nexport default {\r\n  name: 'CharacterNetworkChart',\r\n  props: {\r\n    // 人物关系数据\r\n    characterData: {\r\n      type: Object,\r\n      required: true,\r\n      default: () => ({ nodes: [], links: [] })\r\n    },\r\n    // 图表标题\r\n    title: {\r\n      type: String,\r\n      default: '人物关系网络'\r\n    },\r\n    // 图表高度\r\n    height: {\r\n      type: String,\r\n      default: '600px'\r\n    },\r\n    // 图表宽度\r\n    width: {\r\n      type: String,\r\n      default: '100%'\r\n    },\r\n    // 加载状态\r\n    loading: {\r\n      type: Boolean,\r\n      default: false\r\n    }\r\n  },\r\n  setup(props) {\r\n    const chartRef = ref(null)\r\n    let chart = null\r\n    \r\n    // 计算是否有数据\r\n    const hasData = computed(() => {\r\n      return props.characterData && \r\n             props.characterData.nodes && \r\n             props.characterData.nodes.length > 0 &&\r\n             props.characterData.links &&\r\n             props.characterData.links.length > 0;\r\n    });\r\n\r\n    // 初始化图表\r\n    const initChart = () => {\r\n      // 确保DOM已挂载\r\n      if (!chartRef.value) return\r\n\r\n      // 检查DOM元素是否有尺寸\r\n      if (chartRef.value.clientWidth === 0 || chartRef.value.clientHeight === 0) {\r\n        // 如果没有尺寸，延迟初始化\r\n        setTimeout(() => {\r\n          initChart();\r\n        }, 300);\r\n        return;\r\n      }\r\n\r\n      // 销毁旧图表\r\n      if (chart) {\r\n        chart.dispose()\r\n      }\r\n\r\n      // 初始化图表实例\r\n      chart = echarts.init(chartRef.value)\r\n      \r\n      // 如果没有数据\r\n      if (!hasData.value) {\r\n        return;\r\n      }\r\n      \r\n      // 处理数据\r\n      const { categories, nodes, links } = formatCharacterData(props.characterData)\r\n      \r\n      // 设置图表选项\r\n      const option = {\r\n        title: {\r\n          text: props.title,\r\n          top: 'top',\r\n          left: 'center',\r\n          textStyle: {\r\n            fontWeight: 'normal',\r\n            fontSize: 16\r\n          }\r\n        },\r\n        tooltip: {\r\n          trigger: 'item',\r\n          formatter: function(params) {\r\n            if (params.dataType === 'node') {\r\n              // 节点tooltip\r\n              return `<div style=\"font-weight:bold;color:#fff;font-size:14px;margin-bottom:5px;\">${params.data.name}</div>\r\n                      <div>角色类型: ${params.data.category || '未知'}</div>\r\n                      ${params.data.description ? `<div>描述: ${params.data.description}</div>` : ''}\r\n                      <div>重要度: ${params.data.symbolSize / 10}</div>`;\r\n            } else {\r\n              // 边tooltip\r\n              return `<div style=\"font-weight:bold;color:#fff;font-size:14px;margin-bottom:5px;\">${params.data.source} → ${params.data.target}</div>\r\n                      <div>关系: ${params.data.relation || '关联'}</div>\r\n                      ${params.data.description ? `<div>描述: ${params.data.description}</div>` : ''}`;\r\n            }\r\n          },\r\n          backgroundColor: 'rgba(50,50,50,0.8)',\r\n          borderColor: '#ccc',\r\n          borderWidth: 0,\r\n          padding: [5, 10],\r\n          textStyle: {\r\n            color: '#fff'\r\n          }\r\n        },\r\n        legend: {\r\n          data: categories.map(category => category.name),\r\n          orient: 'vertical',\r\n          right: 10,\r\n          top: 'middle',\r\n          textStyle: {\r\n            color: '#333'\r\n          },\r\n          itemWidth: 10,\r\n          itemHeight: 10,\r\n          itemGap: 10\r\n        },\r\n        toolbox: {\r\n          show: true,\r\n          feature: {\r\n            restore: {\r\n              show: true,\r\n              title: '重置视图'\r\n            },\r\n            saveAsImage: {\r\n              show: true,\r\n              title: '保存为图片'\r\n            }\r\n          }\r\n        },\r\n        animationDuration: 1500,\r\n        animationEasingUpdate: 'quinticInOut',\r\n        series: [{\r\n          name: '人物关系',\r\n          type: 'graph',\r\n          layout: 'force',\r\n          data: nodes,\r\n          links: links,\r\n          categories: categories,\r\n          roam: true,\r\n          label: {\r\n            show: true,\r\n            position: 'right',\r\n            formatter: '{b}'\r\n          },\r\n          force: {\r\n            repulsion: 100,\r\n            gravity: 0.1,\r\n            edgeLength: [50, 100],\r\n            layoutAnimation: true\r\n          },\r\n          lineStyle: {\r\n            color: 'source',\r\n            curveness: 0.3,\r\n            width: 1.5\r\n          },\r\n          emphasis: {\r\n            focus: 'adjacency',\r\n            lineStyle: {\r\n              width: 5\r\n            }\r\n          }\r\n        }]\r\n      };\r\n\r\n      // 渲染图表\r\n      chart.setOption(option)\r\n    }\r\n\r\n    // 格式化角色数据\r\n    const formatCharacterData = (data) => {\r\n      if (!data || !data.nodes || !data.links) {\r\n        return { categories: [], nodes: [], links: [] }\r\n      }\r\n\r\n      // 角色类型分类\r\n      let categories = []\r\n      \r\n      // 如果数据中提供了分类，则使用\r\n      if (data.categories && Array.isArray(data.categories)) {\r\n        categories = data.categories\r\n      } else {\r\n        // 否则从节点中提取分类\r\n        const categorySet = new Set()\r\n        data.nodes.forEach(node => {\r\n          if (node.category) {\r\n            categorySet.add(node.category)\r\n          }\r\n        })\r\n        categories = Array.from(categorySet).map(name => ({ name }))\r\n        \r\n        // 如果没有分类，添加默认分类\r\n        if (categories.length === 0) {\r\n          categories = [\r\n            { name: '主要角色' },\r\n            { name: '次要角色' },\r\n            { name: '配角' }\r\n          ]\r\n        }\r\n      }\r\n\r\n      // 复制节点数组并确保每个节点有必要的属性\r\n      const nodes = data.nodes.map((node, index) => {\r\n        return {\r\n          id: node.id || index,\r\n          name: node.name || `角色${index}`,\r\n          symbolSize: node.value ? Math.max(node.value * 5, 20) : 40,\r\n          value: node.value || 1,\r\n          category: node.category || (\r\n            index < 3 ? '主要角色' : (index < 8 ? '次要角色' : '配角')\r\n          ),\r\n          x: node.x,\r\n          y: node.y,\r\n          draggable: true,\r\n          description: node.description || '',\r\n          itemStyle: node.itemStyle || {\r\n            color: node.color\r\n          }\r\n        }\r\n      })\r\n\r\n      // 复制关系连线数组并确保每个连线有必要的属性\r\n      const links = data.links.map((link, index) => {\r\n        return {\r\n          source: typeof link.source === 'number' ? \r\n                 (data.nodes[link.source] ? data.nodes[link.source].name : link.source) : \r\n                 link.source,\r\n          target: typeof link.target === 'number' ? \r\n                 (data.nodes[link.target] ? data.nodes[link.target].name : link.target) : \r\n                 link.target,\r\n          value: link.value || 1,\r\n          relation: link.relation || '',\r\n          description: link.description || '',\r\n          lineStyle: link.lineStyle || {\r\n            width: link.value ? Math.max(link.value, 1) : 1,\r\n            color: link.color\r\n          }\r\n        }\r\n      })\r\n\r\n      return { categories, nodes, links }\r\n    }\r\n\r\n    // 处理窗口大小改变\r\n    const handleResize = () => {\r\n      chart && chart.resize()\r\n    }\r\n\r\n    // 监听数据变化\r\n    watch(() => props.characterData, (newVal) => {\r\n      if (chart && hasData.value) {\r\n        const { categories, nodes, links } = formatCharacterData(newVal)\r\n        chart.setOption({\r\n          legend: {\r\n            data: categories.map(category => category.name)\r\n          },\r\n          series: [{\r\n            data: nodes,\r\n            links: links,\r\n            categories: categories\r\n          }]\r\n        })\r\n      } else if (chartRef.value && hasData.value) {\r\n        // 如果图表还未初始化，则初始化\r\n        initChart()\r\n      }\r\n    }, { deep: true })\r\n    \r\n    // 监听加载状态\r\n    watch(() => props.loading, (newVal) => {\r\n      if (!newVal && !chart && chartRef.value && hasData.value) {\r\n        // 加载完成且图表未初始化\r\n        initChart()\r\n      }\r\n    })\r\n\r\n    // 组件挂载时初始化图表\r\n    onMounted(() => {\r\n      // 使用nextTick确保DOM已渲染\r\n      // 如果窗口已经加载完成\r\n      if (document.readyState === 'complete') {\r\n        setTimeout(() => {\r\n          if (!props.loading && hasData.value) {\r\n            initChart();\r\n          }\r\n        }, 300);\r\n      } else {\r\n        // 否则等待窗口完全加载\r\n        window.addEventListener('load', () => {\r\n          setTimeout(() => {\r\n            if (!props.loading && hasData.value) {\r\n              initChart();\r\n            }\r\n          }, 300);\r\n        });\r\n      }\r\n      \r\n      // 确保在组件销毁时移除事件监听\r\n      window.addEventListener('resize', handleResize)\r\n    })\r\n\r\n    // 组件卸载前销毁图表\r\n    onBeforeUnmount(() => {\r\n      if (chart) {\r\n        chart.dispose()\r\n        chart = null\r\n      }\r\n      window.removeEventListener('resize', handleResize)\r\n    })\r\n\r\n    return {\r\n      chartRef,\r\n      hasData,\r\n      chart\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.chart-container {\r\n  width: v-bind(width);\r\n  height: v-bind(height);\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.character-network-chart {\r\n  width: 100%;\r\n  height: 100%;\r\n  transition: opacity 0.3s ease;\r\n}\r\n\r\n.loading-overlay {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n  align-items: center;\r\n  background-color: rgba(255, 255, 255, 0.8);\r\n  z-index: 10;\r\n}\r\n\r\n.loading-spinner {\r\n  width: 40px;\r\n  height: 40px;\r\n  border: 3px solid #f3f3f3;\r\n  border-top: 3px solid #3498db;\r\n  border-radius: 50%;\r\n  animation: spin 1s linear infinite;\r\n}\r\n\r\n.loading-text {\r\n  margin-top: 10px;\r\n  color: #666;\r\n}\r\n\r\n.no-data-message {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: #909399;\r\n  font-size: 14px;\r\n}\r\n\r\n.no-data-message i {\r\n  font-size: 32px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n@keyframes spin {\r\n  0% { transform: rotate(0deg); }\r\n  100% { transform: rotate(360deg); }\r\n}\r\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAiB;;EAD9BC,GAAA;EAEwBD,KAAK,EAAC;;;EAF9BC,GAAA;EAM8BD,KAAK,EAAC;;;uBALlCE,mBAAA,CAUM,OAVNC,UAUM,GATOC,MAAA,CAAAC,OAAO,I,cAAlBH,mBAAA,CAGM,OAHNI,UAGM,EAAAC,MAAA,QAAAA,MAAA,OAFJC,mBAAA,CAAmC;IAA9BR,KAAK,EAAC;EAAiB,4BAC5BQ,mBAAA,CAAsC;IAAjCR,KAAK,EAAC;EAAc,GAAC,QAAM,oB,OAEjBS,MAAA,CAAAC,OAAO,I,cAAxBR,mBAAA,CAGM,OAHNS,UAGM,EAAAJ,MAAA,QAAAA,MAAA,OAFJC,mBAAA,CAAuC;IAApCR,KAAK,EAAC;EAAyB,4BAClCQ,mBAAA,CAAe,WAAZ,UAAQ,oB,MARjBI,mBAAA,gBAUIJ,mBAAA,CAAgG;IAA3FK,GAAG,EAAC,UAAU;IAACb,KAAK,EAAC,yBAAyB;IAAEc,KAAK,EAV9DC,eAAA;MAAAC,OAAA,EAU2EP,MAAA,CAAAC,OAAO;IAAA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}