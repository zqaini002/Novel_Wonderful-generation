{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, onMounted } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { ElMessage, ElMessageBox } from 'element-plus';\nimport { User, UserFilled, Reading, Loading, Check, Document, Delete } from '@element-plus/icons-vue';\nimport adminService from '@/api/admin';\nexport default {\n  __name: 'DashboardView',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const router = useRouter();\n    const loading = ref(true);\n    const stats = ref({\n      totalUsers: 0,\n      newUsers: 0,\n      totalNovels: 0,\n      processingNovels: 0,\n      completedNovels: 0\n    });\n\n    // 获取仪表盘数据\n    const fetchDashboardData = async () => {\n      loading.value = true;\n      try {\n        const response = await adminService.getDashboardStats();\n        stats.value = response.data;\n      } catch (error) {\n        console.error('获取仪表盘数据失败:', error);\n        ElMessage.error('获取仪表盘数据失败');\n      } finally {\n        loading.value = false;\n      }\n    };\n\n    // 刷新数据\n    const refreshData = () => {\n      fetchDashboardData();\n    };\n\n    // 导航到用户管理\n    const goToUserManagement = () => {\n      router.push('/admin/users');\n    };\n\n    // 导航到小说管理\n    const goToNovelManagement = () => {\n      router.push('/admin/novels');\n    };\n\n    // 导航到系统日志\n    const goToSystemLogs = () => {\n      router.push('/admin/logs');\n    };\n\n    // 清理缓存\n    const clearCache = async () => {\n      try {\n        // 确认提示\n        await ElMessageBox.confirm('确定要清理系统缓存吗？这可能会暂时影响系统性能。', '确认操作', {\n          confirmButtonText: '确定',\n          cancelButtonText: '取消',\n          type: 'warning'\n        });\n\n        // 执行清理\n        const response = await adminService.clearSystemCache();\n        ElMessage.success('缓存清理成功');\n      } catch (err) {\n        if (err !== 'cancel') {\n          console.error('清理缓存失败:', err);\n          ElMessage.error('清理缓存失败');\n        }\n      }\n    };\n\n    // 组件挂载时获取数据\n    onMounted(() => {\n      fetchDashboardData();\n    });\n    const __returned__ = {\n      router,\n      loading,\n      stats,\n      fetchDashboardData,\n      refreshData,\n      goToUserManagement,\n      goToNovelManagement,\n      goToSystemLogs,\n      clearCache,\n      ref,\n      onMounted,\n      get useRouter() {\n        return useRouter;\n      },\n      get ElMessage() {\n        return ElMessage;\n      },\n      get ElMessageBox() {\n        return ElMessageBox;\n      },\n      get User() {\n        return User;\n      },\n      get UserFilled() {\n        return UserFilled;\n      },\n      get Reading() {\n        return Reading;\n      },\n      get Loading() {\n        return Loading;\n      },\n      get Check() {\n        return Check;\n      },\n      get Document() {\n        return Document;\n      },\n      get Delete() {\n        return Delete;\n      },\n      get adminService() {\n        return adminService;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useRouter","ElMessage","ElMessageBox","User","UserFilled","Reading","Loading","Check","Document","Delete","adminService","router","loading","stats","totalUsers","newUsers","totalNovels","processingNovels","completedNovels","fetchDashboardData","value","response","getDashboardStats","data","error","console","refreshData","goToUserManagement","push","goToNovelManagement","goToSystemLogs","clearCache","confirm","confirmButtonText","cancelButtonText","type","clearSystemCache","success","err"],"sources":["E:/Novel_Wonderful generation/novel-assistant/frontend/src/views/admin/DashboardView.vue"],"sourcesContent":["<template>\r\n  <div class=\"dashboard-container\">\r\n    <el-card class=\"dashboard-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <h2>系统仪表盘</h2>\r\n          <el-button type=\"primary\" @click=\"refreshData\">刷新数据</el-button>\r\n        </div>\r\n      </template>\r\n      \r\n      <div v-if=\"loading\" class=\"loading-container\">\r\n        <el-skeleton :rows=\"6\" animated />\r\n      </div>\r\n      \r\n      <div v-else class=\"dashboard-content\">\r\n        <!-- 数据统计卡片 -->\r\n        <div class=\"stats-cards\">\r\n          <el-card class=\"stat-card\" shadow=\"hover\">\r\n            <template #header>\r\n              <div class=\"stat-header\">\r\n                <span>总用户数</span>\r\n                <el-icon><User /></el-icon>\r\n              </div>\r\n            </template>\r\n            <div class=\"stat-value\">{{ stats.totalUsers }}</div>\r\n          </el-card>\r\n          \r\n          <el-card class=\"stat-card\" shadow=\"hover\">\r\n            <template #header>\r\n              <div class=\"stat-header\">\r\n                <span>新增用户</span>\r\n                <el-icon><UserFilled /></el-icon>\r\n              </div>\r\n            </template>\r\n            <div class=\"stat-value\">{{ stats.newUsers }}</div>\r\n            <div class=\"stat-desc\">过去7天</div>\r\n          </el-card>\r\n          \r\n          <el-card class=\"stat-card\" shadow=\"hover\">\r\n            <template #header>\r\n              <div class=\"stat-header\">\r\n                <span>小说总数</span>\r\n                <el-icon><Reading /></el-icon>\r\n              </div>\r\n            </template>\r\n            <div class=\"stat-value\">{{ stats.totalNovels }}</div>\r\n          </el-card>\r\n          \r\n          <el-card class=\"stat-card\" shadow=\"hover\">\r\n            <template #header>\r\n              <div class=\"stat-header\">\r\n                <span>处理中</span>\r\n                <el-icon><Loading /></el-icon>\r\n              </div>\r\n            </template>\r\n            <div class=\"stat-value\">{{ stats.processingNovels }}</div>\r\n          </el-card>\r\n          \r\n          <el-card class=\"stat-card\" shadow=\"hover\">\r\n            <template #header>\r\n              <div class=\"stat-header\">\r\n                <span>已完成</span>\r\n                <el-icon><Check /></el-icon>\r\n              </div>\r\n            </template>\r\n            <div class=\"stat-value\">{{ stats.completedNovels }}</div>\r\n          </el-card>\r\n        </div>\r\n        \r\n        <!-- 快捷功能区 -->\r\n        <el-card class=\"quick-actions\" shadow=\"hover\">\r\n          <template #header>\r\n            <div class=\"card-header\">\r\n              <h3>快捷操作</h3>\r\n            </div>\r\n          </template>\r\n          \r\n          <div class=\"actions-grid\">\r\n            <el-button @click=\"goToUserManagement\">\r\n              <el-icon><User /></el-icon>\r\n              用户管理\r\n            </el-button>\r\n            \r\n            <el-button @click=\"goToNovelManagement\">\r\n              <el-icon><Reading /></el-icon>\r\n              小说管理\r\n            </el-button>\r\n            \r\n            <el-button @click=\"goToSystemLogs\">\r\n              <el-icon><Document /></el-icon>\r\n              系统日志\r\n            </el-button>\r\n            \r\n            <el-button @click=\"clearCache\">\r\n              <el-icon><Delete /></el-icon>\r\n              清理缓存\r\n            </el-button>\r\n          </div>\r\n        </el-card>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport { useRouter } from 'vue-router'\r\nimport { ElMessage, ElMessageBox } from 'element-plus'\r\nimport { User, UserFilled, Reading, Loading, Check, Document, Delete } from '@element-plus/icons-vue'\r\nimport adminService from '@/api/admin'\r\n\r\nconst router = useRouter()\r\nconst loading = ref(true)\r\nconst stats = ref({\r\n  totalUsers: 0,\r\n  newUsers: 0,\r\n  totalNovels: 0,\r\n  processingNovels: 0,\r\n  completedNovels: 0\r\n})\r\n\r\n// 获取仪表盘数据\r\nconst fetchDashboardData = async () => {\r\n  loading.value = true\r\n  try {\r\n    const response = await adminService.getDashboardStats()\r\n    stats.value = response.data\r\n  } catch (error) {\r\n    console.error('获取仪表盘数据失败:', error)\r\n    ElMessage.error('获取仪表盘数据失败')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\n// 刷新数据\r\nconst refreshData = () => {\r\n  fetchDashboardData()\r\n}\r\n\r\n// 导航到用户管理\r\nconst goToUserManagement = () => {\r\n  router.push('/admin/users')\r\n}\r\n\r\n// 导航到小说管理\r\nconst goToNovelManagement = () => {\r\n  router.push('/admin/novels')\r\n}\r\n\r\n// 导航到系统日志\r\nconst goToSystemLogs = () => {\r\n  router.push('/admin/logs')\r\n}\r\n\r\n// 清理缓存\r\nconst clearCache = async () => {\r\n  try {\r\n    // 确认提示\r\n    await ElMessageBox.confirm(\r\n      '确定要清理系统缓存吗？这可能会暂时影响系统性能。',\r\n      '确认操作',\r\n      {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }\r\n    )\r\n    \r\n    // 执行清理\r\n    const response = await adminService.clearSystemCache()\r\n    ElMessage.success('缓存清理成功')\r\n  } catch (err) {\r\n    if (err !== 'cancel') {\r\n      console.error('清理缓存失败:', err)\r\n      ElMessage.error('清理缓存失败')\r\n    }\r\n  }\r\n}\r\n\r\n// 组件挂载时获取数据\r\nonMounted(() => {\r\n  fetchDashboardData()\r\n})\r\n</script>\r\n\r\n<style scoped>\r\n.dashboard-container {\r\n  padding: 20px;\r\n}\r\n\r\n.dashboard-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.loading-container {\r\n  padding: 20px;\r\n}\r\n\r\n.dashboard-content {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 20px;\r\n}\r\n\r\n.stats-cards {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\r\n  gap: 15px;\r\n}\r\n\r\n.stat-card {\r\n  text-align: center;\r\n}\r\n\r\n.stat-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.stat-value {\r\n  font-size: 36px;\r\n  font-weight: bold;\r\n  margin: 10px 0;\r\n}\r\n\r\n.stat-desc {\r\n  color: #909399;\r\n  font-size: 12px;\r\n}\r\n\r\n.quick-actions {\r\n  margin-top: 10px;\r\n}\r\n\r\n.actions-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));\r\n  gap: 10px;\r\n}\r\n\r\n.actions-grid .el-button {\r\n  display: flex;\r\n  flex-direction: column;\r\n  height: 80px;\r\n  justify-content: center;\r\n  align-items: center;\r\n}\r\n\r\n.actions-grid .el-icon {\r\n  font-size: 24px;\r\n  margin-bottom: 5px;\r\n}\r\n</style> \r\n "],"mappings":";AAyGA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,SAAS,QAAQ,YAAY;AACtC,SAASC,SAAS,EAAEC,YAAY,QAAQ,cAAc;AACtD,SAASC,IAAI,EAAEC,UAAU,EAAEC,OAAO,EAAEC,OAAO,EAAEC,KAAK,EAAEC,QAAQ,EAAEC,MAAM,QAAQ,yBAAyB;AACrG,OAAOC,YAAY,MAAM,aAAa;;;;;;;IAEtC,MAAMC,MAAM,GAAGX,SAAS,CAAC,CAAC;IAC1B,MAAMY,OAAO,GAAGd,GAAG,CAAC,IAAI,CAAC;IACzB,MAAMe,KAAK,GAAGf,GAAG,CAAC;MAChBgB,UAAU,EAAE,CAAC;MACbC,QAAQ,EAAE,CAAC;MACXC,WAAW,EAAE,CAAC;MACdC,gBAAgB,EAAE,CAAC;MACnBC,eAAe,EAAE;IACnB,CAAC,CAAC;;IAEF;IACA,MAAMC,kBAAkB,GAAG,MAAAA,CAAA,KAAY;MACrCP,OAAO,CAACQ,KAAK,GAAG,IAAI;MACpB,IAAI;QACF,MAAMC,QAAQ,GAAG,MAAMX,YAAY,CAACY,iBAAiB,CAAC,CAAC;QACvDT,KAAK,CAACO,KAAK,GAAGC,QAAQ,CAACE,IAAI;MAC7B,CAAC,CAAC,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,YAAY,EAAEA,KAAK,CAAC;QAClCvB,SAAS,CAACuB,KAAK,CAAC,WAAW,CAAC;MAC9B,CAAC,SAAS;QACRZ,OAAO,CAACQ,KAAK,GAAG,KAAK;MACvB;IACF,CAAC;;IAED;IACA,MAAMM,WAAW,GAAGA,CAAA,KAAM;MACxBP,kBAAkB,CAAC,CAAC;IACtB,CAAC;;IAED;IACA,MAAMQ,kBAAkB,GAAGA,CAAA,KAAM;MAC/BhB,MAAM,CAACiB,IAAI,CAAC,cAAc,CAAC;IAC7B,CAAC;;IAED;IACA,MAAMC,mBAAmB,GAAGA,CAAA,KAAM;MAChClB,MAAM,CAACiB,IAAI,CAAC,eAAe,CAAC;IAC9B,CAAC;;IAED;IACA,MAAME,cAAc,GAAGA,CAAA,KAAM;MAC3BnB,MAAM,CAACiB,IAAI,CAAC,aAAa,CAAC;IAC5B,CAAC;;IAED;IACA,MAAMG,UAAU,GAAG,MAAAA,CAAA,KAAY;MAC7B,IAAI;QACF;QACA,MAAM7B,YAAY,CAAC8B,OAAO,CACxB,0BAA0B,EAC1B,MAAM,EACN;UACEC,iBAAiB,EAAE,IAAI;UACvBC,gBAAgB,EAAE,IAAI;UACtBC,IAAI,EAAE;QACR,CACF,CAAC;;QAED;Q